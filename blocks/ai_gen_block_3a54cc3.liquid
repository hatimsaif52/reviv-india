{% doc %}
  @prompt
    animeted number going up , with title at the top and bottom , make sure to add custumaition of paddings margins and size
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-counter-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: {{ block.settings.margin_left }}px;
    margin-right: {{ block.settings.margin_right }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-counter-title-top-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_top_size }}px;
    color: {{ block.settings.title_top_color }};
    margin: 0 0 {{ block.settings.title_top_spacing }}px 0;
    font-weight: {{ block.settings.title_top_weight }};
  }

  .ai-counter-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    color: {{ block.settings.number_color }};
    font-weight: {{ block.settings.number_weight }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-counter-title-bottom-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_bottom_size }}px;
    color: {{ block.settings.title_bottom_color }};
    margin: {{ block.settings.title_bottom_spacing }}px 0 0 0;
    font-weight: {{ block.settings.title_bottom_weight }};
  }
{% endstyle %}

<animated-counter-{{ ai_gen_id }}
  class="ai-counter-{{ ai_gen_id }}"
  data-target="{{ block.settings.target_number }}"
  data-duration="{{ block.settings.animation_duration }}"
  data-prefix="{{ block.settings.number_prefix }}"
  data-suffix="{{ block.settings.number_suffix }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title_top != blank %}
    <h3 class="ai-counter-title-top-{{ ai_gen_id }}">{{ block.settings.title_top }}</h3>
  {% endif %}

  <div class="ai-counter-number-{{ ai_gen_id }}">
    <span class="ai-counter-prefix-{{ ai_gen_id }}">{{ block.settings.number_prefix }}</span>
    <span class="ai-counter-value-{{ ai_gen_id }}">0</span>
    <span class="ai-counter-suffix-{{ ai_gen_id }}">{{ block.settings.number_suffix }}</span>
  </div>

  {% if block.settings.title_bottom != blank %}
    <p class="ai-counter-title-bottom-{{ ai_gen_id }}">{{ block.settings.title_bottom }}</p>
  {% endif %}
</animated-counter-{{ ai_gen_id }}>

<script>
  (function() {
    class AnimatedCounter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.hasAnimated = false;
      }

      connectedCallback() {
        this.target = parseFloat(this.dataset.target) || 0;
        this.duration = parseFloat(this.dataset.duration) || 2000;
        this.counterElement = this.querySelector('.ai-counter-value-{{ ai_gen_id }}');
        
        this.setupObserver();
      }

      setupObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.3
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.hasAnimated) {
              this.hasAnimated = true;
              this.animateCounter();
            }
          });
        }, options);

        observer.observe(this);
      }

      animateCounter() {
        const startTime = performance.now();
        const startValue = 0;
        const endValue = this.target;

        const animate = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / this.duration, 1);
          
          const easeOutQuart = 1 - Math.pow(1 - progress, 4);
          const currentValue = startValue + (endValue - startValue) * easeOutQuart;
          
          if (Number.isInteger(this.target)) {
            this.counterElement.textContent = Math.floor(currentValue);
          } else {
            const decimals = this.target.toString().split('.')[1]?.length || 0;
            this.counterElement.textContent = currentValue.toFixed(decimals);
          }

          if (progress < 1) {
            requestAnimationFrame(animate);
          } else {
            if (Number.isInteger(this.target)) {
              this.counterElement.textContent = Math.floor(endValue);
            } else {
              const decimals = this.target.toString().split('.')[1]?.length || 0;
              this.counterElement.textContent = endValue.toFixed(decimals);
            }
          }
        };

        requestAnimationFrame(animate);
      }
    }

    customElements.define('animated-counter-{{ ai_gen_id }}', AnimatedCounter{{ ai_gen_id }});
  })();
</script>

