{% doc %}
  @prompt
    generate a nblock that shows an image for mobile and a different one for desktop, they should be responsive for each
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
  }

  .ai-responsive-image__desktop-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    height: auto;
  }

  .ai-responsive-image__mobile-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: auto;
  }

  .ai-responsive-image__placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 300px;
  }

  .ai-responsive-image__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-responsive-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .ai-responsive-image__desktop-{{ ai_gen_id }} {
      display: block;
    }

    .ai-responsive-image__mobile-{{ ai_gen_id }} {
      display: none;
    }
  }

  {% if block.settings.border_radius > 0 %}
    .ai-responsive-image__desktop-{{ ai_gen_id }},
    .ai-responsive-image__mobile-{{ ai_gen_id }},
    .ai-responsive-image__placeholder-{{ ai_gen_id }} {
      border-radius: {{ block.settings.border_radius }}px;
      overflow: hidden;
    }
  {% endif %}
{% endstyle %}

<div class="ai-responsive-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.desktop_image %}
    <img
      src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
      alt="{{ block.settings.desktop_image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.desktop_image.width }}"
      height="{{ block.settings.desktop_image.height }}"
      class="ai-responsive-image__desktop-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="ai-responsive-image__placeholder-{{ ai_gen_id }} ai-responsive-image__desktop-{{ ai_gen_id }}">
      {{ 'image' | placeholder_svg_tag }}
      <div class="ai-responsive-image__empty-state-{{ ai_gen_id }}">
        Add a desktop image
      </div>
    </div>
  {% endif %}

  {% if block.settings.mobile_image %}
    <img
      src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
      alt="{{ block.settings.mobile_image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.mobile_image.width }}"
      height="{{ block.settings.mobile_image.height }}"
      class="ai-responsive-image__mobile-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="ai-responsive-image__placeholder-{{ ai_gen_id }} ai-responsive-image__mobile-{{ ai_gen_id }}">
      {{ 'image' | placeholder_svg_tag }}
      <div class="ai-responsive-image__empty-state-{{ ai_gen_id }}">
        Add a mobile image
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Responsive image",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Responsive image"
    }
  ]
}
{% endschema %}
