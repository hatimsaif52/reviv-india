{% doc %}
  @prompt
    create an image with text, text above and image below, make it possible to upload the image here, and for desktop make the title big and the image to one side, make it responsive. give the posibility to adjust margin and padding,as well as text alignment, and size and font. make sure i can change the color scheem on the section level, add the possibility to change all the title paddings and margins
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left }}px;
    margin: {{ block.settings.margin_top }}px {{ block.settings.margin_right }}px {{ block.settings.margin_bottom }}px {{ block.settings.margin_left }}px;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 100%;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    margin: {{ block.settings.title_margin_top }}px {{ block.settings.title_margin_right }}px {{ block.settings.title_margin_bottom }}px {{ block.settings.title_margin_left }}px;
    padding: {{ block.settings.title_padding_top }}px {{ block.settings.title_padding_right }}px {{ block.settings.title_padding_bottom }}px {{ block.settings.title_padding_left }}px;
    color: rgb(var(--color-foreground));
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .ai-image-text-container-{{ ai_gen_id }} {
      flex-direction: row;
      align-items: center;
      gap: 40px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      flex: 1;
      {% if block.settings.desktop_layout == 'image_left' %}
        order: 2;
      {% endif %}
    }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
      flex: 1;
      {% if block.settings.desktop_layout == 'image_left' %}
        order: 1;
      {% endif %}
    }

    .ai-image-text-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }
  }
{% endstyle %}

<div class="ai-image-text-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-image-text-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
    </div>

    <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1500 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-image-text-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
            Next, add an image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

