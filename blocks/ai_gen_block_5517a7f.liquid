{% doc %}
  @prompt
    Create a responsive offer information card.
    
    The card should be a white container with:
    
    A visible solid border
    
    Large rounded corners
    
    Soft shadow
    
    Generous padding that scales down slightly on mobile
    
    Full-width behavior with clean spacing on desktop and mobile
    
    Top section
    
    At the top, place a horizontal row with space between left and right.
    
    Left side:
    
    A small square or circular image placeholder (this will be a product image)
    
    The image should be small, aligned vertically with text, and have slight rounding
    
    Next to the image, place a short line of bold text (this is a primary text line)
    
    The text should be visually dominant but not oversized
    
    Keep the image and text aligned as a single unit
    
    Right side:
    
    A larger bold text value (this is the main value)
    
    Next to it, a secondary muted text value with strikethrough styling
    
    Both values should align neatly and remain readable on mobile
    
    On smaller screens, allow this section to wrap naturally without breaking layout
    
    Divider
    
    Insert a thin horizontal divider spanning the width of the card
    
    Divider should be subtle and spaced from the top section
    
    Content section
    
    Below the divider, place a vertical list of short text rows.
    
    Each row should:
    
    Have a small icon placeholder on the left
    
    Have a single line of text to the right
    
    Be evenly spaced from the next row
    
    Maintain good readability on mobile and desktop
    
    Use consistent icon sizing and alignment across all rows.
    
    Responsiveness
    
    Desktop: everything remains in a clean single-card layout
    
    Mobile: elements stack or wrap gracefully without overflow
    
    Maintain touch-friendly spacing and readable font sizes
    
    Styling notes
    
    Emphasize hierarchy using font weight and size, not labels
    
    Avoid hardcoded wording or meaning
    
    All text should be treated as interchangeable placeholders
    
    No assumptions about purchase type, frequency, or behavior, add a buy button at the bottom, this buttton wil have a link not opening in a new window, can u make the icons of the each row choose
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-offer-card-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    padding: {{ block.settings.padding_desktop }}px;
  }

  .ai-offer-card__top-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-offer-card__left-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  .ai-offer-card__image-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    flex-shrink: 0;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-offer-card__image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-offer-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-offer-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-offer-card__primary-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.primary_text_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    line-height: 1.3;
    word-break: break-word;
  }

  .ai-offer-card__right-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .ai-offer-card__main-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.main_value_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    line-height: 1;
  }

  .ai-offer-card__secondary-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.secondary_value_size }}px;
    font-weight: 400;
    color: {{ block.settings.muted_text_color }};
    text-decoration: line-through;
    line-height: 1;
  }

  .ai-offer-card__divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-offer-card__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_spacing }}px;
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-offer-card__row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-offer-card__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_color }};
  }

  .ai-offer-card__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-offer-card__row-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.row_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.4;
    flex: 1;
  }

  .ai-offer-card__button-{{ ai_gen_id }} {
    display: inline-block;
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-align: center;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-offer-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-offer-card-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_mobile }}px;
    }

    .ai-offer-card__top-{{ ai_gen_id }} {
      gap: 12px;
    }

    .ai-offer-card__left-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-offer-card__primary-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.primary_text_size | times: 0.9 }}px;
    }

    .ai-offer-card__main-value-{{ ai_gen_id }} {
      font-size: {{ block.settings.main_value_size | times: 0.9 }}px;
    }

    .ai-offer-card__secondary-value-{{ ai_gen_id }} {
      font-size: {{ block.settings.secondary_value_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<offer-card-{{ ai_gen_id }} class="ai-offer-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-offer-card__top-{{ ai_gen_id }}">
    <div class="ai-offer-card__left-{{ ai_gen_id }}">
      <div class="ai-offer-card__image-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 200 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            loading="lazy"
            width="200"
            height="200"
          >
        {% else %}
          <div class="ai-offer-card__image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      {% if block.settings.primary_text != blank %}
        <div class="ai-offer-card__primary-text-{{ ai_gen_id }}">
          {{ block.settings.primary_text }}
        </div>
      {% endif %}
    </div>
    <div class="ai-offer-card__right-{{ ai_gen_id }}">
      {% if block.settings.main_value != blank %}
        <div class="ai-offer-card__main-value-{{ ai_gen_id }}">
          {{ block.settings.main_value }}
        </div>
      {% endif %}
      {% if block.settings.secondary_value != blank %}
        <div class="ai-offer-card__secondary-value-{{ ai_gen_id }}">
          {{ block.settings.secondary_value }}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-offer-card__divider-{{ ai_gen_id }}"></div>

  <div class="ai-offer-card__content-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign row_enabled_key = 'row_' | append: i | append: '_enabled'
        assign row_text_key = 'row_' | append: i | append: '_text'
        assign row_icon_key = 'row_' | append: i | append: '_icon'

        assign row_enabled = block.settings[row_enabled_key]
        assign row_text = block.settings[row_text_key]
        assign row_icon = block.settings[row_icon_key]
      %}

      {% if row_enabled and row_text != blank %}
        <div class="ai-offer-card__row-{{ ai_gen_id }}">
          <div class="ai-offer-card__icon-{{ ai_gen_id }}">
            {% case row_icon %}
              {% when 'check' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% when 'star' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% when 'gift' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 12 20 22 4 22 4 12"></polyline>
                  <rect x="2" y="7" width="20" height="5"></rect>
                  <line x1="12" y1="22" x2="12" y2="7"></line>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                </svg>
              {% when 'truck' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13"></rect>
                  <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                  <circle cx="5.5" cy="18.5" r="2.5"></circle>
                  <circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
              {% when 'clock' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              {% when 'heart' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              {% when 'tag' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                  <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
              {% when 'shield' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
              {% when 'refresh' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 4 23 10 17 10"></polyline>
                  <polyline points="1 20 1 14 7 14"></polyline>
                  <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                </svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            {% endcase %}
          </div>
          <div class="ai-offer-card__row-text-{{ ai_gen_id }}">
            {{ row_text }}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if block.settings.button_text != blank %}
    <a
      href="{{ block.settings.button_link }}"
      class="ai-offer-card__button-{{ ai_gen_id }}"
    >
      {{ block.settings.button_text }}
    </a>
  {% endif %}
</offer-card-{{ ai_gen_id }}>

<script>
  (function() {
    class OfferCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('offer-card-{{ ai_gen_id }}', OfferCard{{ ai_gen_id }});
  })();
</script>

