{% doc %}
  @prompt
    text and image keep background same color, can u make the images more thab one and make thm scrollable? maybe 4 images aligned to the left, can u make the images more like a scrollable gallery with 4 pictures? keep one title at the top pnmy and have every aspect adjustable if possile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gallery-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-gallery-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-gallery-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.title_spacing }}px;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-gallery-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0;
    line-height: 1.2;
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-gallery-wrapper-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-gallery-scroll-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: {{ block.settings.scrollbar_style }};
    scrollbar-color: {{ block.settings.scrollbar_color }} {{ block.settings.scrollbar_track_color }};
    padding-bottom: {{ block.settings.scrollbar_spacing }}px;
  }

  .ai-gallery-scroll-{{ ai_gen_id }}::-webkit-scrollbar {
    height: {{ block.settings.scrollbar_height }}px;
  }

  .ai-gallery-scroll-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: {{ block.settings.scrollbar_track_color }};
    border-radius: {{ block.settings.scrollbar_radius }}px;
  }

  .ai-gallery-scroll-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: {{ block.settings.scrollbar_color }};
    border-radius: {{ block.settings.scrollbar_radius }}px;
  }

  .ai-gallery-scroll-{{ ai_gen_id }}::-webkit-scrollbar-thumb:hover {
    background: {{ block.settings.scrollbar_hover_color }};
  }

  .ai-gallery-item-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}px;
    scroll-snap-align: {{ block.settings.scroll_snap }};
    position: relative;
  }

  .ai-gallery-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: {{ block.settings.image_fit }};
    display: block;
    border-radius: {{ block.settings.image_radius }}px;
    border: {{ block.settings.image_border_width }}px solid {{ block.settings.image_border_color }};
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
    border-radius: {{ block.settings.image_radius }}px;
    border: {{ block.settings.image_border_width }}px solid {{ block.settings.image_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: {{ block.settings.placeholder_opacity | divided_by: 100.0 }};
  }

  .ai-gallery-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: {{ block.settings.title_color }};
    text-align: center;
    pointer-events: none;
    opacity: 0.7;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-gallery-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * {{ block.settings.mobile_title_scale | divided_by: 100.0 }});
    }

    .ai-gallery-item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_image_width }}px;
    }

    .ai-gallery-image-{{ ai_gen_id }},
    .ai-gallery-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_image_height }}px;
    }

    .ai-gallery-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-gallery-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <div class="ai-gallery-header-{{ ai_gen_id }}">
        <h2 class="ai-gallery-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      </div>
    {% endif %}

    <div class="ai-gallery-wrapper-{{ ai_gen_id }}">
      <div class="ai-gallery-scroll-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% assign image_key = 'image_' | append: i %}
          {% assign image = block.settings[image_key] %}
          
          <div class="ai-gallery-item-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 1000 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-gallery-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-gallery-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-gallery-empty-state-{{ ai_gen_id }}">
                  Add image {{ i }}
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

