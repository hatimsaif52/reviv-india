{% doc %}
  @prompt
    generate a title and three bullet point sbeneath, put everyhting in a box, with curved borders, make everyhitng adjustable, make it responsive to desktop too , add the posibility to chnage the color scheme of the section, make it possible to change the color whote behond the box, add padding from the outside to the border
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-info-box-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_background }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-info-box-{{ ai_gen_id }} {
    padding: {{ block.settings.box_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-info-box__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    text-align: {{ block.settings.text_alignment }};
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-info-box__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.bullet_spacing }}px;
  }

  .ai-info-box__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_spacing }}px;
  }

  .ai-info-box__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-top: 2px;
  }

  .ai-info-box__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-info-box__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-info-box-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px;
    }

    .ai-info-box-{{ ai_gen_id }} {
      padding: {{ block.settings.box_padding | times: 0.7 }}px;
      max-width: 100%;
    }

    .ai-info-box__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-info-box__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-info-box__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-info-box-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-info-box-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}">
    {% if block.settings.title != blank %}
      <h3 class="ai-info-box__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
    {% endif %}

    <ul class="ai-info-box__list-{{ ai_gen_id }}">
      {% if block.settings.bullet_1 != blank %}
        <li class="ai-info-box__item-{{ ai_gen_id }}">
          <div class="ai-info-box__icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
          </div>
          <p class="ai-info-box__text-{{ ai_gen_id }}">{{ block.settings.bullet_1 }}</p>
        </li>
      {% endif %}

      {% if block.settings.bullet_2 != blank %}
        <li class="ai-info-box__item-{{ ai_gen_id }}">
          <div class="ai-info-box__icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
          </div>
          <p class="ai-info-box__text-{{ ai_gen_id }}">{{ block.settings.bullet_2 }}</p>
        </li>
      {% endif %}

      {% if block.settings.bullet_3 != blank %}
        <li class="ai-info-box__item-{{ ai_gen_id }}">
          <div class="ai-info-box__icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
          </div>
          <p class="ai-info-box__text-{{ ai_gen_id }}">{{ block.settings.bullet_3 }}</p>
        </li>
      {% endif %}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Info box with bullets",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Key Features"
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Bullet point 1",
      "default": "Premium quality materials"
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Bullet point 2",
      "default": "Fast and free shipping"
    },
    {
      "type": "text",
      "id": "bullet_3",
      "label": "Bullet point 3",
      "default": "30-day money back guarantee"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Box color scheme",
      "default": "scheme-4"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Background behind box",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Box style"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Outer padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "box_padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Inner padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5c085"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 600
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 20
    },
    {
      "type": "header",
      "content": "Bullet points"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#e5c085"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Icon spacing",
      "default": 12
    },
    {
      "type": "range",
      "id": "bullet_spacing",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Spacing between bullets",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Info box with bullets"
    }
  ]
}
{% endschema %}
