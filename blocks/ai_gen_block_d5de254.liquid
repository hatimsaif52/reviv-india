{% doc %}
  @prompt
    add a title nulber at the iddle and another title, can u add another title before the number?, can u animate the number to start incrementing  to 50 k, up to 50000+ not 5000
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-title-number-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.spacing }}px;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-title-number__first-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.first_title_size }}px;
    font-weight: {{ block.settings.first_title_weight }};
    color: {{ block.settings.first_title_color }};
    text-align: center;
    margin: 0;
    max-width: {{ block.settings.title_max_width }}px;
  }

  .ai-title-number__number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    line-height: 1;
    margin: 0;
  }

  .ai-title-number__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    text-align: center;
    margin: 0;
    max-width: {{ block.settings.title_max_width }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-title-number__first-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.first_title_size }}px * 0.8);
    }

    .ai-title-number__number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.7);
    }

    .ai-title-number__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }
{% endstyle %}

<animated-counter-{{ ai_gen_id }}
  class="ai-title-number-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.first_title != blank %}
    <h2 class="ai-title-number__first-title-{{ ai_gen_id }}">
      {{ block.settings.first_title }}
    </h2>
  {% endif %}

  <div class="ai-title-number__number-{{ ai_gen_id }}" data-target="{{ block.settings.target_number | times: 1000 }}">
    0{{ block.settings.number_suffix }}
  </div>

  {% if block.settings.title != blank %}
    <h3 class="ai-title-number__title-{{ ai_gen_id }}">
      {{ block.settings.title }}
    </h3>
  {% endif %}
</animated-counter-{{ ai_gen_id }}>

<script>
  (function() {
    class AnimatedCounter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.hasAnimated = false;
      }

      connectedCallback() {
        this.numberElement = this.querySelector('.ai-title-number__number-{{ ai_gen_id }}');
        this.targetNumber = parseInt(this.numberElement.getAttribute('data-target'));
        this.suffix = '{{ block.settings.number_suffix }}';
        this.duration = {{ block.settings.animation_duration }};
        
        this.setupObserver();
      }

      setupObserver() {
        const options = {
          threshold: 0.5,
          rootMargin: '0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.hasAnimated) {
              this.hasAnimated = true;
              this.animateCounter();
            }
          });
        }, options);

        observer.observe(this);
      }

      animateCounter() {
        const startTime = performance.now();
        const startValue = 0;
        const endValue = this.targetNumber;

        const animate = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / this.duration, 1);
          
          const easeOutQuart = 1 - Math.pow(1 - progress, 4);
          const currentValue = Math.floor(startValue + (endValue - startValue) * easeOutQuart);
          
          this.numberElement.textContent = this.formatNumber(currentValue) + this.suffix;

          if (progress < 1) {
            requestAnimationFrame(animate);
          } else {
            this.numberElement.textContent = this.formatNumber(endValue) + this.suffix;
          }
        };

        requestAnimationFrame(animate);
      }

      formatNumber(num) {
        if (num >= 1000) {
          return (num / 1000).toFixed(num % 1000 === 0 ? 0 : 1) + 'k';
        }
        return num.toString();
      }
    }

    customElements.define('animated-counter-{{ ai_gen_id }}', AnimatedCounter{{ ai_gen_id }});
  })();
</script>

