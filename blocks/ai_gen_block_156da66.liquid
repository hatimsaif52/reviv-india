{% doc %}
  @prompt
    generate a section that has a text on top, a number in the middle as a jumbo text, and this number should have an animation that will show the number progressing gradually to the number I entered. So, for example, if I enter a thousand, it's going to show the number incrementing from a certain number with a certain speed to the target number, and in the bottom of this number we will have another text., add color scheme change, add padding chnage and margins 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-counter-block-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-counter-block__top-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.top_text_size }}px;
    margin: 0 0 {{ block.settings.spacing_top }}px;
    font-weight: {{ block.settings.top_text_weight }};
  }

  .ai-counter-block__number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: {{ block.settings.number_weight }};
    margin: 0;
    line-height: 1.1;
  }

  .ai-counter-block__bottom-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.bottom_text_size }}px;
    margin: {{ block.settings.spacing_bottom }}px 0 0;
    font-weight: {{ block.settings.bottom_text_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-counter-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
      margin: {{ block.settings.margin_top | times: 0.7 }}px 0 {{ block.settings.margin_bottom | times: 0.7 }}px;
    }

    .ai-counter-block__top-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.top_text_size | times: 0.8 }}px;
    }

    .ai-counter-block__number-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_size | times: 0.6 }}px;
    }

    .ai-counter-block__bottom-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.bottom_text_size | times: 0.8 }}px;
    }
  }
  .ai-counter-block-{{ ai_gen_id }} {
  padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
  text-align: {{ block.settings.text_alignment }};
  background-color: {{ block.settings.background_color }};
}

/* Make the custom element itself paint bg and beat color-scheme defaults */
animated-counter-{{ ai_gen_id }}.ai-counter-block-{{ ai_gen_id }} {
  display:block;
  background-color: {{ block.settings.background_color }} !important;
}
.color-{{ block.settings.color_scheme }}.ai-counter-block-{{ ai_gen_id }} {
  background-color: {{ block.settings.background_color }} !important;
}

/* Text colors */
.ai-counter-block__top-text-{{ ai_gen_id }} { color: {{ block.settings.top_text_color }}; }
.ai-counter-block__number-{{ ai_gen_id }}    { color: {{ block.settings.number_color }}; }
.ai-counter-block__bottom-text-{{ ai_gen_id }} { color: {{ block.settings.bottom_text_color }}; }

{% endstyle %}

<animated-counter-{{ ai_gen_id }}
  class="ai-counter-block-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.top_text != blank %}
    <div class="ai-counter-block__top-text-{{ ai_gen_id }}">
      {{ block.settings.top_text }}
    </div>
  {% endif %}

  <div
    class="ai-counter-block__number-{{ ai_gen_id }}"
    data-target="{{ block.settings.target_number }}"
    data-start="{{ block.settings.start_number }}"
    data-duration="{{ block.settings.animation_duration }}"
    data-prefix="{{ block.settings.number_prefix }}"
    data-suffix="{{ block.settings.number_suffix }}"
  >
    {{ block.settings.start_number }}{{ block.settings.number_suffix }}
  </div>

  {% if block.settings.bottom_text != blank %}
    <div class="ai-counter-block__bottom-text-{{ ai_gen_id }}">
      {{ block.settings.bottom_text }}
    </div>
  {% endif %}
</animated-counter-{{ ai_gen_id }}>

<script>
  (function() {
    class AnimatedCounter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.hasAnimated = false;
      }

      connectedCallback() {
        this.counterElement = this.querySelector('.ai-counter-block__number-{{ ai_gen_id }}');
        this.targetNumber = parseInt(this.counterElement.dataset.target);
        this.startNumber = parseInt(this.counterElement.dataset.start);
        this.duration = parseInt(this.counterElement.dataset.duration);
        this.prefix = this.counterElement.dataset.prefix || '';
        this.suffix = this.counterElement.dataset.suffix || '';

        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.3
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.hasAnimated) {
              this.animateCounter();
              this.hasAnimated = true;
            }
          });
        }, options);

        this.observer.observe(this);
      }

      animateCounter() {
        const startTime = performance.now();
        const difference = this.targetNumber - this.startNumber;

        const updateCounter = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / this.duration, 1);

          const easeOutQuart = 1 - Math.pow(1 - progress, 4);
          const currentNumber = Math.floor(this.startNumber + (difference * easeOutQuart));

          this.counterElement.textContent = this.prefix + this.formatNumber(currentNumber) + this.suffix;

          if (progress < 1) {
            requestAnimationFrame(updateCounter);
          } else {
            this.counterElement.textContent = this.prefix + this.formatNumber(this.targetNumber) + this.suffix;
          }
        };

        requestAnimationFrame(updateCounter);
      }

      formatNumber(num) {
        return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('animated-counter-{{ ai_gen_id }}', AnimatedCounter{{ ai_gen_id }});
  })();
</script>

