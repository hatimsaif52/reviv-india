{% doc %}
  @prompt
    generate a comparison table : Create a customizable comparison table section for the product page.
    The table should have 5 rows and 4 columns:
    
    First column: “Feature / Benefit” (text)
    
    Second column: dynamic
    
    Third column: dynamic
    
    The section should let me edit and add rows or columns dynamically from the Shopify theme editor — including changing feature names and toggling between ✅, or ❌.
    
    Style it clean and minimal — centered text, soft dividers, equal column widths, and subtle gray background for the header row. allow customazation, add color scheme option, paddins inner and outter and margins and size cutomazation
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: {{ block.settings.margin_top }}px auto {{ block.settings.margin_bottom }}px;
    padding: {{ block.settings.outer_padding_top }}px {{ block.settings.outer_padding_horizontal }}px {{ block.settings.outer_padding_bottom }}px;
  }

  .ai-comparison-table-wrapper-{{ ai_gen_id }} {
    min-width: 100%;
    background-color: rgb(var(--color-background));
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    padding: {{ block.settings.inner_padding }}px;
  }

  .ai-comparison-table-inner-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .ai-comparison-table-inner-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background }};
  }

  .ai-comparison-table-inner-{{ ai_gen_id }} th {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-comparison-table-inner-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-size: {{ block.settings.body_font_size }}px;
    color: rgb(var(--color-foreground));
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-comparison-table-inner-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-comparison-table-inner-{{ ai_gen_id }} td:first-child,
  .ai-comparison-table-inner-{{ ai_gen_id }} th:first-child {
    text-align: left;
    font-weight: 500;
  }

  .ai-comparison-table-icon-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.icon_size }}px;
    line-height: 1;
  }

  .ai-comparison-table-check-{{ ai_gen_id }} {
    color: {{ block.settings.check_color }};
  }

  .ai-comparison-table-cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table-{{ ai_gen_id }} {
      padding: {{ block.settings.outer_padding_top | times: 0.7 }}px {{ block.settings.outer_padding_horizontal | times: 0.7 }}px {{ block.settings.outer_padding_bottom | times: 0.7 }}px;
      margin: {{ block.settings.margin_top | times: 0.7 }}px auto {{ block.settings.margin_bottom | times: 0.7 }}px;
    }

    .ai-comparison-table-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.inner_padding | times: 0.7 }}px;
    }

    .ai-comparison-table-inner-{{ ai_gen_id }} th {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-comparison-table-inner-{{ ai_gen_id }} td {
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-comparison-table-icon-{{ ai_gen_id }} {
      font-size: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
  {% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<div class="ai-comparison-table-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
