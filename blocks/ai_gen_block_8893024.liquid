{% doc %}
  @prompt
    generate a divider goes from edge to edge, add color scheme option
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-divider-{{ ai_gen_id }} {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-divider-line-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.divider_thickness }}px;
    background-color: {{ block.settings.divider_color }};
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
    border: none;
    margin: 0;
  }

  {% if block.settings.divider_style == 'dashed' %}
    .ai-divider-line-{{ ai_gen_id }} {
      background: repeating-linear-gradient(
        to right,
        {{ block.settings.divider_color }} 0px,
        {{ block.settings.divider_color }} {{ block.settings.dash_length }}px,
        transparent {{ block.settings.dash_length }}px,
        transparent {{ block.settings.dash_length | plus: block.settings.dash_gap }}px
      );
    }
  {% elsif block.settings.divider_style == 'dotted' %}
    .ai-divider-line-{{ ai_gen_id }} {
      background: repeating-linear-gradient(
        to right,
        {{ block.settings.divider_color }} 0px,
        {{ block.settings.divider_color }} {{ block.settings.divider_thickness }}px,
        transparent {{ block.settings.divider_thickness }}px,
        transparent {{ block.settings.divider_thickness | plus: block.settings.dot_gap }}px
      );
    }
  {% elsif block.settings.divider_style == 'gradient' %}
    .ai-divider-line-{{ ai_gen_id }} {
      background: linear-gradient(
        to right,
        transparent,
        {{ block.settings.divider_color }},
        transparent
      );
    }
  {% endif %}
{% endstyle %}

<div class="ai-divider-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
  <hr class="ai-divider-line-{{ ai_gen_id }}">
</div>

{% schema %}
{
  "name": "Divider",
  "tag": null,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Divider style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ],
      "default": "solid"
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Thickness",
      "default": 1
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Color",
      "default": "#e5c085"
    },
    {
      "type": "range",
      "id": "divider_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacity",
      "default": 100
    },
    {
      "type": "range",
      "id": "dash_length",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Dash length",
      "default": 20
    },
    {
      "type": "range",
      "id": "dash_gap",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "label": "Dash gap",
      "default": 10
    },
    {
      "type": "range",
      "id": "dot_gap",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Dot gap",
      "default": 8
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Divider"
    }
  ]
}
{% endschema %}
