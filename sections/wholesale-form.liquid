{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact page-width page-width--narrow section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- else -%}
      <h2 class="visually-hidden">{{ 'templates.contact.form.title' | t }}</h2>
    {%- endif -%}
    {%- liquid
      assign contact_form_class = 'isolate'
      if settings.animations_reveal_on_scroll
        assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
      endif
    -%}
{%- form 'contact', id: 'WholesaleForm', class: 'wholesale-contact-form' -%}
  {%- if form.posted_successfully? -%}
    <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
      {% render 'icon-success' %}
      {{ 'templates.contact.form.post_success' | t }}
    </h2>
  {%- elsif form.errors -%}
    <div class="form__message">
      <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
        {% render 'icon-error' %}
        {{ 'templates.contact.form.error_heading' | t }}
      </h2>
    </div>
    <ul class="form-status-list caption-large" role="list">
      {%- for field in form.errors -%}
        <li>
          <a href="#WholesaleForm-{{ field }}" class="link">
            {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

  <div class="contact__fields">

    <!-- First Name -->
    <div class="field">
      <label class="field__label" for="WholesaleForm-firstName">First Name <span aria-hidden="true">*</span></label>
      <input
        type="text"
        id="WholesaleForm-firstName"
        class="field__input"
        name="contact[first_name]"
        value="{{ form.first_name | escape }}"
        autocomplete="given-name"
        required
      >
    </div>

    <!-- Last Name -->
    <div class="field">
      <label class="field__label" for="WholesaleForm-lastName">Last Name <span aria-hidden="true">*</span></label>
      <input
        type="text"
        id="WholesaleForm-lastName"
        class="field__input"
        name="contact[last_name]"
        value="{{ form.last_name | escape }}"
        autocomplete="family-name"
        required
      >
    </div>

    <!-- Email -->
    <div class="field field--with-error">
      <label class="field__label" for="WholesaleForm-email">Your Email Address <span aria-hidden="true">*</span></label>
      <input
        type="email"
        id="WholesaleForm-email"
        class="field__input"
        name="contact[email]"
        value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
        spellcheck="false"
        autocapitalize="off"
        autocomplete="email"
        aria-required="true"
        required
        {% if form.errors contains 'email' %}
          aria-invalid="true"
          aria-describedby="WholesaleForm-email-error"
        {% endif %}
      >
      {%- if form.errors contains 'email' -%}
        <small class="contact__field-error" id="WholesaleForm-email-error">
          <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
          <span class="form__message">
            {% render 'icon-error' %}
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </span>
        </small>
      {%- endif -%}
    </div>

    <!-- Dropdown: Number of Units -->
    <div class="field">
      <label class="field__label" for="WholesaleForm-units">How many units are you looking for? <span aria-hidden="true">*</span></label>
      <select id="WholesaleForm-units" class="field__input" name="contact[Number of Units]" required>
        <option value="Under 100">Under 100</option>
        <option value="100+">100+</option>
        <option value="1000+">1000+</option>
        <option value="10000+">10000+</option>
      </select>
    </div>

    <!-- Message / Enquiry -->
    <div class="field">
      <label class="field__label" for="WholesaleForm-body">Your Inquiry <span aria-hidden="true">*</span></label>
      <textarea
        rows="6"
        id="WholesaleForm-body"
        class="text-area field__input"
        name="contact[Enquiry Details]"
        required
      >{{ form.body }}</textarea>
    </div>

  </div>

  <div class="contact__button">
    <button type="submit" class="button">
      {{ 'templates.contact.form.send' | t }}
    </button>
  </div>
{%- endform -%}

  </div>
</div>

{% schema %}
{
  "name": "Wholesale Form",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.contact-form.settings.title.default",
      "label": "t:sections.contact-form.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Wholesale Form"
    }
  ]
}
{% endschema %}
