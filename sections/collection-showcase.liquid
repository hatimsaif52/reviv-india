{% render 'reviv-base' %}
<div class="rv-scope" style="background:#0A0A0B; font-family:'Mulish',sans-serif;">
  <section style="max-width:1240px; margin:0 auto; padding:30px 40px 80px;">
    <h2 style="font-family:'Cormorant Garamond',serif; font-weight:600; font-size:42px; color:#EF9A2E; margin:0 0 32px;">{{ section.settings.heading }}</h2>
    <div class="rv-3col" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }} style="background:#0F0E0C; border:1px solid rgba(236,230,218,0.08); border-radius:12px; overflow:hidden;">
          <div class="rv-stripe" style="position:relative; height:250px;">
            {% if block.settings.image %}<img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.title }}" style="width:100%; height:100%; object-fit:cover;">{% endif %}
            {% if block.settings.badge != blank %}<span style="position:absolute; top:18px; left:18px; background:#E8A33C; color:#161206; font-weight:800; font-size:11px; letter-spacing:0.1em; padding:6px 11px; border-radius:5px;">{{ block.settings.badge }}</span>{% endif %}
            {% unless block.settings.image %}<span style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:rgba(0,0,0,0.55); color:#B8B2A6; font-family:'Space Mono',monospace; font-size:13px; padding:6px 12px; border-radius:5px; white-space:nowrap;">{{ block.settings.chip }}</span>{% endunless %}
          </div>
          <div style="padding:22px;">
            <div style="display:flex; align-items:baseline; justify-content:space-between; gap:10px;">
              <h3 style="font-family:'Cormorant Garamond',serif; font-weight:600; font-size:26px; color:#ECE6DA; margin:0;">{{ block.settings.title }}</h3>
              <span style="font-weight:800; font-size:19px; color:#EEA945; white-space:nowrap;">{{ block.settings.price }}</span>
            </div>
            <p style="color:#8F897F; font-size:13.5px; margin:6px 0 20px;">{{ block.settings.sub }}</p>
            {% if block.settings.product != blank %}
              {% form 'product', block.settings.product %}
                <input type="hidden" name="id" value="{{ block.settings.product.selected_or_first_available_variant.id }}">
                <button type="submit" class="rv-cart-btn" style="width:100%; background:transparent; border:1px solid rgba(232,163,60,0.6); color:#E8A33C; font-family:'Mulish',sans-serif; font-weight:800; letter-spacing:0.12em; font-size:12.5px; padding:15px; border-radius:6px; cursor:pointer;">ADD TO CART</button>
              {% endform %}
            {% else %}
              <a href="{{ block.settings.url }}" class="rv-cart-btn" style="display:block; text-align:center; background:transparent; border:1px solid rgba(232,163,60,0.6); color:#E8A33C; text-decoration:none; font-weight:800; letter-spacing:0.12em; font-size:12.5px; padding:15px; border-radius:6px;">ADD TO CART</a>
            {% endif %}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Collection showcase",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Collection" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product (enables Add to Cart)" },
        { "type": "image_picker", "id": "image", "label": "Image (optional)" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "BEST SELLER" },
        { "type": "text", "id": "chip", "label": "Placeholder chip label", "default": "R3 mouthguard" },
        { "type": "text", "id": "title", "label": "Title", "default": "R3 (RevivThree)" },
        { "type": "text", "id": "sub", "label": "Subtitle", "default": "Maximum protection" },
        { "type": "text", "id": "price", "label": "Price", "default": "₹18,990" },
        { "type": "url", "id": "url", "label": "Fallback link (if no product)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Collection showcase",
    "blocks": [
      { "type": "product", "settings": { "badge": "BEST SELLER", "chip": "R3 mouthguard", "title": "R3 (RevivThree)", "sub": "Maximum protection", "price": "₹18,990" } },
      { "type": "product", "settings": { "badge": "PREMIUM", "chip": "R2 in gift box", "title": "R2 (RevivTwo)", "sub": "1 year support · in box", "price": "₹14,490" } },
      { "type": "product", "settings": { "badge": "NEW · CLEAR", "chip": "R1 clear guard", "title": "R1 (RevivOne)", "sub": "Everyday starter", "price": "₹9,490" } }
    ]
  }]
}
{% endschema %}
