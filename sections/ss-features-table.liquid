<link rel="stylesheet" href="{{ 'ss-featured-table.css' | asset_url }}" type="text/css">

{% assign mf_headings = product.metafields.custom.featured_table_heading.value %}
{% assign mf_texts = product.metafields.custom.featured_table_text.value %}

{% assign use_metafields = false %}
{% if mf_headings != blank and mf_texts != blank %}
  {% assign use_metafields = true %}
{% endif %}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section class="main-featured-spec-table color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="page-width">
  <div class="featured-spec-table  featured-spec-table__inner">

    {%- if use_metafields -%}
      {%- for heading in mf_headings -%}
        {% assign index = forloop.index0 %}
        {% assign value = mf_texts[index] %}

        {% if heading != blank and value != blank %}
          <div class="spec-row">
            <div class="spec-label">{{ heading }}</div>
            <div class="spec-value">{{ value }}</div>
          </div>
        {% endif %}
      {%- endfor -%}

    {%- else -%}
      {%- for block in section.blocks -%}
        <div class="spec-row" {{ block.shopify_attributes }}>
          <div class="spec-label">
            {{ block.settings.heading }}
          </div>
          <div class="spec-value">
            {{ block.settings.text }}
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}

  </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Spec Table",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Specification Row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Fabric"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Cotton"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SS Feature Spec Table",
    }
  ]
}
{% endschema %}
