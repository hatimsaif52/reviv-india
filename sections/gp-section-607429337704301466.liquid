        const viewportCenter = window.innerHeight / 2;
        
        if (container && items.length > 0) {
            const firstItem = items[0].getBoundingClientRect();
            const lastItem = items[items.length - 1].getBoundingClientRect();
            
            // Start at center of first dot, end at center of last dot
            const startPoint = firstItem.top + 50; 
            const endPoint = lastItem.top + 18; // Precise offset for Dot 3 icon
            const totalDistance = endPoint - startPoint;

            let progress = (viewportCenter - startPoint) / totalDistance;
            progress = Math.max(0, Math.min(1, progress)) * 100;
            
            container.style.setProperty('--line-height', progress + '%');
        }

        // Active State Reversing
        items.forEach(item => {
            const itemRect = item.getBoundingClientRect();
            const itemMid = itemRect.top + (itemRect.height / 2);

            // Tightened the window to 100px for a more distinct focus effect
            if (itemMid < viewportCenter + 100 && itemMid > viewportCenter - 100) {
                item.classList.add('is-active');
            } else {
                item.classList.remove('is-active');
            }
        });
    };

    window.addEventListener('scroll', handleTimeline);
    handleTimeline(); 
});
        } catch(err){}
      </script>
    
    
