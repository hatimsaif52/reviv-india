      <style id="custom-css-gQmhcy2P_7">
        /* 1. Muted/Default State */
.timeline-item {
    opacity: 0.2; 
    filter: blur(0.5px);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 2. Active State */
.timeline-item.is-active {
    opacity: 1 !important;
    filter: blur(0px);
}

/* 3. Text & Variable Overrides */
.timeline-item.is-active p,
.timeline-item.is-active span,
.timeline-item.is-active .gp-g-paragraph-1,
.timeline-item.is-active [data-gp-text-class],
.timeline-item.is-active h2,
.timeline-item.is-active .gp-g-heading-1 {
    color: #E4893A !important;
    --c: #E4893A !important; 
    --td1: #E4893A !important;
}

.timeline-item.is-active i,
.timeline-item.is-active svg,
.timeline-item.is-active .gp-icon {
    color: #E4893A !important;
    fill: #E4893A !important;
}

/* 4. THE PROGRESS TRACK (FIXED ENDING) */
.timeline-container {
    border-left: none !important; 
    position: relative;
}

/* Static Grey Track - Adjusted bottom to stop at Dot 3 */
.timeline-container::before {
    content: "";
    position: absolute;
    left: -2px;
    top: 50px;     
    bottom: 110px; /* INCREASED: This pulls the line up to meet Dot 3 */
    width: 2px;
    background-color: rgba(255, 255, 255, 0.1); 
    z-index: 0;
}

/* Gold Filling Line - Adjusted max-height to match track */
.timeline-container::after {
    content: "";
    position: absolute;
    left: -2px;
    top: 50px;
    width: 2px;
    height: var(--line-height, 0%);
    background-color: #E4893A;
    z-index: 1;
    transition: height 0.1s linear;
    max-height: calc(100% - 162px); /* Matches Top (50) + Bottom (110) */
}

/* Active Dot Pulse */
.timeline-item.is-active .timeline-dot {
    background-color: #E4893A !important;
    box-shadow: 0 0 10px #E4893A, 0 0 20px rgba(228, 137, 58, 0.4);
    transform: scale(1.3);
    transition: all 0.3s ease;
}

/* 5. Stacking & Video */
.timeline-section-wrapper {
    position: relative;
    z-index: 1;
}

.section-after-timeline {
    position: relative;
    z-index: 2;
    background: #000;
}

.sticky-video-col {
    position: sticky !important;
    top: 120px;
    z-index: 1;
}
      </style>
    
