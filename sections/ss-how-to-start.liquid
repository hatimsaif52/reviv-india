<section class="how-to-start">
  <div class="container">
    
    <div class="how-to-start__header">
      <span class="badge">
        <span class="dot"></span>
        {{ section.settings.heading }}
      </span>
    </div>

    <div class="how-to-start__box">
      <p class="intro">
        {{ section.settings.intro_text }}
      </p>

      <div class="steps">
        {% for block in section.blocks %}
          <div class="step">
            <div class="step__number">{{ forloop.index }}</div>
            <div class="step__content">
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.description }}</p>
            </div>
          </div>
          {% unless forloop.last %}
            <hr>
          {% endunless %}
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<style>
.how-to-start {
  padding: 60px 20px;
  background: #fff;
}

.how-to-start .container {
  max-width: 1200px;
  margin: 0 auto;
}

.how-to-start__header {
  text-align: center;
  margin-bottom: 20px;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
    font-size:19px;
    color:#904F06;
  border-radius: 999px;
  border: 1px solid #EFC98B;
  background: linear-gradient(90deg, #FFF0D8 0%, #FFFAF3 100%);
  font-weight: 500;
  margin-bottom:30px;
}

.badge .dot {
  width: 8px;
  height: 8px;
  background: green;
  border-radius: 50%;
}

.how-to-start__box {
  background: #FFFAF0;
  padding: 30px 80px 50px;
  border-radius: 16px;
}

.intro {
  margin-bottom: 25px;
  color: #333;
}

.step {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}

.step__number {
  background: #b45309;
  color: #fff;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  flex-shrink: 0;
  line-height: 0;
}

.step__content h4 {
  margin: 0;
  font-size: 16px;
}

.step__content p {
  margin: 5px 0 0;
  color: #555;
  font-size: 14px;
}

.steps hr {
  border: none;
  border-top: 1px solid #cfc6bb;
  margin: 20px 0;
}

@media (max-width: 767px) {
  .how-to-start__box {
    padding: 20px;
  }

  .step {
    flex-direction: row;
  }
}
</style>

{% schema %}
{
  "name": "SS How to Start",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to start"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "Once we agree to work together, the only thing we need is your permission to run the video as a Meta ad. Here's the process:"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Step title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Step description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SS How to Start",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}