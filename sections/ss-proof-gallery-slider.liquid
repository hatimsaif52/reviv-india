<section class="proof-gallery" id="ba-proof-gallery">
  <div class="container">

    <!-- Header -->
    <div class="pg-header">
      <p class="pg-subtitle">PROOF GALLERY</p>
      <h2>Before & after results</h2>
    </div>

    <!-- Slider -->
    <div class="pg-slider-wrapper">
     <div class="pg-viewport">
      <div
        class="pg-slider"
        id="pgSlider"
        data-per-slide-desktop="{{ section.settings.cards_per_slide_desktop | default: 12 | plus: 0 }}"
        data-per-slide-mobile="{{ section.settings.cards_per_slide_mobile | default: 2 | plus: 0 }}"
      >
      {% for block in section.blocks %}
        <div class="pg-card" data-pg-card {{ block.shopify_attributes }}>
          <div class="pg-images">
            <div class="pg-img">
              {%- if block.settings.before != blank -%}
                <img src="{{ block.settings.before | image_url: width: 900 }}" alt="Result" loading="lazy" />
              {%- endif -%}
              <span class="pg-pill pg-pill--before">Before</span>
              <span class="pg-pill pg-pill--after">After</span>
            </div>
          </div>

          <div class="pg-content">
            <h4>{{ block.settings.name }}</h4>
            <p>{{ block.settings.text }}</p>
            <span class="pg-tag">{{ block.settings.tag }}</span>
          </div>
        </div>
      {% endfor %}
      </div>
     </div>

      <!-- Dots -->
      <div class="pg-dots" id="pgDots"></div>
    </div>

  </div>
</section>

<style>
.proof-gallery {
  background: #f3f3f3;
  padding: 80px 20px;
}

.container {
  max-width: 1200px;
  margin: auto;
}

.pg-header {
  text-align: center;
  margin-bottom: 40px;
}

.pg-subtitle {
  letter-spacing: 4px;
  font-size: 12px;
  color: #777;
}

.pg-header h2 {
  font-size: clamp(32px, 6vw, 65px);
  margin-top: 10px;
}

.pg-slider-wrapper {
  position: relative;
}

.pg-viewport {
  overflow: hidden;
  position: relative;
  transition: height 0.35s ease;
}

.pg-slider {
  display: flex;
  transition: transform 0.4s ease;
  align-items: flex-start;
  --pg-slide-cols: 3;
  --pg-slide-gap: 20px;
  --pg-slide-pad: 0px;
}

.pg-slide {
  min-width: 100%;
  display: grid;
  grid-template-columns: repeat(var(--pg-slide-cols, 3), minmax(0, 1fr));
  gap: var(--pg-slide-gap, 20px);
  padding-left: var(--pg-slide-pad, 0px);
  padding-right: var(--pg-slide-pad, 0px);
  align-items: start;
  align-content: start;
  height: auto;
}

.pg-card {
  max-width: 100%;
    border-radius: 30px 30px 20px 20px;
    overflow: hidden;
    flex-shrink: 0;
    background: #e2c089;
    display: flex;
    flex-direction: column;
}

.pg-images {
    height: 250px;
    display: block;
    overflow: hidden;
}

.pg-img {
    position: relative;
    height: 100%;
}

.pg-img img {
    width: 100%;
    height: 100%;
    object-fit: fill;
    display: block;
  border-top-left-radius: 30px;
  border-top-right-radius: 30px;
  pointer-events: none;
}

.pg-pill {
  position: absolute;
  top: 10px;
  padding: 4px 12px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 800;
  line-height: 1;
}

.pg-pill--before {
  left: 10px;
  background: #e2c089;
  color: #000;
}

.pg-pill--after {
  right: 10px;
  background: #fff;
  color: #000;
}

.pg-content {
    padding: 20px 15px 20px;
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
}

.pg-content h4 {
    margin: 0 0 10px 0;
    font-size: 23px;
    overflow: hidden;
    display: -webkit-box !important;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
}

.pg-content p {
    font-size: 12px;
    color: #333;
    line-height: 1.2;
    min-height: 40px;
    overflow: hidden;
    display: -webkit-box !important;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
}

.pg-tag {
    display: inline-block;
    margin-top: auto;
    background: #fff;
    padding: 1px 13px;
    border-radius: 17px;
    font-size: 11px;
    font-weight: 800;
    align-self: flex-start;
}

/* Dots */
.pg-dots {
  text-align: center;
  margin-top: 20px;
}

.pg-dots span {
  display: inline-block;
  width: 11px;
  height: 11px;
  background: #bbb;
  border-radius: 50%;
  margin: 0 4px;
  cursor: pointer;
}

.pg-dots .active {
  background: #000;
  width: 11px;
  height: 11px;
}

.pg-slider {
  cursor: grab;
}

.pg-slider:active {
  cursor: grabbing;
}

.pg-slide {
  user-select: none;
}

/* Responsive */
@media (max-width: 1024px) {
  .pg-card {
    min-width: 0;
  }
}

@media (max-width: 600px) {
  .proof-gallery {
    padding: 52px 16px;
  }

  .pg-header {
    margin-bottom: 28px;
  }

  .pg-subtitle {
    letter-spacing: 3px;
  }

  .pg-images {
    height: auto;
  }

  .pg-img {
    height: auto;
    aspect-ratio: 1 / 1;
  }

  .pg-img img {
    height: 100%;
  }

  .pg-pill {
    top: 8px;
    padding: 4px 10px;
    font-size: 9px;
  }

  .pg-card {
    min-width: 0;
    border-radius: 22px 22px 16px 16px;
  }

  .pg-content {
    padding: 14px 12px 14px;
  }

  .pg-content h4 {
    font-size: 18px;
    -webkit-line-clamp: 2;
  }

  .pg-content p {
    font-size: 11px;
    min-height: 40px;
    line-height: 1.25;
    -webkit-line-clamp: 3;
  }
}

@media (max-width: 1024px) {
  .pg-slide {
    grid-template-columns: repeat(var(--pg-slide-cols, 2), minmax(0, 1fr));
  }
}

@media (max-width: 600px) {
  .pg-slide {
    grid-template-columns: repeat(var(--pg-slide-cols, 1), minmax(0, 1fr));
  }
}
</style>

<script>
(function () {
  function init() {
    const sectionEl = document.getElementById("ba-proof-gallery");
    if (!sectionEl) return;

    const sliderViewport = sectionEl.querySelector(".pg-viewport");
    const slider = sectionEl.querySelector("#pgSlider");
    const dotsContainer = sectionEl.querySelector("#pgDots");
    if (!slider || !dotsContainer) return;

    const originalCards = Array.from(slider.querySelectorAll("[data-pg-card]"));
    let slides = slider.getElementsByClassName("pg-slide");
    let currentPerSlide = 0;

    let index = 0;
    let startX = 0;
    let currentX = 0;
    let isDragging = false;

    function getPerSlide() {
      const desktop = parseInt(slider.dataset.perSlideDesktop || "12", 10);
      const mobile = parseInt(slider.dataset.perSlideMobile || "2", 10);

      const w = window.innerWidth || document.documentElement.clientWidth || 9999;
      if (w <= 600) return mobile;
      return desktop;
    }

    function applySlideLayout(perSlide) {
      const w = window.innerWidth || document.documentElement.clientWidth || 9999;
      let cols = 3;
      let gap = 20;
      let pad = 0;

      if (w <= 600) {
        cols = Math.min(perSlide || 1, 2);
        gap = 12;
        pad = 6;
      } else if (w <= 1024) {
        cols = Math.min(perSlide || 1, 2);
        gap = 16;
        pad = 0;
      } else {
        cols = Math.min(perSlide || 1, 3);
        gap = 20;
        pad = 0;
      }

      slider.style.setProperty("--pg-slide-cols", String(cols));
      slider.style.setProperty("--pg-slide-gap", gap + "px");
      slider.style.setProperty("--pg-slide-pad", pad + "px");
    }

    function buildSlides(perSlide) {
      if (!perSlide || perSlide < 1) perSlide = 1;

      applySlideLayout(perSlide);

      slider.innerHTML = "";
      for (let i = 0; i < originalCards.length; i += perSlide) {
        const slideEl = document.createElement("div");
        slideEl.className = "pg-slide";

        originalCards.slice(i, i + perSlide).forEach((card) => {
          slideEl.appendChild(card);
        });
        slider.appendChild(slideEl);
      }

      slides = slider.getElementsByClassName("pg-slide");
      if (index > slides.length - 1) index = Math.max(0, slides.length - 1);
    }

    // --- Update Slide ---
    function updateSlider() {
      slider.style.transition = "transform 0.4s ease";
      slider.style.transform = `translateX(-${index * 100}%)`;

      if (sliderViewport && slides[index]) {
        let dotsExtra = 0;
        if (dotsContainer) {
          const dotsStyle = window.getComputedStyle(dotsContainer);
          const mt = parseFloat(dotsStyle.marginTop) || 0;
          const mb = parseFloat(dotsStyle.marginBottom) || 0;
          dotsExtra = dotsContainer.offsetHeight + mt + mb;
        }

        sliderViewport.style.height = (slides[index].offsetHeight) + "px";
      }

      [...dotsContainer.children].forEach(dot => dot.classList.remove("active"));
      if (dotsContainer.children[index]) {
        dotsContainer.children[index].classList.add("active");
      }
    }

    // --- Create Dots ---
    function createDots() {
      dotsContainer.innerHTML = "";

      for (let i = 0; i < slides.length; i++) {
        let dot = document.createElement("span");

        dot.addEventListener("click", () => {
          index = i;
          updateSlider();
        });
        dotsContainer.appendChild(dot);
      }
    }

    // --- Drag Start ---
    function startDrag(x) {
      isDragging = true;
      startX = x;
      slider.style.transition = "none";
    }

    // --- Drag Move ---
    function moveDrag(x) {
      if (!isDragging) return;

      currentX = x;
      let diff = currentX - startX;

      slider.style.transform = `translateX(calc(-${index * 100}% + ${diff}px))`;
    }

    // --- Drag End ---
    function endDrag() {
      if (!isDragging) return;
      isDragging = false;

      let diff = currentX - startX;
      let threshold = 50; // swipe sensitivity

      if (diff > threshold && index > 0) {
        index--;
      } else if (diff < -threshold && index < slides.length - 1) {
        index++;
      }

      updateSlider();
    }

    // --- Mouse Events ---
    slider.addEventListener("mousedown", (e) => startDrag(e.pageX));
    window.addEventListener("mousemove", (e) => moveDrag(e.pageX));
    window.addEventListener("mouseup", endDrag);

    // --- Touch Events ---
    slider.addEventListener("touchstart", (e) => startDrag(e.touches[0].clientX));
    slider.addEventListener("touchmove", (e) => moveDrag(e.touches[0].clientX));
    slider.addEventListener("touchend", endDrag);

    // --- Resize ---
    window.addEventListener("resize", () => {
      const nextPerSlide = getPerSlide();
      if (nextPerSlide !== currentPerSlide) {
        currentPerSlide = nextPerSlide;
        buildSlides(currentPerSlide);
        createDots();
      } else {
        applySlideLayout(currentPerSlide);
      }
      updateSlider();
    });

    currentPerSlide = getPerSlide();
    buildSlides(currentPerSlide);
    createDots();
    updateSlider();
  }

  document.addEventListener("DOMContentLoaded", init);
  document.addEventListener("shopify:section:load", function (event) {
    if (event && event.target && event.target.id === "ba-proof-gallery") {
      init();
    }
  });

  init();
})();
</script>

{% schema %}
{
  "name": "Proof Gallery Slider",
  "settings": [
    {
      "type": "range",
      "id": "cards_per_slide_desktop",
      "label": "Cards per slide (desktop)",
      "min": 1,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "cards_per_slide_mobile",
      "label": "Cards per slide (mobile)",
      "min": 1,
      "max": 24,
      "step": 1,
      "default": 2
    }
  ],

  "blocks": [
    {
      "type": "card",
      "name": "Result Card",
      "settings": [
        { "type": "image_picker", "id": "before", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name", "default": "Emily Carter" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "I've been using..." },
        { "type": "text", "id": "tag", "label": "Tag", "default": "R2" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Proof Gallery Slider"
    }
  ]
}
{% endschema %}