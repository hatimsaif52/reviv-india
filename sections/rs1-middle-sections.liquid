{% liquid
  assign section_id = 'rs1-middle-sections-' | append: section.id
%}

<style>
  .{{ section_id }} {
    --rs1-bg:        #0b0b0b;
    --rs1-bg-alt:    #232021;
    --rs1-card:      #141414;
    --rs1-accent:    #dfb88a;
    --rs1-text:      #ffffff;
    --rs1-text-2:    #bfbfbf;
    --rs1-border:    #ffffff14;

    background: var(--rs1-bg);
    color: var(--rs1-text);
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .{{ section_id }} *,
  .{{ section_id }} *::before,
  .{{ section_id }} *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .{{ section_id }} .rs1-container {
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 32px;
    padding-right: 32px;
  }

  .{{ section_id }} .rs1-adv {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--rs1-bg);
    padding-top: 90px;
    padding-bottom: 90px;
  }

  .{{ section_id }} .rs1-eyebrow {
    text-align: center;
    font-style: italic;
    font-size: 14px;
    color: var(--rs1-accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 22px;
    font-weight: 500;
  }

  .{{ section_id }} .rs1-title {
    font-size: 56px;
    font-weight: 500;
    line-height: 1.05;
    text-align: center;
    color: var(--rs1-text);
    max-width: 920px;
    margin: 0 auto;
    letter-spacing: -0.012em;
  }

  .{{ section_id }} .rs1-title em {
    font-style: italic;
    color: var(--rs1-accent);
    font-weight: 500;
  }

  .{{ section_id }} .rs1-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 18px;
    margin-top: 46px;
  }

  .{{ section_id }} .rs1-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .{{ section_id }} .rs1-card__media {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    background: var(--rs1-card);
    aspect-ratio: 1 / 1;
  }

  .{{ section_id }} .rs1-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .{{ section_id }} .rs1-card__num {
    position: absolute;
    top: 10px;
    left: 10px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--rs1-accent);
    letter-spacing: 0.06em;
  }

  .{{ section_id }} .rs1-card__body {
    padding-top: 16px;
  }

  .{{ section_id }} .rs1-card__title {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--rs1-text);
    margin-bottom: 8px;
  }

  .{{ section_id }} .rs1-card__text {
    font-size: 15px;
    line-height: 1.55;
    color: var(--rs1-text-2);
  }

  .{{ section_id }} .rs1-problem {
    background: var(--rs1-bg-alt);
    padding-top: 90px;
    padding-bottom: 90px;
  }

  .{{ section_id }} .rs1-problem-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .{{ section_id }} .rs1-problem-eyebrow {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rs1-accent);
    margin-bottom: 14px;
  }

  .{{ section_id }} .rs1-problem-title {
    font-size: 54px;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.012em;
    color: var(--rs1-text);
    margin-bottom: 20px;
  }

  .{{ section_id }} .rs1-problem-title em {
    font-style: italic;
    color: var(--rs1-accent);
    font-weight: 500;
  }

  .{{ section_id }} .rs1-problem-body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--rs1-text-2);
    max-width: 540px;
    margin-bottom: 26px;
  }

  .{{ section_id }} .rs1-problem-list {
    list-style: none;
    border-top: 1px solid var(--rs1-border);
  }

  .{{ section_id }} .rs1-problem-item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--rs1-border);
    align-items: center;
  }

  .{{ section_id }} .rs1-problem-num {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--rs1-accent);
  }

  .{{ section_id }} .rs1-problem-text {
    font-size: 15px;
    line-height: 1.55;
    color: var(--rs1-text);
  }

  .{{ section_id }} .rs1-problem-media {
    width: 100%;
    background: var(--rs1-card);
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    position: relative;
  }

  .{{ section_id }} .rs1-problem-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .{{ section_id }} .rs1-solution {
    background: var(--rs1-bg);
    padding-top: 90px;
    padding-bottom: 90px;
  }

  .{{ section_id }} .rs1-solution-top {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .{{ section_id }} .rs1-solution-eyebrow {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rs1-accent);
    margin-bottom: 14px;
  }

  .{{ section_id }} .rs1-solution-title {
    font-size: 54px;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.012em;
    color: var(--rs1-text);
  }

  .{{ section_id }} .rs1-solution-title em {
    font-style: italic;
    color: var(--rs1-accent);
    font-weight: 500;
  }

  .{{ section_id }} .rs1-solution-body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--rs1-text-2);
    max-width: 520px;
  }

  .{{ section_id }} .rs1-solution-divider {
    display: block !important;
    margin-top: 40px;
    border-top: 1px solid var(--rs1-border);
  }

  .{{ section_id }} .rs1-solution-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-left: 1px solid var(--rs1-border);
    margin-top: 0;
  }

  .{{ section_id }} .rs1-solution-item {
    padding: 34px 32px 40px;
    border-right: 1px solid var(--rs1-border);
  }

  .{{ section_id }} .rs1-solution-icon {
    width: 84px;
    height: 84px;
    margin-bottom: 18px;
  }

  .{{ section_id }} .rs1-solution-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .{{ section_id }} .rs1-solution-item h4 {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--rs1-text);
  }

  .{{ section_id }} .rs1-solution-item p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--rs1-text-2);
  }

  .{{ section_id }} .rs1-works {
    background: var(--rs1-bg-alt);
    padding-top: 90px;
    padding-bottom: 90px;
  }

  .{{ section_id }} .rs1-works-top {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .{{ section_id }} .rs1-works-eyebrow {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rs1-accent);
    margin-bottom: 14px;
  }

  .{{ section_id }} .rs1-works-title {
    font-size: 54px !important;
    font-weight: 500 !important;
    font-style: normal !important;
    line-height: 1.05 !important;
    letter-spacing: -0.012em !important;
    text-transform: none !important;
    color: var(--rs1-text) !important;
    margin-bottom: 10px;
  }

  .{{ section_id }} .rs1-works-title em {
    font-style: italic;
    color: var(--rs1-accent);
    font-weight: 500;
  }

  .{{ section_id }} .rs1-works-body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--rs1-text-2);
    max-width: 560px;
  }

  .{{ section_id }} .rs1-works-divider {
    display: block !important;
    margin-top: 40px;
    border-top: 1px solid var(--rs1-border);
  }

  .{{ section_id }} .rs1-works-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-left: 1px solid var(--rs1-border);
    margin-top: 0;
  }

  .{{ section_id }} .rs1-works-item {
    padding: 28px 26px 30px;
    border-right: 1px solid var(--rs1-border);
  }

  .{{ section_id }} .rs1-works-num {
    font-size: 32px;
    font-weight: 500;
    color: var(--rs1-accent);
    margin-bottom: 14px;
  }

  .{{ section_id }} .rs1-works-icon {
    width: 72px;
    height: 72px;
    margin-bottom: 14px;
    opacity: 0.92;
  }

  .{{ section_id }} .rs1-works-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .{{ section_id }} .rs1-works-item h4 {
    font-size: 15px;
    font-weight: 700;
    color: var(--rs1-text);
    margin-bottom: 8px;
  }

  .{{ section_id }} .rs1-works-item p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--rs1-text-2);
  }

  .{{ section_id }} .rs1-works-video {
    margin-top: 34px;
    border: 1px solid var(--rs1-border);
    border-radius: 12px;
    overflow: hidden;
    background: #000;
  }

  .{{ section_id }} .rs1-works-video-inner {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .{{ section_id }} .rs1-works-video-inner iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .{{ section_id }} .rs1-who {
    background: var(--rs1-bg);
    padding-top: 90px;
    padding-bottom: 90px;
  }

  .{{ section_id }} .rs1-who-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .{{ section_id }} .rs1-who-eyebrow {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rs1-accent);
    margin-bottom: 14px;
  }

  .{{ section_id }} .rs1-who-title {
    font-size: 44px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--rs1-text);
    margin-bottom: 26px;
    max-width: 560px;
  }

  .{{ section_id }} .rs1-who-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--rs1-accent);
  }

  .{{ section_id }} .rs1-who-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 18px;
    max-width: 640px;
  }

  .{{ section_id }} .rs1-who-item {
    display: grid;
    grid-template-columns: 10px 1fr;
    gap: 14px;
    align-items: start;
  }

  .{{ section_id }} .rs1-who-dot {
    width: 6px;
    height: 6px;
    background: var(--rs1-accent);
    border-radius: 1px;
    margin-top: 7px;
  }

  .{{ section_id }} .rs1-who-item h4 {
    font-size: 15px;
    font-weight: 700;
    color: var(--rs1-text);
    margin-bottom: 6px;
  }

  .{{ section_id }} .rs1-who-item p {
    font-size: 15px;
    line-height: 1.65;
    color: var(--rs1-text-2);
  }

  .{{ section_id }} .rs1-who-media {
    position: relative;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--rs1-border);
    border-radius: 12px;
    overflow: hidden;
    background: #000;
  }

  .{{ section_id }} .rs1-who-media:after {
    content: "";
    position: absolute;
    inset: 16px;
    border: 1px solid #dfb88a2e;
    border-radius: 8px;
    pointer-events: none;
  }

  .{{ section_id }} .rs1-who-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05) brightness(0.9);
  }

  @media (max-width: 1200px) {
    .{{ section_id }} .rs1-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 800px) {
    .{{ section_id }} .rs1-adv {
      background: var(--rs1-bg);
      padding-top: 70px;
      padding-bottom: 70px;
    }

    .{{ section_id }} .rs1-title {
      font-size: 42px;
    }

    .{{ section_id }} .rs1-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
      margin-top: 32px;
    }

    .{{ section_id }} .rs1-problem {
      padding-top: 70px;
      padding-bottom: 70px;
    }

    .{{ section_id }} .rs1-problem-grid {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .{{ section_id }} .rs1-problem-title {
      font-size: 40px;
    }

    .{{ section_id }} .rs1-solution {
      padding-top: 70px;
      padding-bottom: 70px;
    }

    .{{ section_id }} .rs1-solution-top {
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .{{ section_id }} .rs1-solution-title {
      font-size: 40px;
    }

    .{{ section_id }} .rs1-solution-divider {
      margin-top: 28px;
      margin-bottom: 22px;
    }

    .{{ section_id }} .rs1-solution-grid {
      grid-template-columns: 1fr;
      border-left: 0;
      padding-top: 22px;
    }

    .{{ section_id }} .rs1-solution-item {
      padding: 26px 0 26px;
      border-right: 0;
      border-top: 1px solid var(--rs1-border);
    }

    .{{ section_id }} .rs1-solution-item:first-child {
      border-top: 0;
    }

    .{{ section_id }} .rs1-works {
      padding-top: 70px;
      padding-bottom: 70px;
    }

    .{{ section_id }} .rs1-works-top {
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .{{ section_id }} .rs1-works-title {
      font-size: 40px;
    }

    .{{ section_id }} .rs1-works-divider {
      margin-top: 28px;
    }

    .{{ section_id }} .rs1-works-grid {
      grid-template-columns: 1fr;
      border-left: 0;
    }

    .{{ section_id }} .rs1-works-item {
      padding: 22px 0 22px;
      border-right: 0;
      border-top: 1px solid var(--rs1-border);
    }

    .{{ section_id }} .rs1-works-item:first-child {
      border-top: 0;
    }

    .{{ section_id }} .rs1-works-video {
      margin-top: 26px;
      border-radius: 10px;
    }

    .{{ section_id }} .rs1-who {
      padding-top: 70px;
      padding-bottom: 70px;
    }

    .{{ section_id }} .rs1-who-grid {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .{{ section_id }} .rs1-who-title {
      font-size: 34px;
      margin-bottom: 20px;
    }

    .{{ section_id }} .rs1-who-media {
      max-width: 520px;
    }
  }

  @media (max-width: 520px) {
    .{{ section_id }} .rs1-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="{{ section_id }}">
  <div class="rs1-adv">
    <div class="rs1-container">
      {% if section.settings.adv_eyebrow != blank %}
        <div class="rs1-eyebrow">{{ section.settings.adv_eyebrow }}</div>
      {% endif %}

      {% if section.settings.adv_title != blank %}
        <h2 class="rs1-title">{{ section.settings.adv_title }}</h2>
      {% endif %}

      <div class="rs1-grid">
        {% for block in section.blocks %}
          {% if block.type == 'point' %}
            <div class="rs1-card" {{ block.shopify_attributes }}>
              <div class="rs1-card__media">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'rs1-card__img' }}
                {% endif %}

                {% if block.settings.number != blank %}
                  <div class="rs1-card__num">{{ block.settings.number }}</div>
                {% endif %}
              </div>

              <div class="rs1-card__body">
                {% if block.settings.title != blank %}
                  <div class="rs1-card__title">{{ block.settings.title }}</div>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="rs1-card__text">{{ block.settings.text }}</div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="rs1-problem">
    <div class="rs1-container">
      <div class="rs1-problem-grid">
        <div>
          {% if section.settings.problem_eyebrow != blank %}
            <div class="rs1-problem-eyebrow">{{ section.settings.problem_eyebrow }}</div>
          {% endif %}

          {% if section.settings.problem_title != blank %}
            <h2 class="rs1-problem-title">{{ section.settings.problem_title }}</h2>
          {% endif %}

          {% if section.settings.problem_body != blank %}
            <div class="rs1-problem-body">{{ section.settings.problem_body }}</div>
          {% endif %}

          <ul class="rs1-problem-list" role="list">
            {% for block in section.blocks %}
              {% if block.type == 'problem_item' %}
                <li class="rs1-problem-item" {{ block.shopify_attributes }}>
                  {% if block.settings.number != blank %}
                    <div class="rs1-problem-num">{{ block.settings.number }}</div>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <div class="rs1-problem-text">{{ block.settings.text }}</div>
                  {% endif %}
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>

        <div>
          <div class="rs1-problem-media">
            {% if section.settings.problem_image != blank %}
              {{ section.settings.problem_image | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'rs1-problem-img' }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="rs1-solution">
    <div class="rs1-container">
      <div class="rs1-solution-top">
        <div>
          {% if section.settings.solution_eyebrow != blank %}
            <div class="rs1-solution-eyebrow">{{ section.settings.solution_eyebrow }}</div>
          {% endif %}

          {% if section.settings.solution_title != blank %}
            <h2 class="rs1-solution-title">{{ section.settings.solution_title }}</h2>
          {% endif %}
        </div>

        <div>
          {% if section.settings.solution_body != blank %}
            <div class="rs1-solution-body">{{ section.settings.solution_body }}</div>
          {% endif %}
        </div>
      </div>

      <div class="rs1-solution-divider"></div>

      <div class="rs1-solution-grid">
        {% for block in section.blocks %}
          {% if block.type == 'solution_item' %}
            <div class="rs1-solution-item" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <div class="rs1-solution-icon">
                  {{ block.settings.icon | image_url: width: 200 | image_tag: loading: 'lazy' }}
                </div>
              {% endif %}

              {% if block.settings.title != blank %}<h4>{{ block.settings.title }}</h4>{% endif %}
              {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="rs1-works">
    <div class="rs1-container">
      <div class="rs1-works-top">
        <div>
          {% if section.settings.works_eyebrow != blank %}
            <div class="rs1-works-eyebrow">{{ section.settings.works_eyebrow }}</div>
          {% endif %}

          {% if section.settings.works_title != blank %}
            <h2 class="rs1-works-title">{{ section.settings.works_title }}</h2>
          {% endif %}
        </div>

        <div>
          {% if section.settings.works_body != blank %}
            <div class="rs1-works-body">{{ section.settings.works_body }}</div>
          {% endif %}
        </div>
      </div>

      <div class="rs1-works-divider"></div>

      <div class="rs1-works-grid">
        {% for block in section.blocks %}
          {% if block.type == 'works_item' %}
            <div class="rs1-works-item" {{ block.shopify_attributes }}>
              {% if block.settings.number != blank %}<div class="rs1-works-num">{{ block.settings.number }}</div>{% endif %}

              {% if block.settings.icon != blank %}
                <div class="rs1-works-icon">
                  {{ block.settings.icon | image_url: width: 120 | image_tag: loading: 'lazy' }}
                </div>
              {% endif %}

              {% if block.settings.title != blank %}<h4>{{ block.settings.title }}</h4>{% endif %}
              {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.works_video != blank %}
        <div class="rs1-works-video">
          <div class="rs1-works-video-inner">
            {{ section.settings.works_video | video_tag: autoplay: false, loop: false, muted: false, controls: true }}
          </div>
        </div>
      {% elsif section.settings.works_video_url != blank %}
        <div class="rs1-works-video">
          <div class="rs1-works-video-inner">
            {% liquid
              assign _video_id = section.settings.works_video_url.id
              assign _video_type = section.settings.works_video_url.type
            %}
            {% if _video_type == 'youtube' %}
              <iframe
                src="https://www.youtube.com/embed/{{ _video_id }}?rel=0&modestbranding=1"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                title="RS1 video"
              ></iframe>
            {% elsif _video_type == 'vimeo' %}
              <iframe
                src="https://player.vimeo.com/video/{{ _video_id }}"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                title="RS1 video"
              ></iframe>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="rs1-who">
    <div class="rs1-container">
      <div class="rs1-who-grid">
        <div>
          {% if section.settings.who_eyebrow != blank %}
            <div class="rs1-who-eyebrow">{{ section.settings.who_eyebrow }}</div>
          {% endif %}

          {% if section.settings.who_title != blank %}
            <h2 class="rs1-who-title">{{ section.settings.who_title }}</h2>
          {% endif %}

          <ul class="rs1-who-list" role="list">
            {% for block in section.blocks %}
              {% if block.type == 'who_item' %}
                <li class="rs1-who-item" {{ block.shopify_attributes }}>
                  <span class="rs1-who-dot"></span>
                  <div>
                    {% if block.settings.title != blank %}<h4>{{ block.settings.title }}</h4>{% endif %}
                    {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
                  </div>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>

        <div>
          <div class="rs1-who-media">
            {% if section.settings.who_image != blank %}
              {{ section.settings.who_image | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'rs1-who-img' }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

