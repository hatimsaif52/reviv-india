        /* 1. Muted/Default State */
.timeline-item {
    opacity: 0.35;
    transition: all 0.4s ease-in-out;
}

/* 2. Active State - Full Visibility */
.timeline-item.is-active {
    opacity: 1 !important;
}

/* 3. Text & Variable Overrides */
.timeline-item.is-active p,
.timeline-item.is-active span,
.timeline-item.is-active .gp-g-paragraph-1,
.timeline-item.is-active [data-gp-text-class],
.timeline-item.is-active h2,
.timeline-item.is-active .gp-g-heading-1 {
    color: #E4893A !important;
    --c: #E4893A !important;
    --td1: #E4893A !important;
}

.timeline-item.is-active i,
.timeline-item.is-active svg,
.timeline-item.is-active .gp-icon {
    color: #E4893A !important;
    fill: #E4893A !important;
}

/* 4. THE PROGRESS TRACK (Line & Filling) */
.timeline-container {
    border-left: none !important; 
    position: relative;
}

/* Static Grey Track */
.timeline-container::before {
    content: "";
    position: absolute;
    left: -2px;
    top: 50px;     /* Starts at center of Dot 1 */
    bottom: 105px;  /* <--- INCREASE THIS VALUE until the line ends at center of Dot 3 */
    width: 2px;
    background-color: #333;
    z-index: 0;
}
/* Gold Filling Line */
.timeline-container::after {
    content: "";
    position: absolute;
    left: -2px;
    top: 50px;     /* Matches top of grey track */
    width: 2px;
    height: var(--line-height, 0%);
    background-color: #E4893A;
    z-index: 1;
    transition: height 0.1s linear;
  max-height: calc(100% - 150px); /* Adjust this to match (top + bottom from above) */
}

/* Active Dot Pulse */
.timeline-item.is-active .timeline-dot {
    background-color: #E4893A !important;
    box-shadow: 0 0 10px #E4893A, 0 0 20px rgba(228, 137, 58, 0.4);
    transform: scale(1.3);
    transition: all 0.3s ease;
}

/* 5. Section Stacking & Sticky Video */
.timeline-section-wrapper {
    position: relative;
    z-index: 1;
}

.section-after-timeline {
    position: relative;
    z-index: 2;
    background: #000;
}

.sticky-video-col {
    position: sticky !important;
    top: 120px;
    z-index: 1;
}
