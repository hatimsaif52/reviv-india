                    l: { only: "47827001999601", support: "47827001901297" },
                    xl: { only: "47827001704689", support: "47827001606385" },
                },
            };

            var HERO_MEDIA = {
                yellowProduct: {
                    type: "image",
                    src: "https://cdn.shopify.com/s/files/1/0706/4243/4289/files/ig_019a45d28ae9ca180169f16021ea8c8191aaeb3ae373c7bfe9.png?v=1777426542&format=webp",
