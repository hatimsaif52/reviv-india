                    src: "https://cdn.shopify.com/s/files/1/0706/4243/4289/files/reviv-r3-what-to-expect-timeline.avif?v=1782982140",
                    alt: "What to expect with Reviv timeline",
                },
                included: {
                    type: "image",
                    src: "https://cdn.shopify.com/s/files/1/0706/4243/4289/files/reviv-r3-whats-included-kit.avif?v=1782982140",
                    alt: "What's included with Reviv R3",
                },
                routine: {
                    type: "image",
                    src: "https://cdn.shopify.com/s/files/1/0706/4243/4289/files/reviv-r3-nightly-routine-benefits.avif?v=1782982140",
                    alt: "Reviv R3 nightly routine benefits",
                },
                reviews: {
                    type: "image",
                    src: "https://cdn.shopify.com/s/files/1/0706/4243/4289/files/reviv-r3-social-proof-reviews.avif?v=1782982140",
                    alt: "Reviv R3 social proof and reviews",
                },
                comparison: {
                    type: "image",
                    src: "https://getreviv.com/cdn/shop/files/R3_vs._R2_image_for_product_page_1.png?v=1767939249&width=1646",
                    alt: "R3 vs R2 product comparison",
                },
                support: {
                    type: "image",
                    src: "https://getreviv.com/cdn/shop/files/ChatGPT_Image_Apr_14_2026_02_18_01_PM_5fa2ffce-9e69-4b9d-8f58-4abe3af6f078.png?v=1782465377&width=1646",
                    alt: "EGK Biomechanics community and support membership",
                },
                youtube: {
                    type: "youtube",
                    src: "https://www.youtube.com/embed/ZFB03kxlCjg",
                    thumb: "https://img.youtube.com/vi/ZFB03kxlCjg/hqdefault.jpg",
                    alt: "Reviv R3 video",
                },
                productVideo: {
                    type: "video",
                    src: "https://getreviv.com/cdn/shop/videos/c/vp/b84e026e9e6c4aeb8054b627d6b01f7d/b84e026e9e6c4aeb8054b627d6b01f7d.HD-1080p-7.2Mbps-64205587.mp4?v=0",
                    poster: "https://cdn.shopify.com/s/files/1/0706/4243/4289/files/reviv-r3-nightly-routine-benefits.avif?v=1782982140",
                    alt: "Reviv R3 product video",
                },
            };
            var HERO_GALLERIES = {
                yellow: [
                    HERO_MEDIA.yellowProduct,
                    HERO_MEDIA.included,
                    HERO_MEDIA.routine,
                    HERO_MEDIA.reviews,
                    HERO_MEDIA.timeline,
                    HERO_MEDIA.productVideo,
                    HERO_MEDIA.comparison,
                    HERO_MEDIA.youtube,
                    HERO_MEDIA.support,
                ],
                clear: [
                    HERO_MEDIA.clearProduct,
                    HERO_MEDIA.included,
                    HERO_MEDIA.routine,
                    HERO_MEDIA.reviews,
                    HERO_MEDIA.timeline,
                    HERO_MEDIA.productVideo,
                    HERO_MEDIA.comparison,
                    HERO_MEDIA.youtube,
                    HERO_MEDIA.support,
                ],
            };

            var state = { size: "m", color: "yellow", pkg: "only" };
            var ctaText = {
                only: "Start Now",
                support: "Start Now",
            };

            function currentUrl() {
                var id = VARIANTS[state.color][state.size][state.pkg];
                var url = PRODUCT_URL + "?variant=" + id;
                var qs = window.location.search;
                if (qs) {
                    var incoming = new URLSearchParams(qs);
                    var u = new URL(url);
                    incoming.forEach(function (value, key) {
                        if (!u.searchParams.has(key)) {
                            u.searchParams.set(key, value);
                        }
                    });
                    url = u.toString();
                }
                return url;
            }

            function render() {
                var url = currentUrl();
                var label = ctaText[state.pkg];
                var buyBtn = document.getElementById("pd-buy-btn");
                if (buyBtn) {
                    buyBtn.setAttribute("data-href", url);
                    buyBtn.textContent = label;
                }
                document
                    .querySelectorAll("#reviv-pdp .pd-buy-link")
                    .forEach(function (a) {
                        a.setAttribute("data-href", url);
                        var textEl = a.querySelector(".pd-sticky-cta-text");
                        if (textEl) {
                            textEl.textContent = label;
                        } else if (a.classList.contains("pd-primary-btn")) {
                            a.textContent = label;
                        }
                    });
            }

            function wireGroup(groupId, attr, key, onChange) {
                var group = document.getElementById(groupId);
                if (!group) return;
                group.addEventListener("click", function (e) {
                    var btn = e.target.closest("[" + attr + "]");
                    if (!btn) return;
                    state[key] = btn.getAttribute(attr);
                    group
                        .querySelectorAll("[" + attr + "]")
                        .forEach(function (el) {
                            el.classList.toggle("is-active", el === btn);
                        });
                    if (onChange) onChange(btn);
                    render();
                });
            }

            function setFieldValue(id, btn) {
                var el = document.getElementById(id);
                if (el) el.textContent = btn.getAttribute("data-label");
            }

            wireGroup("pd-size-group", "data-size", "size", function (btn) {
                setFieldValue("pd-size-value", btn);
            });
            wireGroup("pd-color-group", "data-color", "color", function (btn) {
                setFieldValue("pd-color-value", btn);
                renderGallery(state.color);
            });
            wireGroup(
                "pd-package-group",
                "data-package",
                "pkg",
                function (btn) {
                    setFieldValue("pd-package-value", btn);
                },
            );

            render();

            /* ---- gallery ---- */
            var mainMedia = document.querySelector("#reviv-pdp .pd-gallery-main");
            var thumbsWrap = document.querySelector("#reviv-pdp .pd-thumbs");
            var currentGalleryItems = [];

            function setMainMedia(item) {
                if (!item || !mainMedia) return;
                mainMedia.innerHTML = "";

                if (item.type === "video") {
                    var video = document.createElement("video");
                    video.controls = true;
                    video.playsInline = true;
                    video.preload = "metadata";
                    if (item.poster) video.poster = item.poster;

                    var source = document.createElement("source");
                    source.src = item.src;
                    source.type = "video/mp4";
                    video.appendChild(source);
                    mainMedia.appendChild(video);
                    return;
                }

                if (item.type === "youtube") {
                    var iframe = document.createElement("iframe");
                    iframe.src = item.src;
                    iframe.title = item.alt || "Reviv video";
                    iframe.loading = "lazy";
                    iframe.allow =
                        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
                    iframe.allowFullscreen = true;
                    mainMedia.appendChild(iframe);
                    return;
                }

                var img = document.createElement("img");
                img.src = item.src;
                img.alt = item.alt || "Reviv R3 mouthguard";
                img.loading = "eager";
                mainMedia.appendChild(img);
            }

            function renderGallery(color) {
                if (!thumbsWrap) return;
                var images = HERO_GALLERIES[color] || HERO_GALLERIES.yellow;
                currentGalleryItems = images;
                thumbsWrap.innerHTML = "";
                images.forEach(function (item, index) {
                    var button = document.createElement("button");
                    button.className =
                        "pd-thumb" +
                        (index === 0 ? " is-active" : "") +
                        (item.type === "video" || item.type === "youtube"
                            ? " pd-thumb--video"
                            : "");
                    button.type = "button";
                    button.setAttribute("data-index", String(index));
                    button.setAttribute("aria-label", item.alt || "View product media");

                    var img = document.createElement("img");
                    img.src = item.thumb || item.poster || item.src;
                    img.alt = item.alt || "Reviv R3 mouthguard";
                    img.loading = "lazy";

                    button.appendChild(img);
                    thumbsWrap.appendChild(button);
                });
                setMainMedia(images[0]);
                thumbsWrap.scrollTop = 0;
                updateThumbArrows();
            }

            var thumbUpBtn = document.querySelector(
                "#reviv-pdp .pd-thumb-arrow--up",
            );
            var thumbDownBtn = document.querySelector(
                "#reviv-pdp .pd-thumb-arrow--down",
            );

            function thumbScrollStep() {
                var thumb = thumbsWrap.querySelector(".pd-thumb");
                if (!thumb) return 0;
                var gap =
                    parseFloat(getComputedStyle(thumbsWrap).rowGap) || 0;
                return (thumb.offsetHeight + gap) * 2;
            }

            function updateThumbArrows() {
                if (!thumbsWrap || !thumbUpBtn || !thumbDownBtn) return;
                var maxScroll =
                    thumbsWrap.scrollHeight - thumbsWrap.clientHeight;
                thumbUpBtn.disabled = thumbsWrap.scrollTop <= 1;
                thumbDownBtn.disabled =
                    thumbsWrap.scrollTop >= maxScroll - 1;
            }

            if (thumbsWrap && thumbUpBtn && thumbDownBtn) {
                thumbUpBtn.addEventListener("click", function () {
                    thumbsWrap.scrollBy({
                        top: -thumbScrollStep(),
                        behavior: "smooth",
                    });
                });
                thumbDownBtn.addEventListener("click", function () {
                    thumbsWrap.scrollBy({
                        top: thumbScrollStep(),
                        behavior: "smooth",
                    });
                });
                thumbsWrap.addEventListener("scroll", updateThumbArrows, {
                    passive: true,
                });
                window.addEventListener("resize", updateThumbArrows);
            }

            if (thumbsWrap) {
                thumbsWrap.addEventListener("click", function (e) {
                    var thumb = e.target.closest(".pd-thumb");
                    if (!thumb || !thumbsWrap.contains(thumb)) return;
                    var index = Number(thumb.getAttribute("data-index"));
                    setMainMedia(currentGalleryItems[index]);
                    thumbsWrap.querySelectorAll(".pd-thumb").forEach(function (t) {
                        t.classList.toggle("is-active", t === thumb);
                    });
                });
            }

            renderGallery(state.color);
        })();

        (function () {
            var shellSelectors = [
                "#gt_float_wrapper",
                ".gt_float_switcher",
                "#google_translate_element",
                "div[class*='kl-teaser-']",
                ".needsclick[class*='kl-teaser-']",
                "[data-testid='animated-teaser']",
                "[data-testid='POPUP']",
                "[aria-label='POPUP Form']",
                "form[class*='klaviyo-form']",
                ".klaviyo-form",
                "img[src*='zo-ko-wp_widget_icon']",
                "a[href*='wa.me']",
                "a[href*='whatsapp' i]",
                "iframe[src*='whatsapp' i]",
                "img[src*='whatsapp' i]",
                "[id*='whatsapp' i]",
                "[class*='whatsapp' i]",
                "h1.main-page-title",
                "h1.page-title",
                ".main-page-title.page-title",
            ];

            function removeShellWidgets() {
                shellSelectors.forEach(function (selector) {
                    try {
                        document
                            .querySelectorAll(selector)
                            .forEach(function (el) {
                                el.remove();
                            });
                    } catch (e) {}
                });

                document.querySelectorAll(".needsclick").forEach(function (el) {
                    if (
                        /Get 10% Off Reviv|UNLOCK 10% OFF/.test(
                            el.textContent || "",
                        )
                    ) {
                        el.remove();
                    }
                });

                document
                    .querySelectorAll(
                        "#MainContent, .content-for-layout, [id^='shopify-section-template--'][id*='__main'], .page-width, .page-width--narrow, [class*='section-template--'][class*='__main-padding'], .rte",
                    )
                    .forEach(function (el) {
                        if (
                            el.querySelector &&
                            el.querySelector("#reviv-pdp")
                        ) {
                            el.style.setProperty(
                                "max-width",
                                "100%",
                                "important",
                            );
                            el.style.setProperty("width", "100%", "important");
                            el.style.setProperty("padding", "0", "important");
                            el.style.setProperty("margin", "0", "important");
                        }
                    });
            }

            removeShellWidgets();
            window.addEventListener("load", removeShellWidgets);
            window.setTimeout(removeShellWidgets, 500);
            window.setTimeout(removeShellWidgets, 1500);

            if (window.MutationObserver && document.documentElement) {
                new MutationObserver(removeShellWidgets).observe(
                    document.documentElement,
                    {
                        childList: true,
                        subtree: true,
                    },
                );
            }
        })();

        (function () {
            /* ---- size chart modal ---- */
            var modal = document.getElementById("pd-size-modal");
            var openBtn = document.getElementById("pd-size-chart-open");
            if (!modal || !openBtn) return;

            function setOpen(open) {
                modal.classList.toggle("is-open", open);
                document.body.style.overflow = open ? "hidden" : "";
            }

            openBtn.addEventListener("click", function () {
                setOpen(true);
            });
            [
                document.getElementById("pd-size-chart-close"),
                document.getElementById("pd-size-chart-close-btn"),
            ].forEach(function (btn) {
                if (btn)
                    btn.addEventListener("click", function () {
                        setOpen(false);
                    });
            });
            modal.addEventListener("click", function (e) {
                if (e.target === modal) setOpen(false);
            });
            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape" && modal.classList.contains("is-open"))
                    setOpen(false);
            });
        })();

        (function () {
            /* ---- other products add to cart ---- */
            var buttons = document.querySelectorAll("#reviv-pdp .pd-other-atc");
            if (!buttons.length) return;

            var onShopify = /(^|\.)getreviv\.com$/.test(
                window.location.hostname,
            );

            buttons.forEach(function (btn) {
                btn.addEventListener("click", function () {
                    var variantId = btn.getAttribute("data-variant");
                    if (!variantId || btn.disabled) return;

                    if (!onShopify) {
                        /* preview fallback: Shopify cart permalink */
                        window.location.href =
                            "https://getreviv.com/cart/add?id=" +
                            variantId +
                            "&quantity=1";
                        return;
                    }

                    var original = btn.textContent;
                    btn.disabled = true;
                    btn.textContent = "Adding…";

                    /* native xBoost path: xbcFetch runs the app's own
                       cart flow + opens the drawer on cart/add responses */
                    var doFetch = window.xbcFetch || window.fetch;
                    var fd = new FormData();
                    fd.append("id", variantId);
                    fd.append("quantity", "1");

                    doFetch("/cart/add.js?xboost_slidecart=true", {
                        method: "POST",
                        body: fd,
                    })
                        .then(function (res) {
                            if (!res.ok) throw new Error("add failed");
                            return res.json();
                        })
                        .then(function () {
                            btn.textContent = "Added ✓";
                            btn.classList.add("is-added");
                            if (!window.xbcFetch) {
                                /* fallback: ask the app to refresh + open */
                                document.dispatchEvent(
                                    new CustomEvent(
                                        "xboost-need-refresh-and-open-cart",
                                        { bubbles: true },
                                    ),
                                );
                            }
                            setTimeout(function () {
                                btn.textContent = original;
                                btn.classList.remove("is-added");
                                btn.disabled = false;
                            }, 2000);
                        })
                        .catch(function () {
                            btn.disabled = false;
                            btn.textContent = original;
                            /* hard fallback: cart permalink */
                            window.location.href =
                                "/cart/add?id=" + variantId + "&quantity=1";
                        });
                });
            });
        })();

        (function () {
            /* ---- other products carousel ---- */
            var track = document.getElementById("pd-other-track");
            var prev = document.getElementById("pd-other-prev");
            var next = document.getElementById("pd-other-next");
            if (!track || !prev || !next) return;

            function step() {
                var card = track.querySelector(".pd-other-card");
                if (!card) return track.clientWidth;
                var gap = parseFloat(getComputedStyle(track).gap) || 16;
                return card.getBoundingClientRect().width + gap;
            }

            function updateArrows() {
                var max = track.scrollWidth - track.clientWidth - 2;
                prev.disabled = track.scrollLeft <= 2;
                next.disabled = track.scrollLeft >= max;
            }

            prev.addEventListener("click", function () {
                track.scrollBy({ left: -step(), behavior: "smooth" });
            });
            next.addEventListener("click", function () {
                track.scrollBy({ left: step(), behavior: "smooth" });
            });
            track.addEventListener("scroll", updateArrows, { passive: true });
            window.addEventListener("resize", updateArrows);
            updateArrows();
        })();

        (function () {
            var hero = document.querySelector("#reviv-pdp .pd-hero");
            var sticky = document.querySelector("#reviv-pdp .pd-sticky");
            if (!hero || !sticky) return;

            function update() {
                var heroBottom = hero.getBoundingClientRect().bottom;
                var show = heroBottom <= 0;
                sticky.classList.toggle("is-visible", show);
                sticky.classList.remove("is-suppressed");
            }

            update();
            window.addEventListener("scroll", update, { passive: true });
            window.addEventListener("resize", update);

            var jumpBtn = document.getElementById("pd-sticky-jump");
            if (jumpBtn) {
                jumpBtn.addEventListener("click", function () {
                    hero.scrollIntoView({
                        behavior: "smooth",
                        block: "start",
                    });
                });
            }
        })();

        (function () {
            /* ---- header dropdown menus ---- */
            var controlGroups = document.querySelectorAll(
                "#reviv-pdp .pd-header-controls",
            );

            function closeMenus() {
                controlGroups.forEach(function (box) {
                    box.classList.remove("is-open");
                    var btn = box.querySelector(".pd-menu-btn");
                    if (btn) btn.setAttribute("aria-expanded", "false");
                });
            }

            controlGroups.forEach(function (box) {
                var btn = box.querySelector(".pd-menu-btn");
                if (!btn) return;
                btn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    var willOpen = !box.classList.contains("is-open");
                    closeMenus();
                    box.classList.toggle("is-open", willOpen);
                    btn.setAttribute(
                        "aria-expanded",
                        willOpen ? "true" : "false",
                    );
                });
                box.querySelectorAll(".pd-menu-dropdown a").forEach(
                    function (a) {
                        a.addEventListener("click", closeMenus);
                    },
                );
            });

            document.addEventListener("click", function (e) {
                if (!e.target.closest("#reviv-pdp .pd-header-controls")) {
                    closeMenus();
                }
            });

            /* ---- floating standalone nav: shows on scroll up ---- */
            var header = document.getElementById("pd-header");
            var floatNav = document.getElementById("pd-float-nav");
            if (!header || !floatNav) return;

            var lastY = window.pageYOffset || 0;

            function updateFloatNav() {
                var y = window.pageYOffset || 0;
                var pastHeader =
                    y > header.offsetTop + header.offsetHeight + 24;
                var show;
                if (!pastHeader) {
                    show = false;
                } else if (y < lastY) {
                    show = true;
                } else if (y > lastY) {
                    show = false;
                } else {
                    show = floatNav.classList.contains("is-visible");
                }
                floatNav.classList.toggle("is-visible", show);
                floatNav.setAttribute("aria-hidden", show ? "false" : "true");
                if (!show) {
                    floatNav
                        .querySelectorAll(".pd-header-controls.is-open")
                        .forEach(function (box) {
                            box.classList.remove("is-open");
                            var btn = box.querySelector(".pd-menu-btn");
                            if (btn) {
                                btn.setAttribute("aria-expanded", "false");
                            }
                        });
                }
                lastY = y;
            }

            updateFloatNav();
            window.addEventListener("scroll", updateFloatNav, {
                passive: true,
            });
            window.addEventListener("resize", updateFloatNav);
        })();

        (function () {
            /* ---- AJAX add-to-cart + slide cart open ---- */
            var busy = false;

            function getBuyUrl(a) {
                return a.getAttribute("data-href") || a.href || "";
            }

            function getVariant(a) {
                try {
                    return new URL(
                        getBuyUrl(a),
                        window.location.origin,
                    ).searchParams.get("variant");
                } catch (err) {
                    return null;
                }
            }

            function slideCartVisible() {
                var el = document.querySelector(".xboost-slide-cart-width");
                if (!el) return false;
                var rect = el.getBoundingClientRect();
                return (
                    rect.width > 50 &&
                    rect.left < window.innerWidth &&
                    rect.right > 0
                );
            }

            function tryOpenSlideCart() {
                /* xBoost slide cart: refresh cart data + open drawer */
                document.dispatchEvent(
                    new CustomEvent("xboost-need-refresh-and-open-cart", {
                        bubbles: true,
                    }),
                );
            }

            function notifyCartUpdated() {
                ["cart:refresh", "cart:updated", "cart:change"].forEach(
                    function (name) {
                        try {
                            document.dispatchEvent(
                                new CustomEvent(name, { bubbles: true }),
                            );
                        } catch (err) {}
                    },
                );
            }

            function canUseAjaxCart() {
                return (
                    window.fetch &&
                    /^https?:$/.test(window.location.protocol) &&
                    /getreviv\.com$/.test(window.location.hostname)
                );
            }

            document.addEventListener("click", function (e) {
                var a = e.target.closest("#pd-buy-btn, .pd-buy-link");
                if (!a || !getBuyUrl(a)) return;
                var variant = getVariant(a);
                if (!variant || !canUseAjaxCart()) {
                    /* buttons don't navigate on their own */
                    e.preventDefault();
                    window.location.href = getBuyUrl(a);
                    return;
                }
                e.preventDefault();
                if (busy) return;
                busy = true;

                /* native xBoost path: xbcFetch runs the app's own
                   cart flow + opens the drawer on cart/add responses */
                var doFetch = window.xbcFetch || window.fetch;
                var fd = new FormData();
                fd.append("id", variant);
                fd.append("quantity", "1");

                doFetch("/cart/add.js?xboost_slidecart=true", {
                    method: "POST",
                    body: fd,
                })
                    .then(function (res) {
                        if (!res.ok) throw new Error("add failed");
                        return res.json();
                    })
                    .then(function () {
                        notifyCartUpdated();
                        if (!window.xbcFetch) tryOpenSlideCart();
                        window.setTimeout(function () {
                            busy = false;
                            if (!slideCartVisible()) {
                                window.location.href = "/cart";
                            }
                        }, 1100);
                    })
                    .catch(function () {
                        busy = false;
                        window.location.href = getBuyUrl(a);
                    });
            });

            /* ---- header cart icons open the slide cart too ---- */
            document.addEventListener("click", function (e) {
                var cartLink = e.target.closest("#reviv-pdp a[href$='/cart']");
                if (!cartLink) return;
                if (
                    !canUseAjaxCart() ||
                    !document.querySelector(".xboost-slide-cart-width")
                ) {
                    return; /* normal nav to /cart */
                }
                e.preventDefault();
                tryOpenSlideCart();
                window.setTimeout(function () {
                    if (!slideCartVisible()) {
                        window.location.href = cartLink.href;
                    }
                }, 900);
            });
        })();
    </script>
</main>

