<style>
    :root {
        --reviv-dark: #242021;
        --reviv-dark-alt: #171515;
        --reviv-cream: #eef1ec;
        --reviv-paper: #fffaf1;
        --reviv-cta: #fcb23e;
        --reviv-cta-hover: #e59d2f;
        --reviv-gold: #e0b580;
        --reviv-gold-hover: #cfa36c;
        --reviv-ink: var(--reviv-dark);
        --reviv-muted: rgba(35, 32, 33, 0.72);
        --reviv-border: rgba(35, 32, 33, 0.14);
        --font-heading:
            "Instrument Sans", system-ui, -apple-system, BlinkMacSystemFont,
            "Segoe UI", sans-serif;
        --fs-xs: clamp(0.75rem, 0.7rem + 0.15vw, 0.84rem);
        --fs-sm: clamp(0.875rem, 0.82rem + 0.18vw, 0.98rem);
        --fs-base: clamp(1rem, 0.94rem + 0.2vw, 1.1rem);
        --fs-lg: clamp(1.125rem, 1.04rem + 0.3vw, 1.25rem);
        --fs-xl: clamp(1.35rem, 1.2rem + 0.55vw, 1.65rem);
        --fs-2xl: clamp(1.65rem, 1.35rem + 1vw, 2.15rem);
        --fs-3xl: clamp(2rem, 1.6rem + 1.45vw, 2.75rem);
        --fs-4xl: clamp(2.35rem, 1.85rem + 1.85vw, 3.35rem);
    }

    #shopify-section-header,
    .header-wrapper,
    .shopify-section-group-header-group,
    .main-header,
    #site-header,
    footer,
    .footer,
    #shopify-section-footer {
        display: none !important;
    }

    #MainContent,
    main#MainContent,
    .content-for-layout,
    [id^="shopify-section-template--"][id*="__main"],
    .page-width,
    .page-width.page-width--narrow {
        max-width: 100% !important;
        width: 100% !important;
        padding-top: 0 !important;
        padding-right: 0 !important;
        padding-bottom: 0 !important;
        padding-left: 0 !important;
        margin-top: 0 !important;
        margin-right: 0 !important;
        margin-bottom: 0 !important;
        margin-left: 0 !important;
    }

    .shopify-section:has(#reviv-pdp),
    .page-width:has(#reviv-pdp),
    .rte:has(#reviv-pdp) {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    [class*="section-template--"][class*="__main-padding"] {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
    }

    h1.main-page-title,
    h1.page-title,
    .main-page-title.page-title {
        display: none !important;
    }

    .rte,
    .rte.scroll-trigger,
    .rte.scroll-trigger.animate--slide-in {
        margin: 0 !important;
        max-width: none !important;
        padding: 0 !important;
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
    }

    #gt_float_wrapper,
    .gt_float_switcher,
    #google_translate_element,
    #xboost-upsell-sticky-add-to-cart-root,
    #xboost-upsell-sticky-cart-root,
    [id^="xboost-upsell-sticky"],
    #xb-sticky-add-to-cart,
    .xb_sticky_add_to_cart,
    div[class*="kl-teaser-"],
    .needsclick[class*="kl-teaser-"],
    [data-testid="animated-teaser"],
    [data-testid="POPUP"],
    [aria-label="POPUP Form"],
    form[class*="klaviyo-form"],
    .klaviyo-form,
    img[src*="zo-ko-wp_widget_icon"],
    a[href*="wa.me"],
    a[href*="whatsapp" i],
    iframe[src*="whatsapp" i],
    img[src*="whatsapp" i],
    [id*="whatsapp" i],
    [class*="whatsapp" i] {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
    }

    html {
        scroll-behavior: smooth;
    }
    body {
        margin: 0;
        background: var(--reviv-cream);
    }

    #reviv-pdp {
        margin-top: 0 !important;
        padding-top: 0 !important;
        background: var(--reviv-cream);
        color: var(--reviv-ink);
    }

    #reviv-pdp,
    #reviv-pdp * {
        box-sizing: border-box;
        font-family:
            "Instrument Sans",
            system-ui,
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            sans-serif;
    }

    #reviv-pdp a {
        color: inherit;
    }

    #reviv-pdp h1,
    #reviv-pdp h2,
    #reviv-pdp h3 {
        font-family: var(--font-heading) !important;
        font-weight: 500;
    }

    .pd-sale-bar {
        margin-top: 0 !important;
        background: var(--reviv-dark);
        color: var(--reviv-cream);
        text-align: center;
        padding: 0.66rem 1rem 0.6rem;
        font-size: var(--fs-xs);
        line-height: 1.12;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 800;
    }

    /* ---------- header ---------- */

    .pd-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem clamp(1.25rem, 3.5vw, 2.75rem);
        background: var(--reviv-cream);
    }

    .pd-logo-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--reviv-dark);
        border-radius: 999px;
        padding: 0.62rem 1.35rem 0.58rem;
        box-shadow: 0 0.4rem 1.2rem rgba(0, 0, 0, 0.16);
        text-decoration: none;
    }

    .pd-logo {
        display: block;
        width: clamp(5.6rem, 9vw, 7.25rem);
        height: auto;
    }

    .pd-header-controls {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: #fff;
        border: 1px solid var(--reviv-border);
        border-radius: 999px;
        padding: 0.32rem 0.55rem 0.32rem 0.32rem;
        box-shadow: 0 0.4rem 1.2rem rgba(0, 0, 0, 0.1);
    }

    .pd-shop-btn {
        border: 0;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        background: var(--reviv-cta);
        color: var(--reviv-dark) !important;
        border-radius: 999px;
        padding: 0.58rem 1.2rem 0.54rem;
        font-size: var(--fs-sm);
        font-weight: 800;
        letter-spacing: -0.01em;
        text-decoration: none;
        transition: background 0.15s ease;
    }

    .pd-shop-btn:hover {
        background: var(--reviv-cta-hover);
    }

    .pd-icon-btn {
        display: inline-grid;
        place-items: center;
        width: 2.4rem;
        height: 2.4rem;
        border: 0;
        border-radius: 50%;
        background: transparent;
        color: var(--reviv-dark);
        cursor: pointer;
        padding: 0;
        transition: background 0.15s ease;
    }

    .pd-icon-btn:hover {
        background: rgba(35, 32, 33, 0.07);
    }

    .pd-menu-dropdown {
        position: absolute;
        top: calc(100% + 0.55rem);
        right: 0;
        min-width: 12.5rem;
        background: #fff;
        border: 1px solid var(--reviv-border);
        border-radius: 1.1rem;
        box-shadow: 0 1rem 2.6rem rgba(0, 0, 0, 0.16);
        padding: 0.45rem;
        display: none;
        z-index: 60;
    }

    .pd-header-controls.is-open .pd-menu-dropdown {
        display: block;
    }

    .pd-menu-dropdown a {
        display: block;
        padding: 0.6rem 0.85rem;
        border-radius: 0.7rem;
        font-size: var(--fs-sm);
        font-weight: 600;
        color: var(--reviv-ink);
        text-decoration: none;
    }

    .pd-menu-dropdown a:hover {
        background: rgba(35, 32, 33, 0.06);
    }

    /* ---------- floating standalone nav (appears on scroll up) ---------- */

    .pd-float-nav {
        position: fixed;
        top: 0.85rem;
        left: 0;
        right: 0;
        z-index: 40;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        padding: 0 clamp(1.25rem, 3.5vw, 2.75rem);
        opacity: 0;
        transform: translateY(-0.65rem);
        pointer-events: none;
        visibility: hidden;
        transition:
            opacity 0.18s ease,
            transform 0.18s ease,
            visibility 0s linear 0.18s;
    }

    .pd-float-nav .pd-logo-badge {
        border: 1px solid rgba(238, 241, 236, 0.3);
        box-shadow: 0 0.5rem 1.4rem rgba(0, 0, 0, 0.28);
    }

    .pd-float-nav.is-visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
        visibility: visible;
        transition-delay: 0s;
    }

    /* ---------- PDP hero: gallery + buy box ---------- */

    .pd-hero {
        width: min(100%, 90rem);
        margin: 0 auto;
        padding: clamp(1.5rem, 3.5vw, 3.25rem) 1.25rem clamp(2.5rem, 5vw, 4rem);
        display: grid;
        grid-template-columns: minmax(0, 1.04fr) minmax(0, 0.96fr);
        gap: clamp(1.75rem, 4vw, 3.5rem);
        align-items: start;
    }

    .pd-gallery {
        position: sticky;
        top: 1.25rem;
        padding-left: 5.9rem;
    }

    .pd-gallery-main {
        aspect-ratio: 1 / 1;
        border-radius: 1.4rem;
        overflow: hidden;
        background: #fff;
        border: 2px solid #242021;
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.08);
    }

    .pd-gallery-main img,
    .pd-gallery-main video,
    .pd-gallery-main iframe {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: contain;
        border: 0;
    }

    .pd-thumb-rail {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 0;
        width: 5rem;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .pd-thumbs {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        overflow-y: auto;
        scrollbar-width: none;
    }

    .pd-thumbs::-webkit-scrollbar {
        display: none;
    }

    .pd-thumb-arrow {
        flex: none;
        height: 2.3rem;
        border-radius: 999px;
        border: 0;
        background: var(--reviv-dark);
        color: #fff;
        padding: 0;
        cursor: pointer;
        display: grid;
        place-items: center;
        box-shadow: 0 0.35rem 0.9rem rgba(36, 32, 33, 0.18);
        transition:
            opacity 0.15s ease,
            background 0.15s ease,
            transform 0.15s ease,
            box-shadow 0.15s ease;
    }

    .pd-thumb-arrow svg {
        width: 1rem;
        height: 1rem;
        display: block;
    }

    .pd-thumb-arrow:hover:not(:disabled) {
        background: var(--reviv-dark-alt, #171515);
        transform: translateY(-1px);
        box-shadow: 0 0.5rem 1.1rem rgba(36, 32, 33, 0.24);
    }

    .pd-thumb-arrow--down:hover:not(:disabled) {
        transform: translateY(1px);
    }

    .pd-thumb-arrow:active:not(:disabled) {
        transform: none;
    }

    .pd-thumb-arrow:disabled {
        opacity: 0.22;
        cursor: default;
        box-shadow: none;
    }

    .pd-thumb {
        flex: none;
        aspect-ratio: 1 / 1;
        border-radius: 0.7rem;
        overflow: hidden;
        border: 2px solid transparent;
        background: #fff;
        padding: 0;
        cursor: pointer;
        transition: border-color 0.15s ease;
    }

    .pd-thumb img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
    }

    .pd-thumb--video {
        position: relative;
    }

    .pd-thumb--video::after {
        content: "▶";
        position: absolute;
        inset: auto 0.45rem 0.45rem auto;
        width: 1.45rem;
        height: 1.45rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(36, 32, 33, 0.82);
        color: #fff;
        font-size: 0.62rem;
        line-height: 1;
    }

    .pd-thumb.is-active {
        border-color: var(--reviv-dark);
    }

    .pd-buybox .pd-proof-line {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.55rem;
        font-size: var(--fs-sm);
        font-weight: 800;
        color: var(--reviv-ink);
        margin-bottom: 0.9rem;
        text-decoration: none;
    }

    .pd-proof-line .pd-proof-text {
        text-decoration: underline;
        text-underline-offset: 0.22em;
        text-decoration-thickness: 1px;
    }

    .pd-stars {
        color: var(--reviv-gold-hover);
        letter-spacing: 0.04em;
    }

    .pd-buybox h1 {
        margin: 0;
        font-size: var(--fs-3xl);
        line-height: 1.06;
        letter-spacing: -0.045em;
        font-weight: 900;
        color: var(--reviv-ink);
    }

    .pd-subhead {
        margin: 0.9rem 0 0;
        color: var(--reviv-ink);
        font-size: var(--fs-lg);
        font-weight: 700;
        line-height: 1.45;
    }

    .pd-benefit-list {
        list-style: none;
        margin: 1.3rem 0 0;
        padding: 0;
        display: grid;
        gap: 0.5rem;
    }

    .pd-benefit-list li {
        display: flex;
        align-items: baseline;
        gap: 0.55rem;
        font-size: var(--fs-sm);
        color: var(--reviv-ink);
        font-weight: 500;
    }

    .pd-tick {
        flex: none;
        width: 1.25rem;
        height: 1.25rem;
        display: inline-grid;
        place-items: center;
        border-radius: 50%;
        background: rgba(224, 181, 128, 0.28);
        color: var(--reviv-dark);
        font-size: 0.72rem;
        font-weight: 900;
        transform: translateY(0.18rem);
    }

    .pd-divider {
        border: 0;
        border-top: 1px solid var(--reviv-border);
        margin: 1.5rem 0 0;
    }

    .pd-field {
        margin-top: 1.35rem;
    }

    .pd-field-label {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.45rem;
        font-size: var(--fs-lg);
        font-weight: 800;
        margin-bottom: 0.7rem;
    }

    .pd-field-value {
        font-weight: 500;
        color: var(--reviv-ink);
    }

    .pd-size-chart-btn {
        margin-left: auto;
        background: none;
        border: 0;
        padding: 0;
        cursor: pointer;
        font-size: var(--fs-sm);
        font-weight: 700;
        color: var(--reviv-gold-hover);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .pd-size-chart-btn:hover {
        color: var(--reviv-dark);
    }

    .pd-pill-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
    }

    .pd-pill {
        border: 1.5px solid var(--reviv-border);
        background: #fff;
        color: var(--reviv-ink);
        border-radius: 0.75rem;
        padding: 0.7rem 1.3rem;
        font-size: var(--fs-sm);
        font-weight: 700;
        cursor: pointer;
        transition:
            border-color 0.15s ease,
            background 0.15s ease;
    }

    .pd-pill small {
        display: block;
        font-size: var(--fs-xs);
        font-weight: 400;
        color: var(--reviv-muted);
    }

    .pd-pill.is-active {
        border-color: var(--reviv-dark);
        background: rgba(224, 181, 128, 0.22);
        color: var(--reviv-ink);
        box-shadow: 0 0 0 1px var(--reviv-dark);
    }

    .pd-pill.is-active small {
        color: var(--reviv-muted);
    }

    /* color cards (image swatches) */

    .pd-color-cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(7.5rem, 1fr));
        gap: 0.7rem;
        max-width: 24rem;
    }

    .pd-color-card {
        border: 1.5px solid var(--reviv-border);
        background: #fff;
        border-radius: 0.9rem;
        overflow: hidden;
        padding: 0;
        cursor: pointer;
        text-align: center;
        transition:
            border-color 0.15s ease,
            box-shadow 0.15s ease;
    }

    .pd-color-card img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        display: block;
    }

    .pd-color-card-label {
        display: block;
        padding: 0.55rem 0.5rem;
        font-size: var(--fs-sm);
        font-weight: 700;
        color: var(--reviv-ink);
        transition: background 0.15s ease;
    }

    .pd-color-card.is-active {
        border-color: var(--reviv-dark);
        box-shadow: 0 0 0 1px var(--reviv-dark);
    }

    .pd-color-card.is-active .pd-color-card-label {
        background: rgba(224, 181, 128, 0.3);
    }

    /* ---------- size chart modal ---------- */

    .pd-size-modal {
        position: fixed;
        inset: 0;
        z-index: 60;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background: rgba(23, 21, 21, 0.55);
        -webkit-backdrop-filter: blur(4px);
        backdrop-filter: blur(4px);
    }

    .pd-size-modal.is-open {
        display: flex;
    }

    .pd-size-modal__content {
        background: #fff;
        border-radius: 1.1rem;
        width: min(100%, 34rem);
        max-height: min(86vh, 46rem);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(23, 21, 21, 0.3);
    }

    .pd-size-modal__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.1rem 1.3rem;
        border-bottom: 1px solid var(--reviv-border);
    }

    .pd-size-modal__title {
        font-size: var(--fs-lg);
        font-weight: 900;
    }

    .pd-size-modal__close {
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 50%;
        border: 1px solid var(--reviv-border);
        background: #fff;
        color: var(--reviv-ink);
        font-size: 1.2rem;
        line-height: 1;
        display: grid;
        place-items: center;
        cursor: pointer;
    }

    .pd-size-modal__close:hover {
        background: var(--reviv-dark);
        color: #fff;
    }

    .pd-size-modal__body {
        padding: 1.3rem;
        overflow-y: auto;
        font-size: var(--fs-sm);
        color: var(--reviv-muted);
        line-height: 1.6;
    }

    .pd-size-modal__body h3 {
        margin: 1.4rem 0 0.6rem;
        font-size: var(--fs-base);
        font-weight: 900;
        color: var(--reviv-ink);
    }

    .pd-size-modal__body h3:first-child {
        margin-top: 0;
    }

    .pd-size-modal__body img {
        display: block;
        width: min(100%, 18rem);
        border-radius: 0.8rem;
        border: 1px solid var(--reviv-border);
        margin: 0.4rem 0 0.6rem;
    }

    .pd-size-modal__body ul {
        margin: 0 0 0.4rem;
        padding-left: 1.1rem;
        display: grid;
        gap: 0.3rem;
    }

    .pd-size-modal__body a {
        color: var(--reviv-gold-hover);
        font-weight: 700;
    }

    .pd-size-modal__table-wrap {
        overflow-x: auto;
        margin-top: 0.4rem;
    }

    .pd-size-modal__body table {
        border-collapse: collapse;
        width: 100%;
        min-width: 30rem;
        font-size: var(--fs-xs);
    }

    .pd-size-modal__body th,
    .pd-size-modal__body td {
        border: 1px solid var(--reviv-border);
        padding: 0.55rem 0.7rem;
        text-align: left;
    }

    .pd-size-modal__body th {
        background: var(--reviv-cream);
        color: var(--reviv-ink);
        font-weight: 800;
    }

    .pd-size-modal__footer {
        padding: 1rem 1.3rem;
        border-top: 1px solid var(--reviv-border);
        text-align: right;
    }

    .pd-size-modal__footer button {
        border: 1.5px solid var(--reviv-dark);
        background: #fff;
        color: var(--reviv-ink);
        border-radius: 0.75rem;
        padding: 0.6rem 1.4rem;
        font-size: var(--fs-sm);
        font-weight: 700;
        cursor: pointer;
    }

    .pd-size-modal__footer button:hover {
        background: var(--reviv-dark);
        color: #fff;
    }

    .pd-package {
        display: grid;
        gap: 0.7rem;
        margin-top: 0.1rem;
    }

    .pd-package-card {
        position: relative;
        text-align: left;
        width: 100%;
        border: 1.5px solid var(--reviv-border);
        background: #fff;
        border-radius: 1rem;
        padding: 1rem 1.1rem;
        cursor: pointer;
        transition:
            border-color 0.15s ease,
            box-shadow 0.15s ease;
    }

    .pd-package-card.is-active {
        border-color: var(--reviv-dark);
        box-shadow: 0 0 0 1.5px var(--reviv-dark);
    }

    .pd-package-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .pd-package-name {
        font-size: var(--fs-base);
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }

    .pd-radio {
        flex: none;
        width: 1.15rem;
        height: 1.15rem;
        border-radius: 50%;
        border: 2px solid rgba(35, 32, 33, 0.35);
        display: inline-grid;
        place-items: center;
    }

    .pd-package-card.is-active .pd-radio {
        border-color: var(--reviv-dark);
    }

    .pd-package-card.is-active .pd-radio::after {
        content: "";
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 50%;
        background: var(--reviv-dark);
    }

    .pd-package-price {
        font-size: var(--fs-lg);
        font-weight: 900;
        white-space: nowrap;
    }

    .pd-package-desc {
        margin: 0.5rem 0 0;
        padding-left: 1.7rem;
        font-size: var(--fs-sm);
        color: var(--reviv-muted);
        line-height: 1.5;
    }

    ul.pd-package-desc {
        list-style: disc;
        padding-left: 2.8rem;
        display: grid;
        gap: 0.3rem;
    }

    .pd-package-tag {
        display: inline-block;
        background: rgba(224, 181, 128, 0.3);
        color: var(--reviv-dark);
        font-size: var(--fs-xs);
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border-radius: 999px;
        padding: 0.2rem 0.6rem;
    }

    .pd-primary-btn,
    .pd-sticky-btn {
        border: 0;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        min-height: 3.65rem;
        border-radius: 999px;
        background: var(--reviv-cta);
        color: #111 !important;
        font-weight: 900;
        font-size: var(--fs-lg);
        line-height: 1;
        text-decoration: none !important;
        box-shadow: 0 0.85rem 1.8rem rgba(97, 67, 22, 0.2);
        transition:
            transform 0.18s ease,
            background 0.18s ease,
            box-shadow 0.18s ease;
    }

    .pd-primary-btn {
        width: 100%;
        padding: 0 1.45rem;
        margin-top: 1.4rem;
    }

    .pd-primary-btn:hover,
    .pd-sticky-btn:hover {
        background: var(--reviv-cta-hover);
        transform: translateY(-1px);
        box-shadow: 0 1rem 2rem rgba(97, 67, 22, 0.25);
    }

    .pd-trust-row {
        margin-top: 0.9rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.45rem 1.1rem;
        font-size: var(--fs-xs);
        color: var(--reviv-muted);
        font-weight: 500;
    }

    .pd-trust-row span::before {
        content: "✓ ";
        color: var(--reviv-gold-hover);
        font-weight: 900;
    }

    /* ---------- buybox trust icons ---------- */

    .pd-trust-icons {
        margin-top: 1.7rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        text-align: center;
    }

    .pd-trust-icon-circle {
        width: 3.1rem;
        height: 3.1rem;
        margin: 0 auto 0.55rem;
        border: 1.5px solid var(--reviv-dark);
        border-radius: 50%;
        display: grid;
        place-items: center;
        color: var(--reviv-dark);
    }

    .pd-trust-icons p {
        margin: 0;
        font-size: var(--fs-sm);
        font-weight: 600;
        color: var(--reviv-ink);
        line-height: 1.35;
    }

    /* ---------- buybox accordions ---------- */

    .pd-acc-list {
        margin-top: 1.9rem;
        border-top: 1px solid var(--reviv-border);
    }

    .pd-acc {
        border-bottom: 1px solid var(--reviv-border);
    }

    .pd-acc summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.15rem 0.15rem;
        font-size: var(--fs-lg);
        font-weight: 800;
        color: var(--reviv-ink);
    }

    .pd-acc summary::-webkit-details-marker {
        display: none;
    }

    .pd-acc-toggle {
        flex: none;
        font-size: 1.45em;
        font-weight: 400;
        line-height: 1;
        color: var(--reviv-ink);
    }

    .pd-acc-toggle::before {
        content: "+";
    }

    .pd-acc[open] .pd-acc-toggle::before {
        content: "–";
    }

    .pd-acc-body {
        padding: 0 0.15rem 1.2rem;
        font-size: var(--fs-sm);
        color: var(--reviv-muted);
        line-height: 1.6;
    }

    .pd-acc-body p {
        margin: 0 0 0.6rem;
    }

    .pd-acc-body ul {
        margin: 0 0 0.6rem;
        padding-left: 1.1rem;
    }

    .pd-acc-body li {
        margin-bottom: 0.3rem;
    }

    .pd-acc-body :last-child {
        margin-bottom: 0;
    }

    /* ---------- shared section shells ---------- */

    .pd-section {
        padding: clamp(3.25rem, 6.5vw, 5.5rem) 1.25rem;
    }

    .pd-section-inner {
        width: min(100%, 76rem);
        margin: 0 auto;
    }

    .pd-kicker {
        color: var(--reviv-gold-hover);
        font-size: var(--fs-xs);
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 900;
        margin-bottom: 0.7rem;
    }

    .pd-section h2 {
        margin: 0 0 1rem;
        font-size: var(--fs-3xl);
        line-height: 1.08;
        letter-spacing: -0.045em;
        font-weight: 900;
        color: var(--reviv-ink);
    }

    .pd-section-lead {
        max-width: 42rem;
        margin: 0;
        color: var(--reviv-muted);
        font-size: var(--fs-base);
        line-height: 1.6;
    }

    /* ---------- narrative splits (problem / solution) ---------- */

    .pd-section-head {
        text-align: center;
        margin-bottom: clamp(2.4rem, 5vw, 3.8rem);
    }

    .pd-section-head .pd-kicker {
        margin-bottom: 0.55rem;
    }

    .pd-section-head h2 {
        margin-bottom: 0;
        max-width: 48rem;
        margin-left: auto;
        margin-right: auto;
    }

    .pd-split {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: clamp(2rem, 5vw, 4.5rem);
        align-items: center;
    }

    .pd-split + .pd-split {
        margin-top: clamp(3rem, 6vw, 5rem);
    }

    .pd-split--flip .pd-split-media {
        order: 2;
    }

    .pd-split-media {
        border-radius: 1.1rem;
        overflow: hidden;
        background: #fff;
        border: 1px solid var(--reviv-border);
        box-shadow: 0 1.25rem 3rem rgba(0, 0, 0, 0.12);
    }

    .pd-split-media img,
    .pd-split-media video {
        width: 100%;
        height: auto;
        display: block;
    }

    .pd-split h3 {
        margin: 0 0 1.15rem;
        font-size: var(--fs-xl);
        font-weight: 900;
        letter-spacing: -0.03em;
        line-height: 1.18;
    }

    .pd-check-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.7rem;
    }

    .pd-check-list li {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        font-size: var(--fs-base);
        color: var(--reviv-muted);
        line-height: 1.5;
    }

    /* problem section (white band) */

    .pd-problem {
        background: #fff;
    }

    .pd-problem .pd-split-media {
        border-color: var(--reviv-border);
        box-shadow: 0 1.25rem 3rem rgba(0, 0, 0, 0.08);
    }

    /* ---------- three hypotheses ---------- */

    .pd-hypo-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.1rem;
    }

    .pd-hypo-card {
        background: #fff;
        border: 1px solid var(--reviv-border);
        border-radius: 1.1rem;
        overflow: hidden;
        text-align: center;
    }

    .pd-hypo-title {
        padding: 0.9rem 1rem;
        font-weight: 900;
        font-size: var(--fs-base);
        letter-spacing: -0.01em;
        color: var(--reviv-ink);
        background: rgba(224, 181, 128, 0.22);
    }

    .pd-hypo-card img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        display: block;
    }

    .pd-hypo-card p {
        margin: 0;
        padding: 1.05rem 1.2rem 1.25rem;
        font-size: var(--fs-sm);
        color: var(--reviv-muted);
        line-height: 1.5;
    }

    /* ---------- how to use ---------- */

    .pd-steps {
        margin-top: 2.4rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.1rem;
    }

    .pd-step {
        background: #fff;
        border: 1px solid var(--reviv-border);
        border-radius: 1.1rem;
        padding: 1.6rem 1.4rem;
    }

    .pd-step img {
        width: 100%;
        border-radius: 0.8rem;
        display: block;
        margin-bottom: 1.1rem;
    }

    .pd-step-num {
        display: inline-grid;
        place-items: center;
        width: 2.3rem;
        height: 2.3rem;
        border-radius: 50%;
        background: var(--reviv-dark);
        color: var(--reviv-cta);
        font-weight: 900;
        font-size: var(--fs-base);
        margin-bottom: 0.9rem;
    }

    .pd-step h3 {
        margin: 0 0 0.4rem;
        font-size: var(--fs-lg);
        font-weight: 900;
        letter-spacing: -0.02em;
    }

    .pd-step p {
        margin: 0;
        font-size: var(--fs-sm);
        color: var(--reviv-muted);
        line-height: 1.55;
    }

    /* ---------- expectations timeline ---------- */

    .pd-tl {
        max-width: 44rem;
        margin: 0 auto;
    }

    .pd-tl-item {
        display: grid;
        grid-template-columns: 10rem 3rem minmax(0, 1fr);
        grid-template-areas: "when spine body";
        align-items: start;
    }

    .pd-tl-when {
        grid-area: when;
        text-align: right;
        font-size: var(--fs-lg);
        font-weight: 900;
        letter-spacing: -0.015em;
        color: var(--reviv-ink);
        line-height: 1.3;
    }

    .pd-tl-spine {
        grid-area: spine;
        position: relative;
        align-self: stretch;
    }

    .pd-tl-spine::before {
        content: "";
        position: absolute;
        left: 50%;
        top: 0;
        bottom: 0;
        width: 1.5px;
        transform: translateX(-50%);
        background: var(--reviv-border);
    }

    .pd-tl-item:first-child .pd-tl-spine::before {
        top: 0.75rem;
    }

    .pd-tl-item:last-child .pd-tl-spine::before {
        background: linear-gradient(
            to bottom,
            var(--reviv-border) 25%,
            transparent
        );
    }

    .pd-tl-spine::after {
        content: "";
        position: absolute;
        left: 50%;
        top: 0.75rem;
        width: 0.72rem;
        height: 0.72rem;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        background: var(--reviv-gold);
        box-shadow: 0 0 0 4px var(--reviv-cream);
    }

    .pd-tl-item:last-child .pd-tl-spine::after {
        background: var(--reviv-cream);
        border: 2px solid var(--reviv-gold);
    }

    .pd-tl-body {
        grid-area: body;
        padding-bottom: clamp(2.1rem, 4vw, 3rem);
    }

    .pd-tl-item:last-child .pd-tl-body {
        padding-bottom: 0;
    }

    .pd-tl-body ul {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.55rem;
    }

    .pd-tl-body li {
        position: relative;
        padding-left: 1.05rem;
        font-size: var(--fs-base);
        color: var(--reviv-ink);
        line-height: 1.55;
    }

    .pd-tl-body li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.62em;
        width: 0.32rem;
        height: 0.32rem;
        border-radius: 50%;
        background: var(--reviv-gold);
    }

    @media (max-width: 720px) {
        .pd-tl-item {
            grid-template-columns: 2.25rem minmax(0, 1fr);
            grid-template-areas:
                "spine when"
                "spine body";
        }

        .pd-tl-when {
            text-align: left;
            margin-bottom: 0.55rem;
        }
    }

    /* ---------- learn more (blog cards) ---------- */

    .pd-learn-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.1rem;
    }

    .pd-learn-card {
        display: flex;
        flex-direction: column;
        background: #fff;
        border: 1px solid var(--reviv-border);
        border-radius: 1.1rem;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition:
            transform 0.18s ease,
            box-shadow 0.18s ease;
    }

    .pd-learn-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 1rem 2.4rem rgba(0, 0, 0, 0.1);
    }

    .pd-learn-card img {
        width: 100%;
        aspect-ratio: 16 / 10;
        object-fit: cover;
        display: block;
    }

    .pd-learn-body {
        padding: 1.25rem 1.3rem 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        flex: 1;
    }

    .pd-learn-body h3 {
        margin: 0;
        font-size: var(--fs-lg);
        font-weight: 900;
        letter-spacing: -0.02em;
    }

    .pd-learn-body p {
        margin: 0;
        font-size: var(--fs-sm);
        color: var(--reviv-muted);
        line-height: 1.55;
        flex: 1;
    }

    .pd-learn-more {
        font-size: var(--fs-sm);
        font-weight: 800;
        color: var(--reviv-gold-hover);
    }

    /* ---------- choose your mouthguard ---------- */

    .pd-choose-card {
        background: var(--reviv-gold);
        border-radius: 1.4rem;
        padding: clamp(1.5rem, 4vw, 3rem);
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
        gap: clamp(1.5rem, 4vw, 3rem);
        align-items: center;
    }

    .pd-choose-card img {
        width: 100%;
        border-radius: 1rem;
        display: block;
    }

    .pd-choose-card h2 {
        margin: 0 0 1.4rem;
        font-size: var(--fs-2xl);
    }

    .pd-choose-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3.3rem;
        padding: 0 1.6rem;
        border-radius: 999px;
        background: var(--reviv-dark);
        color: #fff !important;
        font-weight: 800;
        font-size: var(--fs-base);
        text-decoration: none !important;
        transition:
            transform 0.18s ease,
            background 0.18s ease;
    }

    .pd-choose-btn:hover {
        transform: translateY(-1px);
        background: var(--reviv-dark-alt);
    }

    /* ---------- testimonials ---------- */

    .pd-testimonials {
        background: #fff;
        text-align: center;
    }

    .pd-testimonials-top {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        color: var(--reviv-ink);
        margin-bottom: 1.4rem;
        font-size: var(--fs-sm);
        font-weight: 700;
    }

    .pd-testimonials-top .pd-stars {
        color: var(--reviv-gold-hover);
    }

    .pd-review-grid {
        margin: 2.4rem auto 0;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
        text-align: left;
    }

    .pd-review-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background: var(--reviv-cream);
        border: 1px solid var(--reviv-border);
        border-radius: 1rem;
        padding: clamp(1.5rem, 2.5vw, 2.1rem);
        color: var(--reviv-dark);
    }

    .pd-review-card h3 {
        margin: 0.9rem 0 0.8rem;
        font-size: var(--fs-lg);
        line-height: 1.2;
        font-weight: 900;
    }

    .pd-review-card p {
        margin: 0;
        color: rgba(35, 32, 33, 0.78);
        font-size: var(--fs-sm);
        line-height: 1.6;
    }

    .pd-review-author {
        margin-top: 1.6rem;
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 900;
        font-size: var(--fs-sm);
    }

    .pd-verified {
        width: 1.2rem;
        height: 1.2rem;
        display: inline-grid;
        place-items: center;
        border-radius: 50%;
        background: var(--reviv-gold);
        color: var(--reviv-dark);
        font-size: var(--fs-xs);
    }

    .pd-judgeme-reviews {
        background: #fff;
        color: var(--reviv-ink);
    }

    .pd-judgeme-shell {
        max-width: 75rem;
        margin: 0 auto;
    }

    .pd-judgeme-shell .jdgm-review-widget,
    .pd-judgeme-shell .jm-review-widget {
        --jm-review-widget-text-color: var(--reviv-ink);
        --jm-review-widget-lighter-text-color: var(--reviv-ink);
        --jm-review-widget-button-color: var(--reviv-cta);
        --jm-review-widget-button-text-color: var(--reviv-ink);
        --jm-review-widget-form-button-color: var(--reviv-cta);
        --jm-review-widget-star-and-histogram-color: var(--reviv-gold-hover);
        background: #fff !important;
        color: var(--reviv-ink) !important;
    }

    .pd-judgeme-shell .jm-review-widget {
        padding-block: 0 !important;
    }

    .pd-judgeme-shell .jdgm-rev-widg__header {
        background: #fff !important;
        border: 1px solid var(--reviv-border) !important;
        border-radius: 1.1rem !important;
        color: var(--reviv-ink) !important;
        padding: clamp(1.5rem, 3vw, 2rem) !important;
    }

    #reviv-pdp .pd-judgeme-shell .jdgm-star,
    #reviv-pdp .pd-judgeme-shell .jdgm-star::before,
    #reviv-pdp .pd-judgeme-shell .jdgm-star::after {
        font-family: "JudgemeStar" !important;
        font-style: normal !important;
        font-weight: normal !important;
        line-height: 1 !important;
        text-decoration: none !important;
    }

    .pd-judgeme-shell .jdgm-rev-widg__title,
    .pd-judgeme-shell .jm-review-widget-header__title,
    .pd-judgeme-shell [class*="review-widget-header__title"] {
        margin: 0 !important;
        color: var(--reviv-ink) !important;
        font-family: var(--font-heading) !important;
        font-size: var(--fs-3xl) !important;
        font-weight: 900 !important;
        letter-spacing: -0.045em !important;
        line-height: 1.08 !important;
    }

    .pd-judgeme-shell .jdgm-rev-widg__actions,
    .pd-judgeme-shell .jdgm-rev,
    .pd-judgeme-shell .jdgm-quest {
        background: #fff !important;
        border-color: var(--reviv-border) !important;
        color: var(--reviv-ink) !important;
    }

    .pd-judgeme-shell .jdgm-histogram__frequency,
    .pd-judgeme-shell .jdgm-rev__title,
    .pd-judgeme-shell .jdgm-rev__body,
    .pd-judgeme-shell .jdgm-rev__author,
    .pd-judgeme-shell .jdgm-rev__timestamp,
    .pd-judgeme-shell .jdgm-rev__reply,
    .pd-judgeme-shell .jdgm-form,
    .pd-judgeme-shell .jdgm-form label,
    .pd-judgeme-shell .jm-text,
    .pd-judgeme-shell [class*="review-content__body"] {
        color: var(--reviv-ink) !important;
    }

    .pd-judgeme-shell .jm-button--primary,
    .pd-judgeme-shell .jdgm-write-rev-link {
        border: 1.5px solid var(--reviv-cta) !important;
        border-radius: 999px !important;
        background: var(--reviv-cta) !important;
        color: var(--reviv-ink) !important;
        font-weight: 900 !important;
        min-height: 2.9rem !important;
        padding: 0.72rem 1.25rem !important;
        text-decoration: none !important;
        box-shadow: 0 0.55rem 1.2rem rgba(97, 67, 22, 0.16) !important;
    }

    .pd-judgeme-shell .jm-button--primary:hover,
    .pd-judgeme-shell .jdgm-write-rev-link:hover {
        background: var(--reviv-cta-hover) !important;
        border-color: var(--reviv-cta-hover) !important;
    }

    .pd-judgeme-shell .jm-button--secondary,
    .pd-judgeme-shell .jdgm-ask-question-btn,
    .pd-judgeme-shell .jdgm-paginate__load-more,
    .pd-judgeme-shell .jm-sort-filter__select,
    .pd-judgeme-shell [class*="filter__toggle"] {
        border: 1.5px solid var(--reviv-ink) !important;
        border-radius: 999px !important;
        background: #fff !important;
        color: var(--reviv-ink) !important;
        font-weight: 800 !important;
        text-decoration: none !important;
    }

    .pd-judgeme-shell .jm-button--secondary:hover,
    .pd-judgeme-shell .jdgm-ask-question-btn:hover,
    .pd-judgeme-shell .jdgm-paginate__load-more:hover,
    .pd-judgeme-shell .jm-sort-filter__select:hover,
    .pd-judgeme-shell [class*="filter__toggle"]:hover {
        background: var(--reviv-ink) !important;
        color: #fff !important;
    }

    #reviv-pdp .pd-judgeme-shell .jm-star-rating__font-icon {
       font-family: JudgemeStar, monospace !important;
       font-style: normal !important;
       font-weight: normal !important;
       line-height: 1 !important;
       text-decoration: none !important;
   }

    /* ---------- FAQ ---------- */

    .pd-faq-list {
        margin-top: 2.2rem;
