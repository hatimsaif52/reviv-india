    <script>
        (function () {
            /* ---- variant selection ---- */
            var PRODUCT_URL =
                "https://getreviv.com/products/r3-revivthree-without-support";
            var VARIANTS = {
                yellow: {
                    m: { only: "47596826886385", support: "47228190064881" },
                    l: { only: "47596826788081", support: "47225720930545" },
                    xl: { only: "47596826689777", support: "47225721127153" },
