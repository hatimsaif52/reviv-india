{% render 'reviv-base' %}
<div class="rv-scope" style="background:{{ section.settings.bg_color }}; font-family:'Mulish',sans-serif;">
  <header style="max-width:1240px; margin:0 auto; padding:22px 40px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid rgba(236,230,218,0.08);">
    <a href="{{ routes.root_url }}" style="display:flex; align-items:baseline; gap:10px; text-decoration:none;">
      <span style="display:flex; align-items:center; gap:10px; font-family:'Cormorant Garamond',serif; font-size:28px; font-weight:600; letter-spacing:0.22em; color:#ECE6DA;">
        <svg width="26" height="15" viewBox="0 0 26 15" fill="none" style="margin-bottom:2px;"><path d="M2 13 A11 11 0 0 1 24 13" stroke="#ECE6DA" stroke-width="2" stroke-linecap="round"></path></svg>{{ section.settings.logo_text }}
      </span>
      <span style="font-family:'Mulish',sans-serif; font-size:12px; font-weight:800; letter-spacing:0.28em;"><span style="color:#EF9A2E;">IN</span><span style="color:#ECE6DA;">D</span><span style="color:#37A76A;">IA</span></span>
    </a>
    <nav class="rv-nav" style="display:flex; align-items:center; gap:34px; font-size:14.5px;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' -%}
          <a href="{{ block.settings.url }}" {{ block.shopify_attributes }} style="text-decoration:none; display:flex; align-items:center; gap:5px; {% if block.settings.active %}color:#ECE6DA; font-weight:700;{% else %}color:#B5AFA4;{% endif %}">
            {{ block.settings.label }}{% if block.settings.caret %}<span style="font-size:10px; color:#EF9A2E;">▾</span>{% endif %}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>
    <div style="display:flex; align-items:center; gap:20px; color:#B5AFA4;">
      <a href="{{ routes.search_url }}" style="color:#B5AFA4; display:flex;"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg></a>
      <a href="{{ routes.account_url }}" style="color:#B5AFA4; display:flex;"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg></a>
      <a href="{{ routes.cart_url }}" style="position:relative; color:#B5AFA4; display:flex;">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="4" y="7" width="16" height="14" rx="2"></rect><path d="M8 7a4 4 0 0 1 8 0"></path></svg>
        <span style="position:absolute; top:-8px; right:-9px; min-width:16px; height:16px; padding:0 4px; border-radius:8px; background:#EF9A2E; color:#161206; font-size:10px; font-weight:800; display:flex; align-items:center; justify-content:center;">{{ cart.item_count }}</span>
      </a>
    </div>
  </header>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "REVIV" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0A0A0B" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Home" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "checkbox", "id": "caret", "label": "Show dropdown caret", "default": false },
        { "type": "checkbox", "id": "active", "label": "Highlight as current", "default": false }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "Header",
    "blocks": [
      { "type": "link", "settings": { "label": "Home", "active": true } },
      { "type": "link", "settings": { "label": "Mouthguards", "caret": true } },
      { "type": "link", "settings": { "label": "Wellness", "caret": true } },
      { "type": "link", "settings": { "label": "eBooks" } }
    ]
  }]
}
{% endschema %}
