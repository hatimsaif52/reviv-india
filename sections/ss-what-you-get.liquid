{% schema %}
{
  "name": "SS What You Get",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Top Label",
      "default": "What you get"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for creative partnerships."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (emoji or text)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Performance bonus per video"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Up to $300 per video based on performance."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SS What You Get",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}

<section class="what-you-get">
  <div class="what-container">

    <!-- Header -->
    <div class="what-header">
      <p class="what-badge">{{ section.settings.badge }}</p>
      <h2 class="what-heading">{{ section.settings.heading }}</h2>
    </div>

    <!-- Grid -->
    <div class="what-grid">
      {% for block in section.blocks %}
        <div class="what-card">

          <div class="what-icon">
            <img src="{{ block.settings.icon | img_url }}" />
          </div>

          <h3 class="what-title">
            {{ block.settings.title }}
          </h3>

          <p class="what-desc">
            {{ block.settings.description }}
          </p>

        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
.what-you-get {
  background: #FFFAF0;
  padding: 100px 20px;
}

.what-container {
  max-width: 1200px;
  margin: 0 auto;
}

/* Header */
.what-header {
  margin-bottom: 50px;
}

.what-badge {
  color: #CB9676;
  font-size: 24px;
  margin-bottom: 10px;
}

.what-heading {
    font-size: 72px;
    line-height: 1.11;
    font-weight: 500;
    max-width: 600px;
    margin: 0 0 0;
}

/* Grid */
.what-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 25px;
}

/* Card */
.what-card {
  background: #FFFFFF;
  border: 1px solid #B3B3B3;
  border-radius: 20px;
  padding: 30px;
}

/* Icon */
.what-icon {
    img{
        width:40px;
    }
}

/* Title */
.what-title {
  font-size: 19px;
  font-family:inherit !important;
  margin-bottom: 10px;
}

/* Desc */
.what-desc {
  font-size: 14px;
  color: #555;
  line-height: 1.6;
}

/* Responsive */
@media (max-width: 768px) {
  .what-grid {
    grid-template-columns: 1fr;
  }

  .what-heading {
    font-size: 34px;
  }
}
</style>