{% render 'reviv-base' %}
<div class="rv-scope" style="background:#0A0A0B; font-family:'Mulish',sans-serif;">
  <section class="rv-mg-grid" style="max-width:1240px; margin:0 auto; padding:60px 40px; display:grid; grid-template-columns:0.85fr 1.4fr; gap:50px; align-items:start;">
    <div>
      <h2 style="font-family:'Cormorant Garamond',serif; font-weight:600; font-size:42px; color:#EF9A2E; margin:0 0 22px;">{{ section.settings.heading }}</h2>
      <p style="font-size:16px; line-height:1.65; color:#B5AFA4; margin:0 0 30px;">{{ section.settings.intro }}</p>
      <a href="{{ section.settings.button_url }}" class="rv-shop-btn" style="display:inline-block; background:transparent; border:1px solid rgba(55,167,106,0.7); color:#37A76A; text-decoration:none; font-weight:800; letter-spacing:0.14em; font-size:12.5px; padding:15px 34px; border-radius:6px;">{{ section.settings.button_label }}</a>
    </div>
    <div class="rv-mg-scroll" style="border:1px solid rgba(236,230,218,0.08); border-radius:14px; overflow:hidden;">
      <div class="rv-mg-table" style="display:grid; grid-template-columns:1.3fr 1fr 1fr 1fr;">
        <div style="padding:26px 18px;">&nbsp;</div>
        <div style="padding:26px 14px; text-align:center;">
          <div style="font-family:'Cormorant Garamond',serif; font-size:23px; color:#ECE6DA;">{{ section.settings.col1_name }}</div>
          <div style="font-size:10px; letter-spacing:0.1em; color:#E8A33C; font-weight:800; margin-top:4px;">{{ section.settings.col1_sub }}</div>
        </div>
        <div style="padding:26px 14px; text-align:center;">
          <div style="font-family:'Cormorant Garamond',serif; font-size:23px; color:#ECE6DA;">{{ section.settings.col2_name }}</div>
          <div style="font-size:10px; letter-spacing:0.1em; color:#E8A33C; font-weight:800; margin-top:4px;">{{ section.settings.col2_sub }}</div>
        </div>
        <div style="padding:20px 14px 26px; text-align:center; background:rgba(232,163,60,0.08); border-top:2px solid #E8A33C;">
          {% if section.settings.col3_badge != blank %}<div style="display:inline-block; background:#E8A33C; color:#161206; font-size:10px; font-weight:800; letter-spacing:0.08em; padding:4px 10px; border-radius:12px; margin-bottom:8px;">{{ section.settings.col3_badge }}</div>{% endif %}
          <div style="font-family:'Cormorant Garamond',serif; font-size:23px; color:#E8A33C;">{{ section.settings.col3_name }}</div>
          <div style="font-size:10px; letter-spacing:0.1em; color:#E8A33C; font-weight:800; margin-top:4px;">{{ section.settings.col3_sub }}</div>
        </div>
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }} style="padding:20px 18px; font-size:13.5px; color:#9a948b; border-top:1px solid rgba(236,230,218,0.06);">{{ block.settings.label }}</div>
          <div style="padding:20px 14px; font-size:14px; font-weight:700; color:#ECE6DA; text-align:center; border-top:1px solid rgba(236,230,218,0.06);">{{ block.settings.one }}</div>
          <div style="padding:20px 14px; font-size:14px; font-weight:700; color:#ECE6DA; text-align:center; border-top:1px solid rgba(236,230,218,0.06);">{{ block.settings.two }}</div>
          <div style="padding:20px 14px; font-size:14px; font-weight:700; color:#ECE6DA; text-align:center; background:rgba(232,163,60,0.08); border-top:1px solid rgba(232,163,60,0.15);">{{ block.settings.three }}</div>
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Mouthguards table",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Mouthguards" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Each Reviv mouthguard is crafted with precision using soft premium silicone, designed to cushion your teeth and reduce the effects of nighttime grinding and clenching. Whether you're an athlete, a grinder, or someone who wakes up with jaw discomfort, this is a great appliance for you." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "SHOP NOW" },
    { "type": "url", "id": "button_url", "label": "Button link" },
    { "type": "header", "content": "Column 1" },
    { "type": "text", "id": "col1_name", "label": "Name", "default": "REVIV ONE" },
    { "type": "text", "id": "col1_sub", "label": "Subtitle", "default": "1 YEAR SUPPORT" },
    { "type": "header", "content": "Column 2" },
    { "type": "text", "id": "col2_name", "label": "Name", "default": "REVIV TWO" },
    { "type": "text", "id": "col2_sub", "label": "Subtitle", "default": "1 YEAR SUPPORT" },
    { "type": "header", "content": "Column 3 (highlighted)" },
    { "type": "text", "id": "col3_badge", "label": "Badge", "default": "★ BEST SELLER" },
    { "type": "text", "id": "col3_name", "label": "Name", "default": "REVIV THREE" },
    { "type": "text", "id": "col3_sub", "label": "Subtitle", "default": "1 YEAR SUPPORT" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "one", "label": "Reviv One" },
        { "type": "text", "id": "two", "label": "Reviv Two" },
        { "type": "text", "id": "three", "label": "Reviv Three" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Mouthguards table",
    "blocks": [
      { "type": "row", "settings": { "label": "Price", "one": "₹9,490", "two": "₹14,490", "three": "₹18,990" } },
      { "type": "row", "settings": { "label": "Durability", "one": "2–4 months", "two": "1 year", "three": "1 year" } },
      { "type": "row", "settings": { "label": "Colour", "one": "Blue, Clear", "two": "Yellow, White", "three": "Yellow, White" } },
      { "type": "row", "settings": { "label": "Aggressiveness on Gums", "one": "Medium", "two": "Low", "three": "Much lower" } },
      { "type": "row", "settings": { "label": "Air Holes", "one": "Large", "two": "Small (hard to mouthbreathe)", "three": "Yes (good for saliva flow)" } },
      { "type": "row", "settings": { "label": "Sizes", "one": "Large, Small", "two": "Medium, Large", "three": "Medium, Large, Extra Large" } },
      { "type": "row", "settings": { "label": "Guarantee", "one": "None", "two": "1 yr warranty (1 free replacement)", "three": "1 yr warranty (1 free replacement)" } },
      { "type": "row", "settings": { "label": "Good for Grinders?", "one": "No", "two": "Yes", "three": "Yes" } }
    ]
  }]
}
{% endschema %}
