{%- style -%}
  .section-{{ section.id }} {
    background: #232021;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .customer-reviews-header__subtitle {
    font-size: 24px;
    line-height: 1.5;
    color: #FFFFFF99;
    font-weight: 500;
    text-align: center;
    font-family: "Roboto";
    margin-bottom: 24px;
  }

  .customer-reviews-header__subtitle b {
    color: #FFFFFFCC;
  }

  .customer-reviews-header__title {
    font-size: 48px;
    line-height: 1.5;
    color: #efc98b;
    font-weight: 500;
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 64px;
    font-family: "Cardillac";
  }

  @media (max-width: 600px) {
    .customer-reviews-header__subtitle {
      color: #FFFFFFCC;
      font-size: 16px;
      line-height: 20px;
    }

    .customer-reviews-header__title {
      font-size: 32px;
      line-height: 1;
    }
  }

  .customer-review-cards-desktop-wrapper {
    display: block;
  }

  .customer-review-cards-mobile-wrapper {
    display: none;
  }

  .customer-review-cards-mobile {
    overflow-x: auto;
    scrollbar-width: none; /* Hide scrollbar for WebKit browsers */
  }

  @media (max-width: 600px) {
    .customer-review-cards-desktop-wrapper {
      display: none;
    }

    .customer-review-cards-mobile-wrapper {
      overflow: hidden;
      width: 100%;
      display: block;
    }

    .customer-review-cards-mobile .first-row,
    .customer-review-cards-mobile .second-row
     {
      display: flex;
      width: max-content;
      /* animation: scrollRight 20s linear infinite; */
    }

    .customer-review-cards-mobile .first-row .customer-review-card,
    .customer-review-cards-mobile .second-row .customer-review-card
     {
      flex-shrink: 0;
    }

    .customer-review-cards-mobile .customer-review-card-image {
      max-width: 100%;
      width: auto;
    }

    @keyframes scrollRight {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%); /* Move exactly half the container width */
      }
    }
  }

  .customer-review-cards-desktop-wrapper .customer-review-card-image {
    max-width: 100%;
  }

  .customer-review-cards-desktop-wrapper .customer-review-card:nth-child(even) {
    display: flex;
    justify-content: right;
  }

  .customer-review-cards-mobile-wrapper img {
    width: 100%;
    border-radius: 10px;
    margin-top: 20px;
  }

  .customer-review-cards-mobile .first-row {
    display: flex;
  }

  .customer-review-cards-mobile .second-row {
    display: flex;

  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

