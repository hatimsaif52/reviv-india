    opacity: 0.9;
    margin-top: 40px;
}

/* Ադապտիվություն (Mobile) */
@media (max-width: 480px) {
    .info-section .main-title {
        font-size: 32px;
    }
    .info-section {
        padding: 40px 15px;
    }
}
