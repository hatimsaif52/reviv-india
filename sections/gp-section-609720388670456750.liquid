}

.info-section .container {
    max-width: 600px;
    margin-left: 35px; /* Սա կկենտրոնացնի բլոկը հորիզոնական */
    text-align: left;
}


/* Վերնագրի ոճը */
.info-section .main-title {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 25px;
    text-transform: none; /* Որպեսզի բրաուզերը չփոխի տառերի մեծատառ/փոքրատառը */
}

.features-list-li{
    font-size: 15px;
}

.info-section .main-title span {
    color: #d4b483; 
    display: block; /* Որպեսզի "Imagining It"-ը միշտ լինի նոր տողից */
}

/* Ենթավերնագիր */
.info-section .subtitle {
    font-size: 20px;
    margin-bottom: 30px;
    color: #e0e0e0;
    line-height: 1.4;
}

/* Ցուցակի ոճավորում */
.info-section .features-list {
    list-style: none;
    margin-bottom: 0;
    padding: 0;
}


.info-section .features-list li {

     padding: 8px 8px 9px 17px;
    border-top: 1px solid #333;
    font-size: 14px;
    position: relative;
}

.info-section .features-list li::before {
    content: "•";
    color: #d4b483;
    position: absolute;
    left: 0;
    font-size: 24px;
    top: 0px;
}

/* Ներքևի տեքստը */
.info-section .bottom-text p {
