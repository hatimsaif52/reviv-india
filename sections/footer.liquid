{% render 'reviv-base' %}
<div class="rv-scope" style="font-family:'Mulish',sans-serif;">
  <footer style="position:relative;">
    <div style="display:flex; height:5px;">
      <span style="flex:1; background:#EF9A2E;"></span>
      <span style="flex:1; background:#F3EEE4;"></span>
      <span style="flex:1; background:#37A76A;"></span>
    </div>
    <div style="background:{{ section.settings.bg_color }}; color:#20180A; padding:56px 40px 30px;">
      <div class="rv-3col" style="max-width:1240px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr 1fr; gap:30px;">
        {%- assign col_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'column' -%}
            {%- assign col_index = col_index | plus: 1 -%}
            <div {{ block.shopify_attributes }}>
              <div style="font-size:12px; font-weight:800; letter-spacing:0.2em; margin-bottom:22px;">{{ block.settings.heading }}</div>
              <div style="display:flex; flex-direction:column; gap:14px; font-size:15px;">
                {%- assign links = block.settings.links | newline_to_br | split: '<br />' -%}
                {%- for link in links -%}<span>{{ link | strip }}</span>{%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
        <div style="text-align:right;">
          <div style="display:flex; align-items:center; justify-content:flex-end; gap:12px; font-family:'Cormorant Garamond',serif; font-size:34px; font-weight:600; letter-spacing:0.16em;">
            <svg width="30" height="17" viewBox="0 0 26 15" fill="none" style="margin-bottom:3px;"><path d="M2 13 A11 11 0 0 1 24 13" stroke="#20180A" stroke-width="2.2" stroke-linecap="round"></path></svg>{{ section.settings.logo_text }}
          </div>
          <div style="font-size:13px; letter-spacing:0.14em; font-weight:700; margin-top:10px;">{{ section.settings.tagline }}</div>
          <div style="display:flex; gap:16px; justify-content:flex-end; margin-top:18px; color:#20180A;">
            {% if section.settings.facebook_url != blank %}<a href="{{ section.settings.facebook_url }}" style="color:#20180A; display:flex;"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-8h2.7l.4-3.1H13V8.9c0-.9.25-1.5 1.5-1.5H16V4.6C15.7 4.6 14.7 4.5 13.6 4.5c-2.3 0-3.9 1.4-3.9 4v2.4H7v3.1h2.7V22z"></path></svg></a>{% endif %}
            {% if section.settings.instagram_url != blank %}<a href="{{ section.settings.instagram_url }}" style="color:#20180A; display:flex;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle></svg></a>{% endif %}
          </div>
        </div>
      </div>
      <div style="max-width:1240px; margin:34px auto 0; border-top:1px solid rgba(32,24,10,0.2); padding-top:20px; text-align:center; font-size:13px; color:#3a2e18;">{{ section.settings.copyright }}</div>
    </div>
  </footer>
</div>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#E8A33C" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "REVIV" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "भारत के लिए · MADE FOR INDIA" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026, EBK Inc. All rights reserved. · Prices inclusive of GST." }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "LINKS" },
        { "type": "textarea", "id": "links", "label": "Links (one per line)", "default": "Reviv vs Competitor\neBooks\nTrack Your Order" }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [{
    "name": "Footer",
    "blocks": [
      { "type": "column", "settings": { "heading": "LINKS", "links": "Reviv vs Competitor\neBooks\nTrack Your Order" } },
      { "type": "column", "settings": { "heading": "CUSTOMER CARE", "links": "Contact Us\nReturn & Refund policy\nCash on Delivery · GST Invoice" } }
    ]
  }]
}
{% endschema %}
