{% schema %}
{
  "name": "Three Steps Section",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Top Label",
      "default": "How it works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Three steps from video to payout"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Right Description",
      "default": "No complex onboarding. Create your content, sign the licensing agreement, and collect your performance bonuses."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number",
          "default": "01 —"
        },
        {
        "type": "image_picker",
        "id": "icon",
        "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Make a video"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "(or use one you already made)"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Create a TikTok featuring your product."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Three Steps Section",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}

<section class="steps-section" id="tiktok-how-it-works">
  <div class="steps-container">

    <!-- Top -->
    <div class="steps-header">
      <div class="steps-left">
        <p class="steps-badge">{{ section.settings.badge }}</p>
        <h2 class="steps-heading">
          {{ section.settings.heading }}
        </h2>
      </div>

      <div class="steps-right">
        <p>{{ section.settings.description }}</p>
      </div>
    </div>

    <!-- Cards -->
    <div class="steps-grid">
      {% for block in section.blocks %}
        <div class="step-card">
          <div class="step-number">
            {{ block.settings.step_number }}
          </div>

          <div class="step-icon">
            <!-- simple placeholder icon -->
            <img src="{{ block.settings.icon | img_url }}" />
          </div>

          <h3 class="step-title">
            {{ block.settings.title }}
          </h3>

          {% if block.settings.subtitle != blank %}
            <p class="step-subtitle">
              {{ block.settings.subtitle }}
            </p>
          {% endif %}

          <p class="step-text">
            {{ block.settings.text }}
          </p>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
.steps-section {
  background: linear-gradient(180deg, #FFFFFF 59.71%, #FFFCE0 100%);

  padding: 100px 20px;
}

.steps-container {
  max-width: 1200px;
  margin: 0 auto;
}

.steps-header {
  display: flex;
  justify-content: space-between;
  gap: 40px;
    align-items: flex-end;
  margin-bottom: 50px;
  flex-wrap: wrap;
}

.steps-left {
  max-width: 500px;
}

.steps-badge {
  color: #c58a5c;
  font-size: 24px;
  margin-bottom: 10px;
}

.steps-heading {
  font-size: 72px;
  line-height: 1.1;
  font-weight: 500;
  margin:20px 0;
}

.steps-right {
 max-width: 400px;
    color: #555;
    font-size: 19px;
    line-height: 1.3;
}

/* Cards */
.steps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #B3B3B3;
}

.step-card {
  padding: 30px;
  background: #fff;
  border-right: 1px solid #B3B3B3;
}
.step-card:nth-child(2){ background:#FDFBF7}
.step-card:last-child {
  border-right: none;
}

.step-number {
  font-size: 18px;
  margin-bottom: 20px;
  color: #333;
}

.step-icon img {
    width: 50px;
}

.step-title {
    font-size: 24px;
    font-family: inherit !important;
    letter-spacing: 0px;
    margin: 8px 0 0;
}

.step-subtitle {
    font-size: 12px;
    color: #777;
    margin: 5px 0 0;
}

.step-text {
    font-size: 14px;
    color: #555;
    margin: 10px 0 0;
    line-height: 1.5;
}

/* Responsive */
@media (max-width: 900px) {
  .steps-grid {
    grid-template-columns: 1fr;
  }

  .step-card {
    border-right: none;
    border-bottom: 1px solid #ddd;
  }

  .step-card:last-child {
    border-bottom: none;
  }

  .steps-heading {
    font-size: 34px;
  }
}
</style>