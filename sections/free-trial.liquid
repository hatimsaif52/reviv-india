<script>
//for sticky free trial section
document.addEventListener("DOMContentLoaded", function () {
  const freeTrialSection = document.querySelector(".free-trail-sec");
  const heroBanner = document.querySelector(".sk-main-banner");

  if (!freeTrialSection || !heroBanner) return;

  const heroBottom = () => heroBanner.getBoundingClientRect().bottom + window.scrollY;

  window.addEventListener("scroll", function () {
    const scrollY = window.scrollY;

    if (scrollY > heroBottom()) {
      freeTrialSection.classList.add("fixed");
    } else {
      freeTrialSection.classList.remove("fixed");
    }
  });
});
</script>

<div id="appointment-popup" class="popup">
  <div class="popup-content">
    <span class="close-btn" id="close-btn">&times;</span>
    {% render 'popup-email-form' %}
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var popup = document.getElementById('appointment-popup');
    var openBtns = document.querySelectorAll('.form-popup-btn'); // Select all buttons with class
    var closeBtn = document.getElementById('close-btn');
    var formWrapper = document.getElementById('form-wrapper');

    // Show popup when clicking any button with class "form-popup-btn"
    openBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (popup) {
          popup.style.display = 'flex';
        }
      });
    });

    // Close popup when clicking the close button
    closeBtn?.addEventListener('click', function () {
      if (popup) {
        popup.style.display = 'none';
      }
    });

    // Check if the URL contains "contact_posted=true#"
    if (window.location.href.includes('contact_posted=true#')) {
      if (formWrapper) {
        formWrapper.style.display = 'none'; // Hide form
      }
      openBtns[0]?.click(); // Trigger click on the first button with class "form-popup-btn"
    }
  });

</script>
