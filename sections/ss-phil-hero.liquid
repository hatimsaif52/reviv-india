{% style %}
.c-hero {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: radial-gradient(circle at 20% 30%, rgba(255,180,120,0.15), transparent 40%),
              radial-gradient(circle at 80% 70%, rgba(255,180,120,0.1), transparent 40%),
              #0f0f10;
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.c-hero__wrap {
  display: flex;
  align-items: center;
  gap: 40px;
}

.c-hero.reverse .c-hero__wrap {
  flex-direction: row-reverse;
}

/* LEFT CONTENT */
.c-hero__content {
  flex: 1;
  color: #fff;
}

.c-hero__tag {
display: inline-block;
    font-size: 12px;
    padding: 4px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.08);
    vertical-align: sub;
}

.c-hero__heading {
    font-size: 48px;
    line-height: 1;
    font-weight: 600;
    margin: 20px 0;
    font-family: "Roboto" !important;

}

.c-hero__heading span {
display: block;
background: linear-gradient(90deg, #e5c085, #e5c085, #ffffff);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
}

.c-hero__text {
    margin-top: 16px;
    opacity: 0.7;
    max-width: 480px;
    line-height: 1.4;
}

.c-hero__btn {
    margin-top: 32px;
    display: inline-block;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 500;
    text-decoration: none;
    transition: 0.3s ease;
}
.c-hero__btn svg{
    vertical-align: middle;
    width: 18px;
    height: 18px;
}

.c-hero__btn:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

/* RIGHT IMAGE */
.c-hero__media {
    flex: 1;
    position: relative;
    background: #00000014;
    border-radius: 12px;
    box-shadow: 3px 5px 10px 2px rgb(27 25 25);
}

.c-hero__img {
  width: 100%;
  border-radius: 16px;
}

/* MIC BADGE */
.c-hero__badge {
    position: absolute;
    bottom: 30px;
    transform: translateX(-50%);
    left: 50%;
    background: rgb(26 26 26 / 72%);
    padding: 12px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 90%;
    color: #fff;
    line-height: 1.4;
    transition: 0.3s ease;
}
.c-hero__badge small {
    color: #b2b2b2;
}

.c-hero__badge-icon {
width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #ffb46e33;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
}

.c-hero__media:hover .c-hero__badge {
  transform: translate(-50%, -3px);
}

