{{ 'component-image-with-text-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .search-box-wrapper {
    display: flex;
    height: 56px;
    gap: 12px;
    padding: 0px 2px;
  }

  .search-box__input {
    width: 500px;
    padding-left: 20px;
    font-size: 18px;
    border: 2px solid grey;
  }

  .search-box__input:focus {
    outline: none;
    box-shadow: 0 0 0 2px #efc98b;
  }

  .search-box__button {
    padding: 16px 22px;
    display: flex;
    gap: 8px;
    align-items: center;
    border-radius: 4px;
    background-color: #efc98b;
    cursor: pointer;
    border: none;
  }

  /* Container for all blocks */
  .image-with-text-list {
    display: flex;
    flex-direction: column;
    gap: 60px;
    margin-top: 80px;
  }

  /* Hidden by default — JS will toggle this when search filters */
  .image-with-text-list__item[data-hidden='true'] {
    display: none;
  }

  .image-with-text__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    color: #222021;
  }

  .image-with-text__heading {
    font-size: 40px;
    line-height: 1.125;
    font-weight: 500;
  }

  .image-with-text__author {
    font-size: 28px;
    line-height: 1.25;
    font-weight: 600;
    margin-top: 20px;
    font-style: italic;
  }

  .image-with-text__description {
    font-size: 20px;
    line-height: 1.5;
    margin-top: 40px;
  }

  .image-with-text__button {
    background-color: #efc98b;
    padding: 16px 22px;
    color: black;
    display: inline-block;
    margin-top: 20px;
    border-radius: 4px;
    text-decoration: none;
    cursor: pointer;
  }

  .image-with-text__media-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* No-results message */
  .image-with-text-list__no-results {
    display: none;
    font-size: 20px;
    color: #666;
    padding: 40px 0;
    text-align: center;
  }

  .image-with-text-list__no-results[data-visible='true'] {
    display: block;
  }

  /* Mobile styles */
  @media screen and (max-width: 650px) {
    .image-with-text__content {
      grid-template-columns: 1fr;
    }

    .image-with-text__text-container {
      order: 2;
    }

    .search-box__button-text {
      display: none;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }} gradient">
  <div class="page-width">

    {%- comment -%} Search box {%- endcomment -%}
    <div class="search-box-wrapper">
      <input
        type="text"
        id="image-with-text-search"
        class="search-box__input"
        placeholder="Look for title, author, etc."
        aria-label="Search"
      >
      <button class="search-box__button" id="image-with-text-search-btn" type="button">
        {{- 'search-md.svg' | inline_asset_content -}}
        <span class="search-box__button-text">Search</span>
      </button>
    </div>

    {%- comment -%} All blocks listed without pagination {%- endcomment -%}
    <div class="image-with-text-list" id="image-with-text-list">

      {% for block in section.blocks %}
        <div
          class="image-with-text-list__item"
          {{ block.shopify_attributes }}
          data-heading="{{ block.settings.heading | downcase | escape }}"
          data-author="{{ block.settings.author | downcase | escape }}"
        >
          <div class="image-with-text__content">

            <div class="image-with-text__text-container">
              {%- if block.settings.heading != blank -%}
                <div class="image-with-text__heading">{{ block.settings.heading | upcase }}</div>
              {%- endif -%}
              {%- if block.settings.author != blank -%}
                <div class="image-with-text__author">{{ block.settings.author }}</div>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <div class="image-with-text__description">{{ block.settings.description }}</div>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <a
                  {% if block.settings.button_link %}href="{{ block.settings.button_link }}"{% endif %}
                  class="image-with-text__button"
                >
                  {{ block.settings.button_label | escape }}
                </a>
              {%- endif -%}
            </div>

            <div class="image-with-text__media-container">
              {%- if block.settings.image != blank -%}
                <div class="image-with-text__media">
                  {{
                    block.settings.image
                    | image_url: width: 1500
                    | image_tag:
                      loading: 'lazy',
                      class: 'image-with-text__image',
                      sizes: '(min-width: 750px) 50vw, 100vw',
                      widths: '375, 550, 750, 1100, 1500'
                  }}
                </div>
              {%- else -%}
                <div class="image-with-text__media image-with-text__media--placeholder">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>

          </div>
        </div>
      {% endfor %}

      <p class="image-with-text-list__no-results" id="image-with-text-no-results">
        No results found.
      </p>

    </div>
  </div>
</div>

<script>
  (function () {
    const input      = document.getElementById('image-with-text-search');
    const btn        = document.getElementById('image-with-text-search-btn');
    const items      = document.querySelectorAll('.image-with-text-list__item');
    const noResults  = document.getElementById('image-with-text-no-results');

    function runSearch() {
      const query = input.value.trim().toLowerCase();
      let visibleCount = 0;

      items.forEach(function (item) {
        const heading = item.dataset.heading || '';
        const author  = item.dataset.author  || '';
        const matches = !query || heading.includes(query) || author.includes(query);

        item.dataset.hidden = matches ? 'false' : 'true';
        if (matches) visibleCount++;
      });

      noResults.dataset.visible = visibleCount === 0 ? 'true' : 'false';
    }

    // Search on button click
    btn.addEventListener('click', runSearch);

    // Search on Enter key
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') runSearch();
    });

    // Live search as you type (debounced)
    let debounceTimer;
    input.addEventListener('input', function () {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(runSearch, 250);
    });
  })();
</script>

{% schema %}
{
  "name": "Image With Text List",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Image with text",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "default": "Heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Ken Leaver",
          "label": "Author"
        },
        {
          "type": "richtext",
          "id": "description",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Button label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image With Text List",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}