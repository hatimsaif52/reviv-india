<section class="reviv-cta">
  <div class="reviv-cta__container">
    
    <div class="reviv-cta__box">
      
      <h2 class="reviv-cta__heading">
        {{ section.settings.heading }}
      </h2>

      <p class="reviv-cta__subtext">
        {{ section.settings.subtext }}
      </p>

      <a href="{{ section.settings.button_link }}" class="reviv-cta__button">
        {{ section.settings.button_text }} →
      </a>

      <p class="reviv-cta__note">
        {{ section.settings.note }}
      </p>

    </div>

  </div>
</section>

<style>
.reviv-cta {
  padding: 80px 20px;
  background: #FFFAF0;
}

.reviv-cta__container {
  max-width: 900px;
  margin: 0 auto;
}

.reviv-cta__box {
  background: #fff;
  border-radius: 20px;
  text-align: center;
  padding: 60px 30px;
}

.reviv-cta__heading {
  font-size: 42px;
  line-height: 1.2;
  margin-bottom: 10px;
  color: #3b2415;
  font-weight: 600;
}

.reviv-cta__subtext {
  font-size: 16px;
  color: #6b6b6b;
  margin-bottom: 30px;
}

.reviv-cta__button {
  display: inline-block;
  padding: 10px 28px;
  background: linear-gradient(90deg, #FFCF86 0%, #FFE5BD 100%);
  border-radius: 999px;
  text-decoration: none;
  color: #2c2c2c;
  font-weight: 500;
  border: 1.65px solid;
  font-size:21px;
    border-image-source: linear-gradient(90deg, rgba(0, 0, 0, 0.28) 0%, rgba(134, 51, 0, 0.28) 100%);
  transition: all 0.3s ease;
}

.reviv-cta__button:hover {
  background: #e5b76f;
}

.reviv-cta__note {
  margin-top: 15px;
  font-size: 13px;
  color: #6b6b6b;
  font-style: italic;
}

/* Mobile */
@media (max-width: 767px) {
  .reviv-cta__heading {
    font-size: 28px;
  }

  .reviv-cta__box {
    padding: 40px 20px;
  }
}
</style>

{% schema %}
{
  "name": "SS Tiktok Reviv CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Got a Reviv video? Let's talk."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Email us with a link to your content and we'll get back to you within 1–2 business days."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore A Different Approach"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Bottom Note",
      "default": "We'll reply within 1–2 business days"
    }
  ],
  "presets": [
    {
      "name": "SS Tiktok Reviv CTA"
    }
  ]
}
{% endschema %}