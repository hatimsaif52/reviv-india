{%- style -%}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    background: #232021;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
    }
  }

  .product-navbar-wrapper {
    scrollbar-width: none;
    overflow-x: auto;
    width: 100%;
    padding: 5px 0px;
  }

  .product-navbar-desktop,
  .product-navbar-row {
    display: flex;
    justify-content: space-around;
    align-items: center;
    min-width: 900px;
  }

  .product-navbar-row {
    margin-bottom: 18px;
  }

  .product-navbar-mobile {
    display: none;
  }

  @media screen and (max-width: 850px) {
    .product-navbar-desktop {
      /* display: none; */
    }
    .product-navbar-mobile {
      display: block;
    }
  }

  .product-link {
    font-size: 14px;
    line-height: 14px;
    font-weight: 400px;
    color: #FFFFFFCC;
    text-decoration: none;
  }

  .product-link.active {
    color: #EFC98B;
    text-decoration: underline;
  }

  .product-link:hover {
    text-decoration: underline;
    color: #EFC98B;
    text-decoration: underline;
  }

  @media screen and (max-width: 850px) {
    .product-link {
      font-size: 12px;
      line-height: 12px;
    }
  }

  @media screen and (max-width: 500px) {
    .product-link {
      font-size: 12px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }} gradient color-{{ section.settings.section_color_scheme }}">
  <div class="page-width">
    <div class="product-navbar-wrapper">
      <div class="product-navbar-desktop">
        {% for product in collections.all.products %}
          {% if product.available %}
            <a
              href="{{ product.url }}"
              class="product-link{% if request.path == product.url %} active{% endif %}"
            >
              {{- product.title -}}
            </a>
          {% endif %}
        {% endfor %}
      </div>
      {% comment %}
        <div class="product-navbar-mobile">
          <div class="product-navbar-mobile">
            {% for product in collections.all.products %}
              {% if product.available %}
                {% if count == 0 %}
                  <div class="product-navbar-row">
                {% endif %}

                <a
                  href="{{ product.url }}"
                  class="product-link{% if request.path == product.url %} active{% endif %}"
                >
                  {{- product.title -}}
                </a>

                {% assign count = count | plus: 1 %}
                {% if count == 3 or forloop.last %}
                  </div>
                  {% assign count = 0 %}
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endcomment %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Product Navbar",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Product Navbar",
      "category": "Product"
    }
  ]
}
{% endschema %}
