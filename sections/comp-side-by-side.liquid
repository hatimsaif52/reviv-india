{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<style>
.comparison-columns {
  background: rgb(var(--color-background));
}

.comparison-columns__grid {
  display: grid;
  gap: 4rem;
}

@media screen and (min-width: 750px) {
  .comparison-columns__grid {
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    align-items: center;
  }
}

.comparison-column {
  text-align: center;
}

.comparison-column__inner {
  display: flex;
  gap: 1.5rem;
}

.comparison-column__inner.column {
  flex-direction: column;
}

.comparison-column__inner.column-reverse {
  flex-direction: column-reverse;
}

.comparison-column__inner.row {
  flex-direction: row;
  align-items: center;
  text-align: left;
}

.comparison-column__inner.row-reverse {
  flex-direction: row-reverse;
  align-items: center;
  text-align: left;
}

.comparison-column__icon {
    margin-bottom: 14px;
}
.comparison-column__icon img {
  width: 40px;
  height: 40px;
}

{% comment %} .comparison-column__heading {
  font-family: var(--font-heading-family);
  font-weight: var(--font-heading-weight);
  font-size: calc(var(--font-heading-scale) * 2.2rem);
} {% endcomment %}

.comparison-column__text {
  opacity: 0.85;
  line-height: 1.6;
  color: #FFFFFFA3;
}

.comparison-column__image img {
  max-width: 260px;
  width: 100%;
  height: auto;
  margin-inline: auto;
}

</style>

<section class="comparison-columns section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
  <div class="page-width" style="padding:0;">
    <div class="comparison-columns__grid">

      {% for block in section.blocks %}
        <div class="comparison-column" {{ block.shopify_attributes }}>
          <div class="comparison-column__inner {{ block.settings.layout }}">

            {% if block.settings.icon != blank %}
              <div class="comparison-column__icon">
                {{ block.settings.icon | image_url: width: 64 | image_tag }}
              </div>
            {% endif %}
            {% if block.settings.image != blank %}
              <div class="comparison-column__image">
                {{ block.settings.image | image_url: width: 700 | image_tag }}
              </div>
            {% endif %}

            <div class="comparison-column__content">
              {% if block.settings.heading != blank %}
                <h2 class="comparison-column__heading h1">
                  {{ block.settings.heading }}
                </h2>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="comparison-column__text rte">
                  {{ block.settings.text }}
                </div>
              {% endif %}
            </div>

          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</section>


{% schema %}
{
  "name": "Comparison Side By Side",
  "tag": "section",
  "class": "section",
  "settings": [
    {
    "type": "color_scheme",
    "id": "color_scheme",
    "label": "Color scheme",
    "default": "scheme-4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "What is Reviv?"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add description here</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Main Image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Layout",
          "options": [
            { "value": "column", "label": "Image Top / Text Bottom" },
            { "value": "column-reverse", "label": "Image Bottom / Text Top" },
            { "value": "row", "label": "Image Left / Text Right" },
            { "value": "row-reverse", "label": "Image Right / Text Left" }
          ],
          "default": "column"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Side By Side",
      "blocks": [
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
