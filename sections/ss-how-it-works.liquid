<section class="ss-how-it-works">
  <div class="container">
    <h2>{{ section.settings.heading }}</h2>

    <div class="grid">
      {% for block in section.blocks %}
        <div class="card">
          <span class="step">{{ block.settings.step }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
    .container{
        max-width: 1200px;
        margin:0 auto;
    }
.ss-how-it-works {
  background: #0d0c0b;
  color: #fff;
  padding: 30px 20px;
  text-align: center;
}
.ss-how-it-works h2 {
  margin-bottom: 40px;
  font-size: 28px;
  color: #fff;
  font-family: inherit !important;
  letter-spacing: 2px;
}
.ss-how-it-works .grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px;
}
.ss-how-it-works .card {
  border: 1px solid #3b3630;
  padding: 30px 80px;
  border-radius: 12px;
  background: #1f1c15;
  font-size: 18px;
}
.ss-how-it-works .step {
  display: block;
  margin-bottom: 10px;
  color: #c9a46c;
}
.ss-how-it-works .card h3 {
  margin: 10px 0;
  color: #F0E8D8;
  font-family: inherit !important;
}
.ss-how-it-works .card p {
  color: #8C7F68;
  line-height: 1.3;
}
@media(max-width: 768px){
  .ss-how-it-works .grid { grid-template-columns: 1fr; }
}
</style>

{% schema %}
{
  "name": "SS How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "HOW IT WORKS",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "step", "label": "Step Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [{ "name": "SS How It Works" }]
}
{% endschema %}