
<section class="c-phil">

  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h2 class="c-phil__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="c-phil__wrap">

      <!-- VIDEO -->
      <div class="c-phil__media">
        <div class="c-phil__video-wrap">
          {% if section.settings.show_video %}
            {% if section.settings.video != blank %}
              <div class="c-phil__video">

                <iframe
                  src="
                    {% if section.settings.video.type == 'youtube' %}
                      https://www.youtube.com/embed/{{ section.settings.video.id }}?enablejsapi=1&rel=0{% if section.settings.autoplay %}&autoplay=1&mute=1&loop=1&playlist={{ section.settings.video.id }}{% endif %}
                    {% elsif section.settings.video.type == 'vimeo' %}
                      https://player.vimeo.com/video/{{ section.settings.video.id }}{% if section.settings.autoplay %}?autoplay=1&muted=1&loop=1{% endif %}
                    {% endif %}
                  "
                  frameborder="0"
                  allow="autoplay; encrypted-media"
                  allowfullscreen
                  style="width:100%; height:100%; aspect-ratio:16/9;">
                </iframe>

                {% if section.settings.poster != blank %}
                  <img 
                    src="{{ section.settings.poster | image_url: width: 1200 }}" 
                    class="c-phil__poster"
                    style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;">
                {% endif %}

              </div>
            {% endif %}
            <div class="c-phil__play"></div>
          {% else %}
            {% if section.settings.poster != blank %}
                <img src="{{ section.settings.poster | image_url: width: 1200 }}" class="c-phil__poster_image">
            {% endif %}
          {% endif %}
        </div>
      </div>

      <!-- POINTS -->
      <div class="c-phil__list">
        {% for block in section.blocks %}
        {% if section.settings.section_content != blank %}
            {{section.settings.section_content}}
        {% endif %}

          {% case block.type %}
            {% when 'point' %}
            <h3> {{ block.settings.heading }}</h3>
              <div class="c-phil__item" {{ block.shopify_attributes }}>
                <div class="c-phil__number">
                  {{ forloop.index }}
                </div>
                <div class="c-phil__text">
                  {{ block.settings.text }}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
          <a href="{{ section.settings.button_link }}"
            class="c-hero__btn"
            style="background: {{ section.settings.btn_color }}; color: {{ section.settings.btn_text_color }}">
            {{ section.settings.button_label }} <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="M11 4H4V18C4 19.1046 4.89543 20 6 20H18C19.1046 20 20 19.1046 20 18V13" stroke="#292929" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path><path d="M9 15L20 4" stroke="#292929" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path><path d="M15 4H20V9" stroke="#292929" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></g></svg>
          </a>
      </div>

    </div>

  </div>
</section>
{% style %}
.c-phil__poster_image {
  width:100%; height:100%; max-height: 450px; object-fit:cover;border-radius: 16px;
}
.c-phil {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: #171418;
  color: #fff;
  font-family: "Roboto";
}

.c-phil__heading {
  text-align: center;
  font-size: 28px;
  margin-bottom: 40px;
  color: #fff;
}

/* LAYOUT */
.c-phil__wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}

/* STICKY VIDEO */
.c-phil__media {
  position: sticky;
  top: 100px;
}

.c-phil__video-wrap {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

.c-phil__video {
  width: 100%;
  display: block;
}

/* PLAY BUTTON */
.c-phil__video-wrap .c-phil__play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 55px;
  height: 55px;
  background: #e5c085;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform .3s ease;
}

.c-phil__play:hover {
  transform: translate(-50%, -50%) scale(1.1);
}

.c-phil__play:after {
  content: '';
  border-left: 14px solid #000;
  border-top: 8px solid transparent;
  border-bottom: 8px solid transparent;
  margin-left: 4px;
}

/* POINTS */
.c-phil__list {
  display: flex;
  flex-direction: column;
  gap: 48px;
  h3 {
        font-size: 28px;
        color: #efc98b;
        margin: 0;
        font-family: inherit !important;
        font-weight: 800;
    }
}

.c-phil__item {
  display: flex;
  gap: 10px;
  align-items: center;
  opacity: 0.7;
  transition: all .3s ease;
}

.c-phil__number {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
  transition: all .3s ease;
  background: #ffffff29;
}

.c-phil__text {
  line-height: 1.5;
}

/* HOVER EFFECT */
.c-phil__item:hover {
  opacity: 1;
}

.c-phil__item:hover .c-phil__number {
  color: #e5c085;
  border-color: #e5c085;
  box-shadow: 0 0 12px #e5c08594;
}
.c-hero__btn {
    margin-top: 32px;
    display: inline-block;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 500;
    text-decoration: none;
    transition: 0.3s ease;
}
.c-hero__btn svg{
    vertical-align: middle;
    width: 18px;
    height: 18px;
}

.c-hero__btn:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

/* RESPONSIVE */
@media(max-width: 768px){
  .c-phil__wrap {
    grid-template-columns: 1fr;
  }

  .c-phil__media {
    position: relative;
    top: auto;
  }
}
{% endstyle %}
<script>
document.addEventListener("DOMContentLoaded", function() {
  const wrap = document.querySelector(".c-phil__video-wrap");
  if (!wrap) return;

  const btn = wrap.querySelector(".c-phil__video-wrap .c-phil__play");
  const poster = wrap.querySelector(".c-phil__poster");

  if (!btn) return;

  btn.addEventListener("click", () => {
    btn.style.display = "none";
    if (poster) poster.style.display = "none";
  });
});
</script>

{% schema %}
{
  "name": "SS Phil Video Points",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Singers Phil works with often want to:"
    },
    {
      "type": "textarea",
      "id": "section_content",
      "label": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_video",
      "label": "Show Video",
      "default": true
    },
    {
      "type": "video_url",
      "id": "video",
      "label": "Video",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Video Poster/Image"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    { "type": "color", "id": "btn_color", "label": "Button Color", "default": "#ffb46e" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text Color", "default": "#000000" },
     {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],

  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
         {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Add your point text here"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "SS Phil Video Points",
      "blocks": [
        { "type": "point" },
        { "type": "point" },
        { "type": "point" }
      ]
    }
  ]
}
{% endschema %}