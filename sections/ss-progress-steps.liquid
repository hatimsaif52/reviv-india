{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}
<style>
.progress-steps-grid .image-grid__title{
 text-align: center;
}
.progress-steps-grid .grid{
  column-gap: 19px;
  row-gap: 20px;
  justify-content: center;
}
.progress-steps-grid .grid__item.grid__item--1-col {
  flex: 0 0 29%;
}
.progress-step {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-step__icon img {
  max-width: 60px;
  height: auto;
  margin-bottom: 1rem;
}

.progress-step__heading {
  font-weight: 600;
  margin: 0.2rem 0;
}

.progress-step__subtitle {
  font-size: 16px;
  color: var(--color-foreground, #444);
  margin: 0;
}

.progress-divider {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 1rem 0;
}
.progress-divider img {
  max-width: 40px;
  height: auto;
  width: 25px;
}
p.progress-step__subtitle {
    max-width: 160px;
}
@media screen and (max-width: 749px){
  .progress-steps-grid .grid{
    row-gap: 0;
  }
  .progress-steps-grid .grid__item.grid__item--1-col {
    flex: 0 0 calc(100% - 25px);
  }
  .progress-divider {
    transform: rotate(90deg);
  }
  p.progress-step__subtitle {
    max-width: 200px;
}
}
</style>
<div class="progress-steps-grid image-grid-section color-{{ section.settings.section_color_scheme }} gradient {% if section.settings.heading == blank %}no-heading{% endif %} {{ section.settings.custom_class }}">
  <div class="page-width isolate section-{{ section.id }}-padding">
    
    {%- unless section.settings.heading == blank -%}
      <div class="title-wrapper title-wrapper--no-top-margin">
        <{{ section.settings.heading_size }}
          id="SectionHeading-{{ section.id }}"
          class="image-grid__title inline-richtext{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
          {% endif %}
        >
          {{ section.settings.heading }}
        </{{ section.settings.heading_size }}>
      </div>
    {%- endunless -%}

    <div class="grid grid--{{ section.settings.columns }}-col-desktop grid--1-col-tablet-down color-{{ section.settings.color_scheme }}" role="list">
      {% for block in section.blocks %}
        <div class="grid__item{% if block.settings.column_span %} grid__item--{{ block.settings.column_span }}-col{% endif %}" {{ block.shopify_attributes }}>
          <div class="progress-step">
            
            {% if block.settings.image != blank %}
              <div class="progress-step__icon">
                <img
                  src="{{ block.settings.image | image_url: width: 200 }}"
                  alt="{{ block.settings.alt_text | escape }}"
                  loading="lazy"
                >
              </div>
            {% else %}
              <div class="progress-step__icon">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}

            {% if block.settings.block_heading != blank or block.settings.block_subtitle != blank %}
              <div class="progress-step__text">
                {% if block.settings.block_heading != blank %}
                  <p class="progress-step__heading">{{ block.settings.block_heading }}</p>
                {% endif %}
                {% if block.settings.block_subtitle != blank %}
                  <p class="progress-step__subtitle">{{ block.settings.block_subtitle }}</p>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>

        {%- if section.settings.divider_icon != blank and forloop.last == false -%}
          <div class="progress-divider">
            <img src="{{ section.settings.divider_icon | image_url: width: 60 }}" alt="Step divider" loading="lazy">
          </div>
        {%- endif -%}

      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Progress Steps",
  "tag": "section",
  "class": "section image-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Image Grid"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Number of columns",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
     {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.multirow.settings.container_color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "divider_icon",
      "label": "Divider icon (between steps)"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "grid_item",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text"
        },
        {
          "type": "text",
          "id": "block_heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "block_subtitle",
          "label": "Subtitle"
        },
        {
          "type": "range",
          "id": "column_span",
          "label": "Column span (desktop)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 1
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Progress Steps",
      "category": "Image",
      "blocks": [
        { "type": "grid_item" },
        { "type": "grid_item" },
        { "type": "grid_item" }
      ]
    }
  ]
}
{% endschema %}
