{% render 'reviv-base' %}
<div class="rv-scope" style="background:#0A0A0B; font-family:'Mulish',sans-serif;">
  <section class="rv-hero-grid" style="max-width:1240px; margin:0 auto; padding:70px 40px 40px; display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:center;">
    <div>
      <h1 style="font-family:'Cormorant Garamond',serif; font-weight:600; font-size:60px; line-height:1.02; margin:0 0 26px; letter-spacing:-0.01em;"><span style="color:#EF9A2E;">{{ section.settings.word1 }}</span> <span style="color:#ECE6DA;">{{ section.settings.word2 }}</span> <span style="color:#37A76A;">{{ section.settings.word3 }}</span></h1>
      <p style="font-size:17px; line-height:1.6; color:#B5AFA4; max-width:440px; margin:0 0 30px;">{{ section.settings.subtext }}</p>
      <ul style="list-style:none; margin:0 0 28px; padding:0; display:flex; flex-direction:column; gap:16px;">
        {%- for block in section.blocks -%}{%- if block.type == 'bullet' -%}
          <li {{ block.shopify_attributes }} style="display:flex; align-items:center; gap:14px; font-size:15.5px; color:#DDD6CA;">
            <span style="flex:none; width:26px; height:26px; border-radius:50%; border:1px solid rgba(232,163,60,0.55); display:flex; align-items:center; justify-content:center; color:#E8A33C; font-size:12px;">✓</span>
            <span>{{ block.settings.text }}</span>
          </li>
        {%- endif -%}{%- endfor -%}
      </ul>
      <p style="font-size:12px; line-height:1.55; color:#736E66; max-width:430px; margin:0 0 26px;">{{ section.settings.disclaimer }}</p>
      <a href="{{ section.settings.button_url }}" class="rv-purchase" style="display:inline-block; background:#E8A33C; color:#161206; text-decoration:none; font-weight:800; letter-spacing:0.14em; font-size:13px; padding:17px 40px; border-radius:6px;">{{ section.settings.button_label }}</a>
    </div>
    <div class="rv-hero-media" style="position:relative; height:560px;">
      <div class="rv-stripe rv-hero-card" style="position:absolute; top:0; left:20px; width:300px; height:430px; border:1.5px solid rgba(232,163,60,0.65); border-radius:150px 150px 16px 16px; overflow:hidden;">
        {% if section.settings.before_image %}<img src="{{ section.settings.before_image | image_url: width: 700 }}" alt="" style="width:100%; height:100%; object-fit:cover;">{% endif %}
        <span style="position:absolute; top:20px; left:50%; transform:translateX(-50%); background:rgba(0,0,0,0.6); color:#B8B2A6; font-family:'Space Mono',monospace; font-size:12px; padding:6px 12px; border-radius:5px; white-space:nowrap;">{{ section.settings.before_label }}</span>
      </div>
      <div class="rv-stripe rv-hero-card" style="position:absolute; bottom:0; right:0; width:300px; height:430px; border:1.5px solid rgba(232,163,60,0.9); border-radius:150px 150px 16px 16px; overflow:hidden; box-shadow:0 20px 50px rgba(0,0,0,0.5);">
        {% if section.settings.after_image %}<img src="{{ section.settings.after_image | image_url: width: 700 }}" alt="" style="width:100%; height:100%; object-fit:cover;">{% endif %}
        <span style="position:absolute; bottom:20px; left:50%; transform:translateX(-50%); background:rgba(0,0,0,0.6); color:#E8A33C; font-family:'Space Mono',monospace; font-size:12px; padding:6px 12px; border-radius:5px; white-space:nowrap;">{{ section.settings.after_label }}</span>
      </div>
    </div>
  </section>
  <div style="display:flex; align-items:center; justify-content:center; padding:28px 0 6px;">
    <span style="width:12px; height:12px; background:#EF9A2E; transform:rotate(45deg);"></span>
    <span style="width:120px; height:2px; background:#EF9A2E;"></span>
    <span style="width:11px; height:11px; border-radius:50%; background:#F3EEE4; margin:0 4px;"></span>
    <span style="width:120px; height:2px; background:#37A76A;"></span>
    <span style="width:12px; height:12px; background:#37A76A; transform:rotate(45deg);"></span>
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "word1", "label": "Headline word 1 (saffron)", "default": "Sleep" },
    { "type": "text", "id": "word2", "label": "Headline word 2 (white)", "default": "deeper." },
    { "type": "text", "id": "word3", "label": "Headline word 3 (green)", "default": "Grind less." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "A soft, precision-fit night mouthguard that cushions your teeth and calms nighttime clenching — engineered for better rest." },
    { "type": "textarea", "id": "disclaimer", "label": "Disclaimer", "default": "These statements are based on personal experience and have not been evaluated by the FSSAI. This product is not intended to diagnose, treat, cure or prevent any disease." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "PURCHASE NOW" },
    { "type": "url", "id": "button_url", "label": "Button link" },
    { "type": "image_picker", "id": "before_image", "label": "Before image" },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "BEFORE · Early 2021" },
    { "type": "image_picker", "id": "after_image", "label": "After image" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "AFTER · Early 2025" }
  ],
  "blocks": [
    { "type": "bullet", "name": "Benefit", "settings": [ { "type": "text", "id": "text", "label": "Text", "default": "Woke up with noticeably less jaw tension" } ] }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "Hero",
    "blocks": [
      { "type": "bullet", "settings": { "text": "Woke up with noticeably less jaw tension" } },
      { "type": "bullet", "settings": { "text": "Felt more rested in the mornings" } },
      { "type": "bullet", "settings": { "text": "Stopped grinding through my nights" } },
      { "type": "bullet", "settings": { "text": "My partner said I seemed less restless while sleeping" } },
      { "type": "bullet", "settings": { "text": "It just became part of my routine — I don't sleep without it" } }
    ]
  }]
}
{% endschema %}
