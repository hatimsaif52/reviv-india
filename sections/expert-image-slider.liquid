{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .section-title{
    font-size: 4rem;
    font-style: normal;
    font-weight: 400;
    letter-spacing: .06rem;
    color: rgb(229, 192, 133);
    line-height: calc(1 + .3 / max(1, var(--font-heading-scale)));
    word-break: break-word;
    margin: 35px 0 0;
  }
  .rich-text__wrapper{
    flex-direction: column;
    align-items: center;
  }
  .expert_blocks-container{
    overflow: hidden;
    width: 100%;
    position: relative;
  }
  .expert_blocks-wrapper{
    max-width: fit-content;
    display: flex;
    /* overflow-x: auto; */
    justify-content: start;
    align-items: center;
    gap: 20px;    
    padding: 0 0 10px;
    animation: scroll-left 30s linear infinite;
  }
  .expert_block{
    flex: 0 0 30%; 
  }
  .expert_block img{
      width: 100%;
      border-radius: 12px;
    }
.expert_block h3{
    font-family: Roboto, sans-serif !important;
    margin: 0;
    font-weight: 500;
    font-size: 20px;
}
.expert_block p{
    margin: 0;
    text-transform: uppercase;
    font-size: 10px;
    
}
/* Infinite scroll animation */
@keyframes scroll-left {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-126%);
  }
}

/* Optional: pause animation on hover */
.expert_blocks-container:hover .expert_blocks-wrapper {
  animation-play-state: paused;
}
  @media screen and (max-width: 750px) {
.expert_blocks-wrapper{
    gap: 10px;   
    animation: scroll-left 20s linear infinite;
  }
.expert_block{
    flex: 0 0 45%; 
  }
  .section-title{
    font-size: 3rem;
  }
  .expert_block h3{
    font-size: 16px;
    }
    @keyframes scroll-left {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-272%);
  }
}
  }
@media screen and (max-width: 515px) {
    .expert_block {
        flex: 0 0 69%;
    }
}
    {%- endstyle -%}

<div class="isolate">
  <div class="rich-text content-container color-{{ section.settings.color_scheme }} gradient{% if section.settings.full_width %} rich-text--full-width content-container--full-width{% endif %} section-{{ section.id }}-padding">
    <div class="page-width rich-text__wrapper rich-text__wrapper--{{ section.settings.desktop_content_position }}{% if section.settings.full_width %} page-width{% endif %} {% if section.settings.custom__class != blank %}{{ section.settings.custom__class }}{% endif %}">
        {%- unless section.settings.section_heading == blank -%}
            <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin multicolumn__title">
                <h2 class="section-title {{ section.settings.section_heading }}">
                {{ section.settings.section_heading }}
                </h2>
            </div>
        {%- endunless -%}

        <div class="expert_blocks-container">
            <div class="expert_blocks-wrapper">
                {%- for block in section.blocks -%}
                {%- case block.type -%}
                    {%- when 'expert_block' -%}
                    <div class="expert_block">
                        {%- render 'image-block',
                            image: block.settings.image,
                            width: block.settings.image_width,
                            alignment: block.settings.alignment,
                            block_attributes: block.shopify_attributes
                        -%}
                        <div class="expert_block-content">
                            <h3>{{ block.settings.heading }}</h3>
                            {{ block.settings.text }}
                        </div>
                    </div>
                {%- endcase -%}
                {%- endfor -%}
                {%- for block in section.blocks -%}
                {%- case block.type -%}
                    {%- when 'expert_block' -%}
                    <div class="expert_block">
                        {%- render 'image-block',
                            image: block.settings.image,
                            width: block.settings.image_width,
                            alignment: block.settings.alignment,
                            block_attributes: block.shopify_attributes
                        -%}
                        <div class="expert_block-content">
                            <h3>{{ block.settings.heading }}</h3>
                            {{ block.settings.text }}
                        </div>
                    </div>
                {%- endcase -%}
                {%- endfor -%}
            </div>
        </div>
    </div>
  </div>
</div>


{% schema %}
{
  "name": "Expert Image Slider",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.multirow.settings.container_color_scheme.label",
      "default": "scheme-6"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
  ],
  "blocks": [
    {
      "type": "expert_block",
      "name": "Expert Block",
      "settings": [
        {
            "type": "image_picker",
            "id": "image",
            "label": "Expert Image",
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "t:sections.rich-text.blocks.text.settings.text.default",
          "label": "t:sections.rich-text.blocks.text.settings.text.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Expert Image Slider",
      "blocks": [
        {
            "type": "expert_block"
        }
      ]
    }
  ]
}
{% endschema %}
