
{%- style -%}
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.reco-slider {
  position: relative;
}

.reco-card {
  background: rgb(var(--color-foreground));
  color: rgb(var(--color-background));
  border-radius: 19px;
  text-align: left;
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
}
.reco-content-container{
  padding: 20px 20px 24px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex-grow: 1;
}
.reco-badge {
    position: absolute;
    top: -28px;
    /* left: 16px; */
    background: #e7c17b;
    color: #000;
    font-size: 16px;
    padding: 6px 14px;
    border-radius: 7px;
    border-bottom-right-radius: 0;
    border-bottom-left-radius: 0;
    font-weight: 600;
    width: calc(100% - 28px);
    z-index: -1;
    height: 30px;
    text-align: center;
}

.reco-image {
  /* background: #fff;
  border-radius: 10px; */
  padding: 0;
  margin-bottom: 12px;
  img{
    width: 100%;
    height: auto;
    object-fit: cover;
  }
}

.reco-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.reco-title {
  font-size: 16px;
  font-weight: 700;
}

.reco-tag {
  font-weight: 700;
  font-size: 30px;
}

.reco-text {
  font-size: 13px;
  opacity: 0.85;
  margin-bottom: 14px;
}

.reco-pills {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 18px;
}

.reco-pill {
  background: rgba(239,201,139,0.1);
  padding: 8px 10px;
  text-align: center;
  border-radius: 20px;
  font-size: 13px;
}

.reco-btn {
  text-align: center;
  font-weight: bold;
  font-size: 16px;
  border-radius: 5px;
--buttons-radius: 5px;
}
.reco-btn.btn-reco-sec{
  background: transparent;
  color: #fff;
}

.reco-slider .slider-buttons {
    position: absolute;
    left: -2.5%;
    top: 50%;
    transform: translateY(-50%);
    width: 105%;
    justify-content: space-between;
}
.section-reco-container{
  overflow: hidden;
}
.reco-swiper-{{ section.id }} {
  overflow: visible;
}

.reco-swiper-{{ section.id }} .swiper-slide {
  height: auto;
  display: flex;
}

.reco-swiper-{{ section.id }} .reco-card {
  width: 100%;
}
.reco-slider .slider-button {
    background:rgba(229, 192, 133, 0.64);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    backdrop-filter: blur(2px);
    svg{
      width: 20px;
      height: auto;
      color: #000 !important;
    }
}
.reco-slider .slider-button.is-disabled {
  opacity: 0.3;
  pointer-events: none;
}

.reco-slider .slider-buttons {
  z-index: 5;
}
.reco-swiper-{{ section.id }} .swiper-wrapper {
  padding: 0;
}


/* Desktop spacing exactly like screenshot */
@media screen and (min-width: 990px) {
  .reco-swiper-{{ section.id }} .swiper-wrapper {
    /* gap: 24px; */
  }
}

/* Mobile peek */
@media screen and (max-width: 749px) {
  .reco-swiper-{{ section.id }} {
    padding-right: 24px;
  }
}

{%- endstyle -%}

<div class="multicolumn gradient color-{{ section.settings.section_color_scheme }}">
  <div class="page-width section-reco-container section-{{ section.id }}-padding reco-slider isolate">

<div class="swiper reco-swiper-{{ section.id }}">
  <ul
    class="swiper-wrapper"
    role="list"
  >

        {%- for block in section.blocks -%}
          <li class="swiper-slide"
            {{ block.shopify_attributes }}
          >
            <div class="reco-card gradient color-{{ section.settings.color_scheme }}">

              {% if block.settings.badge != blank %}
                <div class="reco-badge">{{ block.settings.badge }}</div>
              {% endif %}

              {% if block.settings.image != blank %}
                <div class="reco-image">
                  {{
                    block.settings.image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy'
                  }}
                </div>
              {% endif %}

              <div class="reco-content-container">
                <div class="reco-header">
                  {% if block.settings.title != blank %}
                    <div class="reco-title">{{ block.settings.title }}</div>
                  {% endif %}

                  {% if block.settings.tag != blank %}
                    <div class="reco-tag">{{ block.settings.tag }}</div>
                  {% endif %}
                </div>

                {% if block.settings.text != blank %}
                  <div class="reco-text">{{ block.settings.text }}</div>
                {% endif %}

                <div class="reco-pills">
                  {% for i in (1..4) %}
                    {% assign pill_key = 'pill_' | append: i %}
                    {% if block.settings[pill_key] != blank %}
                      <div class="reco-pill">{{ block.settings[pill_key] }}</div>
                    {% endif %}
                  {% endfor %}
                </div>

                {% if block.settings.button_label != blank %}
                  <a
                    class="button button--primary reco-btn {%if block.settings.secondary_btn == true %}btn-reco-sec{% endif %}"
                    href="{{ block.settings.button_link }}"
                  >
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
              </div>

            </div>
          </li>
        {%- endfor -%}
      </ul>

      <div class="slider-buttons">
        <button type="button" class="slider-button slider-button--prev">
          {% render 'icon-caret' %}
        </button>
        <button type="button" class="slider-button slider-button--next">
          {% render 'icon-caret' %}
        </button>
      </div>
    </div>

  </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const swiperEl = document.querySelector('.reco-swiper-{{ section.id }}');
  if (!swiperEl) return;

  const swiper = new Swiper(swiperEl, {
    slidesPerView: 1.15,
    spaceBetween: 16,
    loop: false,
    grabCursor: true,
    watchOverflow: true,   // 🔥 hides nav if not needed
    observer: true,
    observeParents: true,

    navigation: {
      nextEl: '.reco-swiper-{{ section.id }} .slider-button--next',
      prevEl: '.reco-swiper-{{ section.id }} .slider-button--prev',
      disabledClass: 'is-disabled'
    },

    breakpoints: {
      640: {
        slidesPerView: 1.3,
        spaceBetween: 16
      },
      750: {
        slidesPerView: 2,
        spaceBetween: 20
      },
      990: {
        slidesPerView: 3,
        spaceBetween: 24
      }
    },

    on: {
      init: toggleArrows,
      resize: toggleArrows,
      slideChange: toggleArrows
    }
  });

  function toggleArrows() {
    const prev = swiperEl.querySelector('.slider-button--prev');
    const next = swiperEl.querySelector('.slider-button--next');

    if (swiper.isBeginning) prev.classList.add('is-disabled');
    else prev.classList.remove('is-disabled');

    if (swiper.isEnd) next.classList.add('is-disabled');
    else next.classList.remove('is-disabled');

    // Hide arrows completely if no overflow
    if (!swiper.allowSlideNext && !swiper.allowSlidePrev) {
      prev.style.display = 'none';
      next.style.display = 'none';
    } else {
      prev.style.display = '';
      next.style.display = '';
    }
  }
});
</script>

{% schema %}
{
  "name": "Multicolumn Comp Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Section background color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Card color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Recommendation Card",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge (Recommended)" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag", "label": "Tag (R1 / R2 / R3)" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "text", "id": "pill_1", "label": "Pill 1" },
        { "type": "text", "id": "pill_2", "label": "Pill 2" },
        { "type": "text", "id": "pill_3", "label": "Pill 3" },
        { "type": "text", "id": "pill_4", "label": "Pill 4" },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "checkbox", "id": "secondary_btn", "label": "Secondary button", "default":false },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multicolumn Comp Slider",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}