    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#E5C085"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#232021"
    },
    {
      "type": "color",
      "id": "pill_bg_left",
      "label": "Before pill background",
      "default": "#E5C085"
    },
    {
      "type": "color",
      "id": "pill_text_left",
      "label": "Before pill text",
      "default": "#232021"
    },
    {
      "type": "color",
      "id": "pill_bg_right",
      "label": "After pill background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "pill_text_right",
      "label": "After pill text",
      "default": "#232021"
    }
  ],
  "presets": [
    {
      "name": "Before / After - Hero"
    }
  ]
