    {
      "type": "text_with_icon",
      "name": "Text with Icon",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Add your text here"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "select",
          "id": "icon_position",
          "options": [
            {
              "value": "start",
