{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- if section.settings.wrap_image_to_container -%}
    .image-container-style {
        padding: 20px;
        border-radius: 12px;
        background: #E5C085;
    }
  {%- endif -%}

  .video-text-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }

  .video-text-video {
    position: relative;
    width: 100%;
  }

  .video-text-video__container {
    position: relative;
    padding-bottom: 100%; /* 1:1 Aspect Ratio */
    height: 0;
    overflow: hidden;
    width: 100%;
    border-radius: 8px;
    margin-bottom: 24px;
  }

  .substack-embed-wrapper {
    margin-top: 30px;
    margin-bottom: 10px;
  }

  .video-text-video__container video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-text-readers {
    width: 100%;
    max-width: 444px;
  }

  .video-text-reader-image {
    max-width: 100%;
  }

  @media screen and (max-width: 749px) {
    .video-text-wrapper {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.section_color_scheme }}">
  <div class="page-width">
    <div class="video-text-wrapper">
      <div class="video-text-text">
        {%- for block in section.blocks -%}
          {% case block.type %}
            {%- when 'heading' -%}
              <h2 class="image-with-text__heading {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </h2>
            {%- when 'text' -%}
              <div
                class="image-with-text__text rte {{ block.settings.text_style }} image-with-text__text--{{ block.settings.text_size }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
          {%- endcase -%}
        {%- endfor -%}

        <div class="substack-embed-wrapper">
          <iframe
            src="https://reviv.substack.com/embed"
            width="100%"
            height="150"
            style="border:2px solid #EEE; background:black;"
            frameborder="0"
            scrolling="no"
          ></iframe>
        </div>

        <div class="video-text-readers">
          {{ 'readers.png' | asset_url | img_tag: 'Reader image', 'video-text-reader-image' }}
        </div>
      </div>
      <div class="video-text-video">
        <div class="video-text-video__container">
          <video controls autoplay loop muted>
            <source src="https://cdn.shopify.com/videos/c/o/v/d973ca43a4de4b7dbd6d68fb2f812f19.mp4" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        </div>
        {%- for block in section.blocks -%}
          {% case block.type %}
            {%- when 'video-text' -%}
              <div
                class="image-with-text__text rte {{ block.settings.text_style }} image-with-text__text--{{ block.settings.text_size }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "video with text",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.multirow.settings.container_color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
