{% comment %}
How It Works - Two Column with Middle Numbers
{% endcomment %}

<section class="how-it-works-sec color-{{ section.settings.section_color_scheme }} gradient{% if section.settings.full_width %} rich-text--full-width content-container--full-width{% endif %} section-{{ section.id }}-padding">
  <div class="container">
    <h2 class="section-title title">{{ section.settings.heading }}</h2>
    <div class="steps-wrapper">

      {% for block in section.blocks %}
        {% assign mod = forloop.index0 | modulo: 2 %}
        <div class="step-row">
          
          <!-- Left Column (odd steps text) -->
          <div class="step-col left color-{{ section.settings.color_scheme }}">
            {% if mod == 0 %}
              <div class="step-content step-content-left">
                {% if block.settings.pill_content != blank %}<div class="side-pill side-pill-mob"><span>{{block.settings.pill_content}}</span></div>{% endif %}
                <h3>{{ block.settings.step_title }}</h3>
                <p>{{ block.settings.step_text }}</p>
              </div>
            {% endif %}
            {% if section.settings.pills_enabled %}
              {% if mod != 0 %}
                  {% if block.settings.pill_content != blank %}<div class="side-pill side-pill-left"><span>{{block.settings.pill_content}}</span></div>{% endif %}
              {% endif %}
            {% endif %}
          </div>

          <!-- Middle Number Column -->
          <div class="step-col middle">
            <h3 class="step-number">{{ block.settings.step_number }}</h3>
          </div>

          <!-- Right Column (even steps text) -->
          <div class="step-col right color-{{ section.settings.color_scheme }}">
            {% if mod != 0 %}
              <div class="step-content step-content-right">
                {% if block.settings.pill_content != blank %}<div class="side-pill side-pill-mob"><span>{{block.settings.pill_content}}</span></div>{% endif %}
                <h3>{{ block.settings.step_title }}</h3>
                <p>{{ block.settings.step_text }}</p>
              </div>
            {% endif %}
            {% if section.settings.pills_enabled %}
              {% if mod == 0 %}
                  {% if block.settings.pill_content != blank %}<div class="side-pill side-pill-right"><span>{{block.settings.pill_content}}</span></div>{% endif %}
              {% endif %}
            {% endif %}
          </div>

        </div>
      {% endfor %}

    </div>
  </div>
</section>

<style>
.how-it-works-sec {
  padding: 40px 20px;
}
.section-title {
  text-align: center;
  margin-bottom: 50px;
}

.steps-wrapper {
  position: relative;
  max-width: 120rem;
  margin: 0 auto;
}

.steps-wrapper::before {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  border-left: 2px dashed #ccc;
  transform: translateX(-50%);
  z-index: 0;
}

.step-row {
  display: grid;
  grid-template-columns: 1fr 80px 1fr; /* left / middle / right */
  align-items: center;
  margin-bottom: 10px;
  column-gap: 30px;
    
}

.step-col {
  position: relative;
}

.step-content {
  max-width: 90%;

  h3{
font-size: 30px;}
}

.step-col.left {
  text-align: left;
  {% if section.settings.switch_direction %}
    order:2;
  {% endif %}
}

.step-col.right {
  text-align: left;
  {% if section.settings.switch_direction %}
    order:-1;
  {% endif %}
}

.step-number {
  background: #f4c481;
  color: #000;
  font-weight: light;
  font-size: 46px;
  border-radius: 50%;
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  margin: auto;
  position: relative;
}
.side-pill-right{
  text-align: start;
}
.side-pill-left{
  text-align: end;
}
.side-pill{
  span{
    text-transform: uppercase;
    background: #EFC98B33 !important;
    border: 1px solid rgba(239, 201, 139, 0.98);
    border-radius: 50px;
    padding: 4px 20px;
  }
}
.side-pill-mob{
display: none;}
@media (max-width: 768px) {
.steps-wrapper::before {
    content: none;
}
  .steps-wrapper::before {
    left: 40px;
  }
  .step-row {
    grid-template-columns: 1fr;
    grid-template-areas:
      "content";
    text-align: left;
  }
 .step-col:has(.side-pill:not(.side-pill-mob)){
    display: none; /* hide empty columns */
  }
  .step-col.middle {
    grid-area: middle;
    display: none;
  }
  .side-pill{
    display: none;
}
.side-pill-mob{
  display: block;
  text-align: left;
  font-size: 10px;
  margin-top: 5px;
  span{
    min-width: 103px;
    text-align: center;
    display: inline-block;}
}
  .step-content {
    grid-area: content;
    max-width: 100%;
    margin-left: 20px;
  }
  .step-content {
    h3 {
        font-size: 28px;
        margin-block-end: 0;
        margin-block-start: .7rem;
    }
}
}
</style>

{% schema %}
{
  "name": "How It Works - 2 Column",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "How does it work?"
    },
     {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.multirow.settings.container_color_scheme.label",
      "default": "scheme-6"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
    "type": "checkbox",
    "id": "pills_enabled",
    "label": "Enable Pills on the Other Side?",
    "default": false
    },
    {
    "type": "checkbox",
    "id": "switch_direction",
    "label": "Flip content sides",
    "default": false
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Step 1: Click the 'Join Now' button"
        },
        {
          "type": "richtext",
          "id": "step_text",
          "label": "Step Description",
          "default": "<p>Send us an email at affiliates@getreviv.com with your name, country, background, and a short note on why you'd like to join the affiliate program.</p>"
        },
        {
          "type": "text",
          "id": "pill_content",
          "label": "Pill Text"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "How It Works - 2 Column",
      "category": "Custom Sections",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
