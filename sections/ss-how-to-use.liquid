{{ 'ss-how-to-use.css' | asset_url | stylesheet_tag }}
<style>
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

</style>
<div class="how-to-use color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h2 class="how-to-use__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="how-to-use__wrapper">

      <!-- Timeline -->
      <div class="how-to-use__timeline">
        {% for block in section.blocks %}
          <div class="how-to-use__step-indicator">
            <span class="how-to-use__number">{{ forloop.index }}</span>
          </div>
        {% endfor %}
      </div>

      <!-- Steps -->
      <div class="how-to-use__grid">
        {% for block in section.blocks %}
          <div class="how-to-use__item" {{ block.shopify_attributes }}>
            <div class="how-to-use__image">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
            <p class="how-to-use__text">{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "SS How to use",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to use"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "GIF / Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Step text",
          "default": "Step description here"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "SS How to use",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
