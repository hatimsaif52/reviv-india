        "step_FYEn9E": {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "Boil Water",
            "text": "Bring a pot of water to a full boil on the stove or kettle. You need it at maximum temperature for the mold to set correctly."
          }
        },
        "step_EGpQWq": {
          "type": "step",
          "settings": {
            "number": "02",
            "title": "Soak for 60 Seconds",
            "text": "Submerge the RD1 in the boiling water for exactly 60 seconds. This softens it evenly so it can mold precisely to your teeth."
          }
        },
        "step_jXCpxH": {
          "type": "step",
          "settings": {
            "number": "03",
            "title": "Cool Briefly — 3 to 5 Seconds",
            "text": "Using a slotted spoon, remove the guard and dip it in cold water for just 3–5 seconds. Enough to handle it safely without losing its softness."
          }
        },
        "step_Wf4Ygp": {
          "type": "step",
          "settings": {
            "number": "04",
            "title": "Place and Bite Down",
            "text": "Stand in front of a mirror. Place RD1 on your lower teeth, centered in the bite channel. Gently bite down and press your fingers along the side walls to shape it around your teeth."
          }
        },
        "step_7QHHNT": {
          "type": "step",
          "settings": {
            "number": "05",
            "title": "Hold for 5 Minutes",
            "text": "Keep the guard in your mouth for at least 5 minutes without moving it. This gives the material enough time to take the exact shape of your bite."
          }
        },
        "step_FjjtCY": {
          "type": "step",
          "settings": {
            "number": "06",
            "title": "Set in Cold Water",
            "text": "Place the molded guard back in cold water for 5 minutes to lock in the shape. Once done — it's ready to wear."
          }
