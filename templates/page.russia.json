          }
        },
        "review_EjQhLy": {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "\"Кен — это человек, который мыслит нестандартно. Я — пациент, восстанавливающийся после химиотерапии, и использую этот метод уже около года. Я определённо переживаю изменения и с нетерпением жду дальнейших результатов.\"",
            "author_name": "Чарли",
            "author_description": "72-летний мужчина, который страдал от хронической боли после химиотерапии при раке 4 стадии.",
            "author_image": "shopify://shop_images/testi-1.jpg"
          }
        }
