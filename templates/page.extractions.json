    "tmj_block_UtYCDW": {
      "type": "tmj-block",
      "blocks": {
        "rich_text_7Mewpm": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>When you extract teeth I view that it is a bit like removing a structural support in a building.  </p>"
          }
        },
        "rich_text_D4G9EG": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>The structure collapses a little bit and the rest of the teeth move to find a new stability point.</p>"
          }
        },
        "rich_text_ntGJxe": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>Using a mouthguard serves as a sort of support beam that helps prevent further collapses and even starts to push things back out.</p>"
          }
        },
        "rich_text_C4jMHz": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>It works via the soft tissue and 'inflates' the skull, which allows the bones and jaw to move back to where they should be over time.</p>"
          }
        },
        "rich_text_FBPAdU": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>I find that the teeth move during this healing process to healthier positions.  Often similar to where they were pre-extraction. </p>"
          }
        }
      },
      "block_order": [
        "rich_text_7Mewpm",
        "rich_text_D4G9EG",
        "rich_text_ntGJxe",
        "rich_text_C4jMHz",
        "rich_text_FBPAdU"
      ],
      "settings": {
        "heading": "Why I do think a flat mouthguard helps",
        "padding_top": "pt-8",
        "padding_bottom": "pb-12"
      }
    },
