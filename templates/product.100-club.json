      "blocks": {
        "step_4VPUBc": {
          "type": "step",
          "settings": {
            "step_number": "‎",
            "step_title": "Welcome & Foundation",
            "step_text": "<p>We will contact you via the phone number provided, and will Kick off with a small group (8–10 people). Meet your coach and doctors. Complete your at-home test and upload your initial health metrics — or use our home nurse service.</p>",
            "pill_content": "Week 1"
          }
        },
        "step_ANMirC": {
          "type": "step",
          "settings": {
            "step_number": "‎",
            "step_title": "Personalised Goals & Plan",
            "step_text": "<p>Once your results are in, your doctor builds your personalised longevity plan. Your coach clarifies your health goals and core longevity pillars.</p>",
            "pill_content": "Week 2"
          }
        },
        "step_3qBB46": {
          "type": "step",
          "settings": {
            "step_number": "‎",
            "step_title": "Pillars of Longevity",
            "step_text": "<p>Weekly sessions help you improve nutrition, movement, recovery, and mindset.<br/><br/>Your coach reviews progress and adjusts your plan in real-time.</p>",
            "pill_content": "Weeks 3-8"
          }
        },
        "step_wrh9MJ": {
          "type": "step",
          "settings": {
            "step_number": "‎",
