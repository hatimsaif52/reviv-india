        "row_8WHLaA": {
          "type": "row",
          "settings": {
            "feature": "Size Guide",
            "col_2_text": "R1 size guide",
            "col_2_is_button": true,
            "col_2_modal": "<div class=\"size-chart-wrapper\">\n          <div class=\"size-chart__heading\">\n            Choosing the right mouthpiece size is crucial for your comfort and the effectiveness of our product. Here's\n            a straightforward guide to help you make the best choice:\n          </div>\n          <div class=\"size-chart__subheading\">Which Size Should You Choose?</div>\n          <div>\n<img src=\"https://cdn.shopify.com/s/files/1/0706/4243/4289/files/reviv-big.png?v=1765514985\" alt=\"Reviv image\" class=\"reviv2-large-image\">\n          </div>\n          <div>\n            <div class=\"d-flex\">\n              <div class=\"size-chart-specification__dot\">●</div>\n              <div class=\"size-chart-specification__content\">\n                Large Size:\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  This is suitable for most adults.\n                </div>\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Ensures a snug, comfortable fit for best effectiveness.\n                </div>\n              </div>\n            </div>\n          </div>\n          <div>\n<img src=\"https://cdn.shopify.com/s/files/1/0706/4243/4289/files/R1_Size_Chart.png?v=1762591815\" alt=\"Reviv image\" class=\"reviv2-large-image\">\n          </div>\n          <div>\n            <div class=\"d-flex\">\n              <div class=\"size-chart-specification__dot\">●</div>\n              <div class=\"size-chart-specification__content\">\n                Small Size:\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Designed for teens and adults with smaller mouths.\n                </div>\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Slightly narrower and shorter for a more precise fit.\n                </div>\n              </div>\n            </div>\n          </div>\n          <div>\n            <div class=\"size-chart__subheading\">Mouthpiece Dimensions</div>\n            <div class=\"size-chart__table-wrapper\">\n              <table class=\"size-chart-table\">\n                <tbody>\n<tr class=\"size-chart-table__header\">\n                  <th>Size</th>\n                  <th>Length</th>\n                  <th>Width</th>\n                  <th>Height</th>\n                  <th>Best for</th>\n                </tr>\n                <tr>\n                  <td>Small</td>\n                  <td>4.7 cm</td>\n                  <td>6.0 cm</td>\n                  <td>2.5 cm</td>\n                  <td>Teens &amp; small adult mouths</td>\n                </tr>\n                <tr>\n                  <td>Large</td>\n                  <td>5.0 cm</td>\n                  <td>6.7 cm</td>\n                  <td>3.0 cm</td>\n                  <td>Most adults</td>\n                </tr>\n              </tbody>\n</table>\n            </div>\n          </div>\n          <div>\n            <div class=\"size-chart__subheading\">How to measure your mouth</div>\n            <div class=\"size-chart-specification__content\">\n              1. Measure Your Mouth Width:\n              <div class=\"d-flex\">\n                <div class=\"size-chart-specification__dot\">○</div>\n                Use a soft measuring tape or a ruler.\n              </div>\n              <div class=\"d-flex\">\n                <div class=\"size-chart-specification__dot\">○</div>\n                Open your mouth slightly and measure the distance between the outer edges of your molars (back teeth).\n              </div>\n            </div>\n            <div class=\"size-chart-specification__content\">\n              2. Measure Your Mouth Length:\n              <div class=\"d-flex\">\n                <div class=\"size-chart-specification__dot\">○</div>\n                Place the measuring tape from the front of your upper teeth to the back of your molars.\n              </div>\n            </div>\n            <div class=\"size-chart-specification__content\">\n              3. Compare with Our Mouthpiece Dimensions:\n              <div class=\"d-flex\">\n                <div class=\"size-chart-specification__dot\">○</div>\n                Small Size: 4.7 cm (Length) × 6.0 cm (Width) × 2.5 cm (Height) → Best for teens &amp; small adult mouths.\n              </div>\n              <div class=\"d-flex\">\n                <div class=\"size-chart-specification__dot\">○</div>\n                Large Size: 5.0 cm (Length) x 6.7 cm (Width) x 3.0 cm (Height) → Best for most adults.\n              </div>\n              <div class=\"d-flex\">\n                <div class=\"size-chart-specification__dot\">○</div>\n                If you're between sizes, we recommend going one size up for comfort.\n              </div>\n            </div>\n          </div>\n                      <div class=\"size-chart__subheading\">Need help on how to measure?</div>\n            <div>Check out this video - <a class=\"size-chart__email\" href=\"https://youtu.be/pUDMltQ84MI\">link</a>\n</div>\n          </div>\n          <div>\n            <div class=\"size-chart__subheading\">Already found your fit? Purchase Now</div>\n            <div>\n              If you're still uncertain about which size to choose, feel free to reach out to me at\n              <span class=\"size-chart__email\">ken@getreviv.com</span>.\n            </div>\n          </div>",
            "col_3_text": "R2 size guide",
            "col_3_is_button": true,
            "col_3_modal": "<div class=\"size-chart-wrapper\">\n          <div class=\"size-chart__heading\">\n            Choosing the right mouthpiece size is crucial for your comfort and the effectiveness of our product. Here's\n            a straightforward guide to help you make the best choice:\n          </div>\n          <div class=\"size-chart__subheading\">Which Size Should You Choose?</div>\n          <div>\n<img src=\"https://cdn.shopify.com/s/files/1/0706/4243/4289/files/reviv2-size-large.png?v=1747645606\" alt=\"Reviv2 image\" class=\"reviv2-large-image\">\n          </div>\n          <div>\n            <div class=\"d-flex\">\n              <div class=\"size-chart-specification__dot\">●</div>\n              <div class=\"size-chart-specification__content\">\n                Large Size:\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  This is suitable for most adults.\n                </div>\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Ensures a snug, comfortable fit for best effectiveness.\n                </div>\n              </div>\n            </div>\n          </div>\n          <div>\n<img src=\"https://cdn.shopify.com/s/files/1/0706/4243/4289/files/reviv2-size-medium.png?v=1747645611\" alt=\"Reviv2 image\" class=\"reviv2-large-image\">\n          </div>\n          <div>\n            <div class=\"d-flex\">\n              <div class=\"size-chart-specification__dot\">●</div>\n              <div class=\"size-chart-specification__content\">\n                Medium Size:\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Designed for teens and adults with smaller mouths.\n                </div>\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Slightly narrower and shorter for a more precise fit.\n                </div>\n              </div>\n            </div>\n          </div>\n          <div>\n            <div class=\"size-chart__subheading\">Mouthpiece Dimensions</div>\n            <div class=\"size-chart__table-wrapper\">\n              <table class=\"size-chart-table\">\n                <tbody>\n<tr class=\"size-chart-table__header\">\n                  <th>Size</th>\n                  <th>Length</th>\n                  <th>Width</th>\n                  <th>Height</th>\n                  <th>Best for</th>\n                </tr>\n                <tr>\n                  <td>Large</td>\n                  <td>54 mm</td>\n                  <td>74 mm</td>\n                  <td>30 mm</td>\n                  <td>Most adults</td>\n                </tr>\n                <tr>\n                  <td>Medium</td>\n                  <td>46 mm</td>\n                  <td>63 mm</td>\n                  <td>25 mm</td>\n                  <td>Teens &amp; small adult mouths</td>\n                </tr>\n              </tbody>\n</table>\n            </div>\n          </div>\n          <div>\n            <div class=\"size-chart__subheading\">Need help on how to measure?</div>\n            <div>Check out this video - <a class=\"size-chart__email\" href=\"https://youtu.be/3qnYhe__7yU\">link</a>\n</div>\n          </div>\n          <div>\n            <div class=\"size-chart__subheading\">Already found your fit? Purchase Now</div>\n            <div>\n              If you're still uncertain about which size to choose, feel free to reach out to me at\n              <span class=\"size-chart__email\">ken@getreviv.com</span>.\n            </div>\n          </div>\n        </div>",
            "col_4_text": "R3 size guide",
            "col_4_is_button": true,
            "col_4_modal": "<div class=\"size-chart-wrapper\">\n          <div class=\"size-chart__heading\">\n            Choosing the right mouthpiece size is crucial for your comfort and the effectiveness of our product. Here's a straightforward guide to help you make the best choice:\n          </div>\n          <div class=\"size-chart__subheading\">Which Size Should You Choose?</div>\n          <div>\n            <img src=\"https://cdn.shopify.com/s/files/1/0706/4243/4289/files/R3_XL.webp?v=1764752251\" alt=\"Reviv 3 Image\" width=\"300\" height=\"auto\">\n</div>\n</div>          \n          <div>\n            <div class=\"d-flex\">\n              <div class=\"size-chart-specification__dot\">●</div>\n              <div class=\"size-chart-specification__content\">\n                XL Size:  \n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  This is suitable for adults with large mouth size.\n                </div>\n              </div>\n            </div>\n          </div>\n          <div>\n            <img src=\"https://cdn.shopify.com/s/files/1/0706/4243/4289/files/R3_L.webp?v=1764752252\" alt=\"Reviv 3 Image\" width=\"300\" height=\"auto\">\n</div>          \n          <div>\n            <div class=\"d-flex\">\n              <div class=\"size-chart-specification__dot\">●</div>\n              <div class=\"size-chart-specification__content\">\n                Large Size:  \n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  This is suitable for most adults.\n                </div>\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Ensures a snug, comfortable fit for best effectiveness.\n                </div>\n              </div>\n            </div>\n          </div>\n          <div>\n            <img src=\"https://cdn.shopify.com/s/files/1/0706/4243/4289/files/R3_M.webp?v=1764752252\" alt=\"Reviv 3 Image\" width=\"300\" height=\"auto\">\n</div>         \n          <div>\n            <div class=\"d-flex\">\n              <div class=\"size-chart-specification__dot\">●</div>\n              <div class=\"size-chart-specification__content\">\n                Medium Size:  \n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Designed for teens and adults with smaller mouths.  \n                </div>\n                <div class=\"d-flex\">\n                  <div class=\"size-chart-specification__dot\">○</div>\n                  Slightly narrower and shorter for a more precise fit\n                </div>\n              </div>\n            </div>\n          </div>\n          <div>\n            <div class=\"size-chart__subheading\">Mouthpiece Dimensions</div>\n            <div class=\"size-chart__table-wrapper\">\n              <table class=\"size-chart-table\">\n                <tbody>\n<tr class=\"size-chart-table__header\">\n                  <th>Size</th>\n                  <th>Length</th>\n                  <th>Width</th>\n                  <th>Height</th>\n                  <th>Thickness</th>\n                  <th>Best for</th>\n                </tr>\n                <tr>\n                  <td>XL</td>\n                  <td>59.6 mm</td>\n                  <td>84 mm</td>\n                  <td>27 mm</td>\n                  <td>5 mm</td>\n                  <td>Adults with large mouth sizes.</td>\n                </tr>\n                <tr>\n                  <td>Large</td>\n                  <td>53.6 mm</td>\n                  <td>73.2 mm</td>\n                  <td>26 mm</td>\n                  <td>4.2 mm</td>\n                  <td>Most adults</td>\n                </tr>\n                <tr>\n                  <td>Medium</td>\n                  <td>46 mm</td>\n                  <td>63.5 mm</td>\n                  <td>23 mm</td>\n                  <td>4.1 mm</td>\n                  <td>Teens &amp; small adult mouths</td>\n                </tr>\n              </tbody>\n</table>\n            </div>\n          </div>\n          <div class=\"size-chart__subheading\">Need help on how to measure?</div>\n            <div>Check out this video - <a class=\"size-chart__email\" href=\"https://youtu.be/gmoeX-6gsFg\">link</a>\n</div>         <div>\n            <div class=\"size-chart__subheading\">Already found your fit? Purchase Now</div>\n            <div>\n              If you're still uncertain about which size to choose, feel free to reach out to me at\n              <span class=\"size-chart__email\">ken@getreviv.com</span>.\n            </div>\n          </div>"
          }
        }
