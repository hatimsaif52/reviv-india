    "tmj_block_UtYCDW": {
      "type": "tmj-block",
      "blocks": {
        "rich_text_7Mewpm": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>Reviv acts like a door jam preventing the jaw from closing</p>"
          }
        },
        "rich_text_D4G9EG": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>This causes the soft tissue covering the jaw and skull to stretch.  </p>"
          }
        },
        "rich_text_ntGJxe": {
          "type": "rich_text",
          "name": "3rd bullet",
          "settings": {
            "rich_text": "<p>The skull inflates allowing more space for cranial bones to revert to where they should go and for jaw to return back to where it should be.</p>"
          }
        },
        "rich_text_C4jMHz": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>As the jaw reverts to where it should be the TMJ joint where it connects to the skull is able to heal.</p>"
          }
        },
        "rich_text_FBPAdU": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>As the joint heals I found that various symptoms associated with TMJ improved.</p>"
          }
        }
      },
      "block_order": [
