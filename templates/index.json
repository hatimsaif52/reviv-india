    "custom_liquid_6tdQXd": {
      "type": "custom-liquid",
      "disabled": true,
      "settings": {
        "custom_liquid": "<section class=\"what-you-get-section\">\n  <div class=\"what-you-get-section__container\">\n\n    <div class=\"what-you-get-section__three-column-grid\">\n      <div class=\"what-you-get-section__column-one\"><div class=\"what-you-get-section__section-header-wrapper\">\n      <div class=\"what-you-get-section__section-header\">\n        <div class=\"what-you-get-section__icon-wrapper\">\n          <div class=\"what-you-get-section__icon what-you-get-section__featured-icon\">\n            <div data-framer-component-type=\"SVG\" data-framer-name=\"Icon\" class=\"what-you-get-section__framer-icon\" aria-hidden=\"true\">\n              <div class=\"what-you-get-section__svgContainer\">\n               <svg width=\"22\" height=\"26\" viewBox=\"-1 -1 22 26\" fill=\"none\" id=\"svg243528306_580\">\n<path d=\"M11.1667 0.333374L0.7757 12.8025C0.368757 13.2909 0.165285 13.535 0.162176 13.7412C0.159473 13.9205 0.239355 14.0911 0.378801 14.2037C0.539208 14.3334 0.857041 14.3334 1.49271 14.3334H10L8.83334 23.6667L19.2243 11.1975C19.6312 10.7092 19.8347 10.465 19.8378 10.2588C19.8405 10.0796 19.7606 9.90902 19.6212 9.79633C19.4608 9.66671 19.143 9.66671 18.5073 9.66671H10L11.1667 0.333374Z\" stroke=\"#E5C085\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n</svg>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"what-you-get-section__heading-text\">\n          <h2 class=\"what-you-get-section__section-heading\">What You Get</h2>\n        </div>\n      </div>\n      <div class=\"what-you-get-section__supporting-text\">\n        <p class=\"what-you-get-section__section-description\">Achieve Balanced Proportions and Enhanced Flexibility for a Healthier, More Aligned Body</p>\n      </div>\n    </div></div>\n      <div class=\"what-you-get-section__column-two\">\n\n        <div class=\"what-you-get-section__feature-item\">\n          <div class=\"what-you-get-section__item-content\">\n            <div class=\"what-you-get-section__image-wrapper\">\n              <div class=\"what-you-get-section__image-container\">\n                <img src=\"https://framerusercontent.com/images/4IV3FrLTitXTh2ew2ZH13WsJApo.png\" alt=\"Reviv One Appliance\" class=\"what-you-get-section__framer-feature-image\" loading=\"lazy\">\n              </div>\n            </div>\n            <div class=\"what-you-get-section__text-content\">\n              <div class=\"what-you-get-section__description-group\">\n                <div class=\"what-you-get-section__feature-title-wrapper\">\n                  <h3 class=\"what-you-get-section__feature-title\">\n                    <span class=\"what-you-get-section__feature-title-span\">The R1/R2 Appliance</span>\n                  </h3>\n                </div>\n                <div class=\"what-you-get-section__feature-description-wrapper\">\n                  <p class=\"what-you-get-section__feature-description\">\n                    <span class=\"what-you-get-section__feature-description-span\">The appliance Ken has designed and been developing for ~10 years. Shipped to your home within a week.</span>\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"what-you-get-section__feature-item\">\n          <div class=\"what-you-get-section__item-content\">\n            <div class=\"what-you-get-section__text-content\">\n              <div class=\"what-you-get-section__description-group\">\n                <div class=\"what-you-get-section__feature-title-wrapper\">\n                  <h3 class=\"what-you-get-section__feature-title\">\n                    <span class=\"what-you-get-section__feature-title-span\">1 Year Access to Our Closed Skool Community (<a href=\"https://www.skool.com/reviv-2885\" target=\"_blank\" rel=\"noopener\" style=\"color: inherit; text-decoration: underline;\">link</a>)</span>\n                  </h3>\n                </div>\n                <div class=\"what-you-get-section__feature-description-wrapper\">\n                  <p class=\"what-you-get-section__feature-description\">\n                    <span class=\"what-you-get-section__feature-description-span\">A supportive community of others that are also going through the Reviv process.</span>\n                  </p>\n                </div>\n              </div>\n            </div>\n\n          </div>\n        </div><div class=\"what-you-get-section__feature-item\">\n          <div class=\"what-you-get-section__item-content\">\n            <div class=\"what-you-get-section__text-content\">\n              <div class=\"what-you-get-section__description-group\">\n                <div class=\"what-you-get-section__feature-title-wrapper\">\n                  <h3 class=\"what-you-get-section__feature-title\">\n                    <span class=\"what-you-get-section__feature-title-span\">Ken tracks your progress journal</span>\n                  </h3>\n                </div>\n                <div class=\"what-you-get-section__feature-description-wrapper\">\n                  <p class=\"what-you-get-section__feature-description\">\n                    <span class=\"what-you-get-section__feature-description-span\">You're provided a journal template to track how you feel and ask any questions you may have.Ken reviews and comments at least once a week.\n</span>\n                  </p>\n                <p class=\"what-you-get-section__feature-description\">\n                    <span class=\"what-you-get-section__feature-description-span\">Many users report changes during their journey. The journal is a powerful tool that helps you stay on top of tracking your experience.\n</span>\n                  </p></div>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n      </div>\n      <div class=\"what-you-get-section__column-three\">\n\n        <div class=\"what-you-get-section__feature-item\">\n          <div class=\"what-you-get-section__item-content\">\n            <div class=\"what-you-get-section__image-wrapper\">\n              <div class=\"what-you-get-section__image-container\">\n                <img src=\"https://framerusercontent.com/images/I9ftSvP2iE5I1MchDJY7JYcGE.png\" alt=\"60+ Educational Videos\" class=\"what-you-get-section__framer-feature-image\" loading=\"lazy\">\n              </div>\n            </div>\n            <div class=\"what-you-get-section__text-content\">\n              <div class=\"what-you-get-section__description-group\">\n                <div class=\"what-you-get-section__feature-title-wrapper\">\n                  <h3 class=\"what-you-get-section__feature-title\">\n                    <span class=\"what-you-get-section__feature-title-span\">60+ Educational Videos</span>\n                  </h3>\n                </div>\n                <div class=\"what-you-get-section__feature-description-wrapper\">\n                  <p class=\"what-you-get-section__feature-description\">\n                    <span class=\"what-you-get-section__feature-description-span\">Videos cover everything Ken has learned during his 10 year journey.</span>\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"what-you-get-section__feature-item\">\n          <div class=\"what-you-get-section__item-content\">\n            <div class=\"what-you-get-section__text-content\">\n              <div class=\"what-you-get-section__description-group\">\n                <div class=\"what-you-get-section__feature-title-wrapper\">\n                  <h3 class=\"what-you-get-section__feature-title\">\n                    <span class=\"what-you-get-section__feature-title-span\">Direct Access to Ken</span>\n                  </h3>\n                </div>\n                <div class=\"what-you-get-section__feature-description-wrapper\">\n                  <p class=\"what-you-get-section__feature-description\">\n                    <span class=\"what-you-get-section__feature-description-span\">Get an initial 30-minute one-on-one onboarding call with Ken. Get support from him via messages anytime during your journey.</span>\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n         <div class=\"what-you-get-section__feature-item\">\n          <div class=\"what-you-get-section__item-content\">\n            <div class=\"what-you-get-section__text-content\">\n              <div class=\"what-you-get-section__description-group\">\n                <div class=\"what-you-get-section__feature-title-wrapper\">\n                  <h3 class=\"what-you-get-section__feature-title\">\n                    <span class=\"what-you-get-section__feature-title-span\"> </span>\n                  </h3>\n                </div>\n                <div class=\"what-you-get-section__feature-description-wrapper\">\n                  <p class=\"what-you-get-section__feature-description\">\n                    <span class=\"what-you-get-section__feature-description-span\"> </span>\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n</section>\n\n<style>\n  .what-you-get-section {\n    padding-top: 70px;\n    padding-bottom: 80px;\n  }\n\n  .what-you-get-section__container {\n    max-width: 1200px;\n    margin-left: auto;\n    margin-right: auto;\n    padding-left: 25px;\n    padding-right: 25px;\n  }\n\n  .what-you-get-section__section-header-wrapper {\n    margin-bottom: 70px;\n    text-align: left; /* Changed to left align for column layout */\n  }\n\n  .what-you-get-section__section-header {\n    display: flex;\n    align-items: flex-start;\n    justify-content: flex-start;\n    gap: 15px;\n    margin-bottom: 15px;\n    flex-direction: column;\n  }\n\n  .what-you-get-section__icon-wrapper