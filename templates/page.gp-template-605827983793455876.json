    "gp_section_605958667920998998": {
      "type": "gp-section-605958667920998998",
      "settings": {
        "checksum": "0e910823cf49351c6308b2ee5027b09ae219a9506e4c6df4074f1ac8a5fb157e_1_1_1_0__1",
        "ggtraz9tDjE_text": "Happy Customers. Real Results",
        "ggxZ6oSS4pE_text": "<p>Over 20,000 people have started their reversal journey.</p><p>Here are just a few of their stories.</p>",
        "gg9jewHrxaa_text": "<p>Some people even wonder if something bigger is going on, they haven't seen the real hell which is me 2 weeks ago before starting reviv. Changing structure is the way. I’ve never felt so organized &amp; peace. I've Never felt so organized &amp; peace.</p><p>&nbsp;</p>",
