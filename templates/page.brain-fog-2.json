    "tmj_block_UtYCDW": {
      "type": "tmj-block",
      "blocks": {
        "rich_text_7Mewpm": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>Reviv acts like a door stop that prevents the jaw from closing.</p>"
          }
        },
        "rich_text_D4G9EG": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>I view that this stretches the soft tissue that covers the skull and jaw, which 'inflates' the skull.</p>"
          }
        },
        "rich_text_eg4YY8": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>By inflating the skull the cranial bones are able to move outwards and back to where they 'should' be over time.</p>"
          }
        },
        "rich_text_ntGJxe": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>This outward movement of the cranial bones is basically like 'uncrushing the skull'.  And it takes compression off the brain.</p>"
          }
        },
        "rich_text_C4jMHz": {
          "type": "rich_text",
          "settings": {
            "rich_text": "<p>As compression is taken off the brain I have seen how a number of folks (including myself) that had brain fog were able to get relief from it.</p>"
          }
        }
      },
      "block_order": [
