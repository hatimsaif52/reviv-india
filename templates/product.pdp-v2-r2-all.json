    "image_with_text_NhKBPg": {
      "type": "image-with-text",
      "blocks": {
        "heading_axfFiE": {
          "type": "heading",
          "settings": {
            "heading": "We at Reviv believe that there might be a structural root cause",
            "heading_size": "h2"
          }
        },
        "text_with_icon_Ypy9db": {
          "type": "text_with_icon",
          "settings": {
            "text": "There is essentially a set of physics that hold the body up and teeth play a critical role in this",
            "icon": "shopify://shop_images/check_gold_188bdbb7-7481-45a4-98f2-73f78fdd9f75.png",
            "icon_position": "start",
            "text_style": "body",
            "alignment": "left",
            "show_below_image": false
          }
        },
        "text_with_icon_4PT8yF": {
          "type": "text_with_icon",
          "settings": {
            "text": "Because of these physics the skull can essentially collapse inwards due to changes in the teeth",
            "icon": "shopify://shop_images/check_gold_188bdbb7-7481-45a4-98f2-73f78fdd9f75.png",
            "icon_position": "start",
            "text_style": "body",
            "alignment": "left",
            "show_below_image": false
          }
        },
        "text_with_icon_UW77ej": {
          "type": "text_with_icon",
          "settings": {
            "text": "The health of the skull is reflected by the quality of the curve of spee (how the upper and lower teeth come together)",
            "icon": "shopify://shop_images/check_gold_188bdbb7-7481-45a4-98f2-73f78fdd9f75.png",
            "icon_position": "start",
            "text_style": "body",
            "alignment": "left",
            "show_below_image": false
          }
        },
        "text_with_icon_DhgLhX": {
          "type": "text_with_icon",
          "settings": {
            "text": "Orthodontics, extractions and grinding result in the flattening of this curve of spee",
            "icon": "shopify://shop_images/check_gold_188bdbb7-7481-45a4-98f2-73f78fdd9f75.png",
            "icon_position": "start",
            "text_style": "body",
            "alignment": "left",
            "show_below_image": false
          }
        }
      },
