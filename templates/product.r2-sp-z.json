          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{%- assign sp_title = \"\" -%}\n\n{%- assign sp_b1 = \"\n<div class='gift-row'>\n  <div class='gift-left'>\n    <div class='gift-top'>\n      <span class='gift-title'>Month access to Reviv Comunity</span>\n    </div>\n    <p class='gift-sub'>\n      Join 2,000+ Reviv users, see their progress, share yours and receive direct help from Ken, the founder.\n    </p>\n  </div>\n  <div class='gift-right'>\n    <div class='gift-price'>\n      <span class='gift-old'>10$</span>\n      <span class='gift-free'>FREE</span>\n    </div>\n  </div>\n</div>\n\" -%}\n\n{%- assign sp_b2 = \"\n<div class='gift-row'>\n  <div class='gift-left'>\n    <div class='gift-top'>\n  \n      <span class='gift-title'>Mouthguard case</span>\n    </div>\n  </div>\n  <div class='gift-right'>\n    <div class='gift-price'>\n      <span class='gift-old'>10$</span>\n      <span class='gift-free'>FREE</span>\n    </div>\n  </div>\n</div>\n\" -%}\n\n{%- assign sp_b3 = \"\" -%}\n{%- assign sp_duration = \"\" -%}\n{%- assign sp_free = \"\" -%}\n{%- assign sp_old = \"\" -%}\n\n<div class=\"sp-card v3\">\n  <div class=\"sp-topgrid\">\n    {% if sp_title != \"\" %}\n      <h3 class=\"sp-title\">{{ sp_title }}</h3>\n    {% endif %}\n\n    <div class=\"sp-new\">\n      {% if sp_free != \"\" %}<span class=\"sp-free\">{{ sp_free }}</span>{% endif %}\n      {% if sp_duration != \"\" %}<span class=\"sp-duration\">{{ sp_duration }}</span>{% endif %}\n    </div>\n\n    <div class=\"sp-oldwrap\">\n      {% if sp_old != \"\" %}<span class=\"sp-old\">{{ sp_old }}</span>{% endif %}\n    </div>\n  </div>\n\n  <div class=\"sp-bottom\">\n    <ul class=\"sp-list\">\n      {% if sp_b1 != \"\" %}<li class=\"first\">{{ sp_b1 }}</li>{% endif %}\n      {% if sp_b2 != \"\" %}<li class=\"second\">{{ sp_b2 }}</li>{% endif %}\n      {% if sp_b3 != \"\" %}<li>{{ sp_b3 }}</li>{% endif %}\n    </ul>\n  </div>\n</div>\n\n<style>\n  /* ==== CONFIG ==== */\n  .sp-card.v3{\n    --sp-bg:#E5C085;\n    --sp-fg:#393737;\n    --sp-border:#ffffff;\n    --sp-free:#393737;\n    --sp-radius:18px;\n    --sp-inner-margin:10px;\n    --sp-pad:18px;\n    --sp-title-size: clamp(18px, 2vw, 24px);\n    --sp-duration-size: clamp(12px, 1.4vw, 16px);\n    --sp-free-size: clamp(18px, 2vw, 22px);\n    --sp-old-size: clamp(14px, 1.4vw, 18px);\n    --sp-bullet-size: clamp(14px, 1.4vw, 18px);\n  }\n\n  /* Card */\n  .sp-card.v3{\n    margin:0;\n    padding:var(--sp-inner-margin);\n    box-sizing:border-box;\n    max-width:100%;\n    width:100%;\n    background:var(--sp-bg);\n    color:var(--sp-fg);\n    border:2px solid var(--sp-border);\n    border-radius:var(--sp-radius);\n    overflow:hidden;\n  }\n  .sp-card.v3 *{ box-sizing:border-box; margin:0; padding:0; }\n\n  /* Top grid (structure only) */\n  .sp-topgrid{\n    display:grid;\n    grid-template-columns:minmax(0,1fr) auto auto;\n    align-items:start;\n    padding:var(--sp-pad);\n    padding-bottom:0;\n    padding-top:6px;\n    column-gap:10px;\n  }\n  .sp-title{\n    grid-column:1 / -1;\n    font-weight:800;\n    font-size:var(--sp-title-size);\n    line-height:1.15;\n    margin-bottom:12px;\n  }\n  .sp-title:empty{ display:none; }\n\n  .sp-new,\n  .sp-oldwrap{\n    display:none;\n  }\n\n  /* Bottom list */\n  .sp-bottom{\n    padding:var(--sp-pad);\n    padding-top:8px;\n  }\n  .sp-list{\n    list-style:none;\n    display:flex;\n    flex-direction:column;\n    gap:4px;\n  }\n  .sp-list li{\n    padding-left:0;\n    font-size:var(--sp-bullet-size);\n    line-height:1.3;\n  }\n  .sp-list li::before{ content:none !important; }\n\n  /* === Gift layout === */\n\n  /* One \"entity\" */\n  .gift-row{\n    display:grid;\n    grid-template-columns:minmax(0,3fr) auto; /* left / right sections */\n    column-gap:32px;\n    align-items:stretch;\n    padding:6px 0;\n  }\n\n  /* LEFT section = stacked top (title) + description */\n  .gift-left{\n    display:flex;\n    flex-direction:column;\n    row-gap:4px;\n  }\n\n  .gift-top{\n    display:flex;\n    align-items:baseline;\n    gap:8px;\n    flex-wrap:wrap;\n  }\n\n  .gift-qty{\n    font-weight:700;\n    font-size:clamp(18px, 1.6vw, 22px);\n    color:var(--sp-fg);\n  }\n\n  .gift-title{\n    font-weight:900 !important;\n    font-size:clamp(18px, 2vw, 22px);\n    line-height:1.1;\n    color:#393737;\n    font-family:var(--font-heading-family, inherit) !important;\n}\n\n  .gift-sub{\n    font-size:clamp(11px, 1.2vw, 12px); /* smaller body */\n    max-width:32rem;\n    color:#000000;\n    font-style: italic;\n opacity:0.5;\n\n  }\n\n  /* RIGHT section = price pinned bottom-right */\n  .gift-right{\n    display:flex;\n    flex-direction:column;\n    justify-content:flex-end; /* push price to bottom */\n    align-items:flex-end;\n  }\n\n  .gift-price{\n    display:flex;\n    align-items:center;\n    gap:10px;\n    font-weight:800;\ncolor:#ed5946;\n  }\n\n  .gift-old{\n    text-decoration:line-through;\n    opacity:0.7;\n    font-size:var(--sp-old-size);\n  }\n\n  .gift-free{\n    font-size:clamp(20px, 2.1vw, 26px);\n    letter-spacing:0.04em;\n  }\n\n  /* Mobile: keep SAME layout, just adjust padding / widths */\n  @media (max-width:560px){\n    .sp-topgrid{\n      grid-template-columns:1fr;\n      padding-bottom:0;\n      padding-top:4px;\n    }\n\n    /* keep two columns so order matches desktop */\n    .gift-row{\n      column-gap:16px; /* tighter gap on small screens */\n    }\n\n    .gift-sub{\n      max-width:100%;\n    }\n  }\n\n\n\n#zoko-8aec0844-b70f-11ec-b909-0242ac120002 {\n  display: none !important;\n}\n</style>"
