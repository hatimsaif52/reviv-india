    "collapsible_content_wfc3CF": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_RCbmXQ": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Who is Repod for?",
            "icon": "lightning_bolt",
            "row_content": "<p>Repod is made for anyone who uses a Reviv mouthguard, or any night guard and wants a fast, effective, and hands-free way to keep it clean and bacteria-free without harsh scrubbing.</p>",
            "page": ""
          }
        },
        "collapsible_row_4yBbK4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What are the cleaning modes?",
            "icon": "lightning_bolt",
            "row_content": "<p>Repod offers two modes:<br/>- Tap once for a 3-minute quick clean<br/>- Tap twice for a 6-minute deep clean</p><p>Please note that RePod automatically shuts off after each cycle.</p>",
            "page": ""
          }
        },
        "collapsible_row_GRLFkq": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Will Repod damage my appliance?",
            "icon": "lightning_bolt",
            "row_content": "<p>No. Repod uses gentle ultrasonic technology: no heat, no friction which makes it safe for dental appliances of all types.</p>",
            "page": ""
          }
        },
        "collapsible_row_4D3KW7": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I use any cleaning solution?",
            "icon": "lightning_bolt",
            "row_content": "<p>Daily cleaning requires only water. Avoid any harsh or abrasive cleaners.</p>",
            "page": ""
          }
        },
        "collapsible_row_PbTwYc": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I clean the Repod after use?",
            "icon": "lightning_bolt",
            "row_content": "<p>After each use, unplug the unit, pour out the water, and wipe the tank dry with a soft cloth. Never submerge the entire device in water.</p>",
            "page": ""
          }
        },
        "collapsible_row_qELnMc": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Will this work in my country?",
            "icon": "check_mark",
            "row_content": "<p>Yes. Repod supports 100–240V, so it works worldwide. The device ships with a US plug. If you're outside the US, you may need a simple plug adapter.<br/>To make it easy, we’ll refund up to $15 for the adapter, just send us the receipt.</p>",
            "page": ""
          }
        }
      },
