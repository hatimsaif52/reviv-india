  Product Terms and Conditions Checkbox
  - Renders a checkbox that must be checked before adding to cart
  - Include with: {% render 'product-term' %}
{% endcomment %}

{{ 'component-product-terms.css' | asset_url | stylesheet_tag }}
{{ 'component-modal-product-terms.css' | asset_url | stylesheet_tag }}
<style>
