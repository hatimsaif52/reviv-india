{{ 'component-size-chart.css' | asset_url | stylesheet_tag }}

<div class="size-chart-container">
  <button type="button" class="size-chart-button" id="SizeChartButton">
    <span class="size-chart-button__text">Size</span>
    <span class="size-chart-button__secondtext">SIZE CHART &gt;</span>
  </button>
</div>

<!-- Modal markup - initially hidden -->
<div class="size-chart-modal" id="SizeChartModal" style="display: none;">
  <div class="size-chart-modal__content">
    <div class="size-chart-modal__header">
      <div class="size-chart-modal__header-heading">Size Guide</div>
      <button type="button" class="size-chart-modal__close" id="size-chart-modal__close" aria-label="Close">
        &times;
      </button>
    </div>
    <div class="size-chart-modal__body">
      {% assign lowercase_title = product.url | downcase %}
      {% if lowercase_title contains 'reviv-two' %}
        <div class="size-chart-wrapper">
          <div class="size-chart__heading">
            Choosing the right mouthpiece size is crucial for your comfort and the effectiveness of our product. Here's
            a straightforward guide to help you make the best choice:
          </div>
          <div class="size-chart__subheading">Which Size Should You Choose?</div>
          <div class="size-chart__subheading">Large Size</div>
          <div>
            {{ 'reviv2-size-large.png' | file_url | img_tag: 'Reviv2 image', 'reviv2-large-image' }}
          </div>
          <div>
            <div class="d-flex size-description">
              <div class="size-chart-specification__content">
                <div class="d-flex">
                  <div class="size-chart-specification__dot">○</div>
                  This is suitable for most adults.
                </div>
                <div class="d-flex">
                  <div class="size-chart-specification__dot">○</div>
                  Ensures a snug, comfortable fit for best effectiveness.
                </div>
              </div>
            </div>
          </div>
          <div class="size-chart__subheading">Medium Size</div>
          <div>
            {{ 'reviv2-size-medium.png' | file_url | img_tag: 'Reviv2 image', 'reviv2-medium-image' }}
          </div>
          <div>
            <div class="d-flex size-description">
              <div class="size-chart-specification__content">
                <div class="d-flex">
                  <div class="size-chart-specification__dot">○</div>
                  Designed for teens and adults with smaller mouths.
                </div>
                <div class="d-flex">
                  <div class="size-chart-specification__dot">○</div>
                  Slightly narrower and shorter for a more precise fit.
                </div>
              </div>
            </div>
          </div>
          <div>
            <div class="size-chart__subheading">Mouthpiece Dimensions</div>
            <div class="size-chart__table-wrapper">
              <table class="size-chart-table">
                <tr class="size-chart-table__header">
                  <th>Size</th>
                  <th>Length</th>
                  <th>Width</th>
                  <th>Height</th>
                  <th>Best for</th>
                </tr>
                <tr>
                  <td>Large</td>
                  <td>54 mm</td>
                  <td>74 mm</td>
                  <td>30 mm</td>
                  <td>Most adults</td>
                </tr>
                <tr>
                  <td>Medium</td>
                  <td>46 mm</td>
                  <td>63 mm</td>
                  <td>25 mm</td>
                  <td>Teens & small adult mouths</td>
                </tr>
              </table>
            </div>
          </div>
          <div>
            <div class="size-chart__subheading">Need help on how to measure?</div>
            <div>Check out this video - <a class="size-chart__email" href="https://youtu.be/3qnYhe__7yU">link</a></div>
          </div>
          <div>
            <div class="size-chart__subheading">Already found your fit? Purchase Now</div>
            <div>
              If you're still uncertain about which size to choose, feel free to reach out to me at
              <span class="size-chart__email">ken@getreviv.com</span>.
            </div>
          </div>
        </div>

      {% elsif lowercase_title contains 'rd1-revivday' %}
