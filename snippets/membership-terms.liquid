    color: #007BFF;             /* Blue for normal links */
    text-decoration: underline; /* Optional underline */
  }

  .product-terms-modal__section-detail a:visited {
    color: #007BFF;             /* Keep visited links blue */
  }

  .product-terms-modal__section-detail a:hover {
    color: #0056b3;             /* Darker blue on hover */
  }
  .product-terms-modal__section-detail a {
