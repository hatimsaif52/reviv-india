{%- style -%}
  @media screen and (min-width: 990px) {
    .custom-tiktok-template-header { display: flex; justify-content: space-between; }
    .custom-tiktok-template-header .header__inline-menu { margin-top: 0 !important; }
  }
  .custom-tiktok-template-header .btn-primary { display: inline-block; margin-left: 12px; }
  .custom-tiktok-template-header .btn-primary:hover { color: #000 !important;text-decoration: none !important; }
{%- endstyle -%}
<header class="header custom-tiktok-template-header header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}">
    <header-drawer data-breakpoint="tablet">
      <details id="Details-menu-drawer-container" class="menu-drawer-container">
        <summary class="header__icon header__icon--menu header__icon--summary link focus-inset" aria-label="{{ 'sections.header.menu' | t }}">
          <span>
            {% render 'icon-hamburger' %}
            {% render 'icon-close' %}
          </span>
        </summary>
        <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
          <div class="menu-drawer__inner-container">
            <div class="menu-drawer__navigation-container">
              <nav class="menu-drawer__navigation">
                <ul class="menu-drawer__menu has-submenu list-menu" role="list">
                  <li><a href="#tiktok-how-it-works" class="menu-drawer__menu-item list-menu__item link link--text focus-inset">HOW IT WORKS</a></li>
                  <li><a href="#tiktok-earnings" class="menu-drawer__menu-item list-menu__item link link--text focus-inset">EARNINGS</a></li>
                  <li><a href="mailto:affiliates@getreviv.com?subject=Interested in Meta bonus for tiktok content" class="btn-primary menu-drawer__menu-item list-menu__item link link--text focus-inset">GET STARTED</a></li>
                </ul>
              </nav>
            </div>
          </div>
        </div>
      </details>
    </header-drawer>
    <h1 class="header__heading">    
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 50vw{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{ settings.logo | image_url: width: 600 | image_tag:
              class: 'header__heading-logo',
              widths: widths,
              height: logo_height,
              width: settings.logo_width,
              alt: logo_alt,
              sizes: sizes,
              preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </h1>
    <nav class="header__inline-menu">
      <ul class="list-menu list-menu--inline" role="list">
        <li><a href="#tiktok-how-it-works" class="header__menu-item list-menu__item link link--text focus-inset"><span>HOW IT WORKS</span></a></li>
        <li><a href="#tiktok-earnings" class="header__menu-item list-menu__item link link--text focus-inset"><span>EARNINGS</span></a></li>
        <li><a href="mailto:affiliates@getreviv.com?subject=Interested in Meta bonus for tiktok content" class="btn-primary"><span>GET STARTED</span></a></li>
      </ul>
    </nav>
</header>